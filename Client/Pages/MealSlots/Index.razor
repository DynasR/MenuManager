@page "/mealslots"
@using MenuManager.Shared.Entities
@inject MealSlotService MealSlotSvc
@inject DayPlanService DayPlanSvc
@inject ISnackbar Snackbar

<PageTitle>Meal Slots</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Meal Slots</MudText>

<MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PlaylistAdd"
           OnClick="AddRow" Class="mb-4">
    Add row
</MudButton>

@if (_pendingRows.Count > 0)
{
    <MudDataGrid T="MealSlotDraft" Items="_pendingRows" ReadOnly="false"
                 EditMode="DataGridEditMode.Cell" Hover="true" Dense="true"
                 Class="mb-0">
        <Columns>
            <PropertyColumn Property="x => x.MealType" Title="Meal Type" Editable="true">
                <EditTemplate>
                    <MudSelect T="MealType" @bind-Value="context.Item.MealType"
                               Immediate="true" Margin="Margin.Dense">
                        @foreach (var mt in Enum.GetValues<MealType>())
                        {
                            <MudSelectItem T="MealType" Value="mt">@mt</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.DayPlanId" Title="Day Plan" Editable="true">
                <CellTemplate>
                    @DayPlanDate(context.Item.DayPlanId)
                </CellTemplate>
                <EditTemplate>
                    <MudSelect T="int" @bind-Value="context.Item.DayPlanId"
                               Immediate="true" Margin="Margin.Dense">
                        @foreach (var dp in _dayPlans)
                        {
                            <MudSelectItem T="int" Value="dp.Id">@dp.Date.ToString("d")</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                   OnClick="@(() => ValidateRow(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => RemoveRow(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

<MudDataGrid T="MealSlotResponse" Items="_mealSlots" ReadOnly="false"
             EditMode="DataGridEditMode.Cell" CommittedItemChanges="OnCommittedItemChanges"
             Loading="_loading" Hover="true" Striped="true" Dense="true">
    <Columns>
        <PropertyColumn Property="x => x.MealType" Title="Meal Type" Editable="true">
            <EditTemplate>
                <MudSelect T="MealType" @bind-Value="context.Item.MealType"
                           Immediate="true" Margin="Margin.Dense">
                    @foreach (var mt in Enum.GetValues<MealType>())
                    {
                        <MudSelectItem T="MealType" Value="mt">@mt</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.DayPlanId" Title="Day Plan" Editable="true">
            <CellTemplate>
                @DayPlanDate(context.Item.DayPlanId)
            </CellTemplate>
            <EditTemplate>
                <MudSelect T="int" @bind-Value="context.Item.DayPlanId"
                           Immediate="true" Margin="Margin.Dense">
                    @foreach (var dp in _dayPlans)
                    {
                        <MudSelectItem T="int" Value="dp.Id">@dp.Date.ToString("d")</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteAsync(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private List<MealSlotResponse> _mealSlots = [];
    private List<DayPlanResponse> _dayPlans = [];
    private bool _loading = true;
    private List<MealSlotDraft> _pendingRows = [];

    private sealed class MealSlotDraft
    {
        public MealType MealType { get; set; }
        public int DayPlanId { get; set; }
    }

    private void AddRow() => _pendingRows.Add(new MealSlotDraft());

    private void RemoveRow(MealSlotDraft draft) => _pendingRows.Remove(draft);

    private async Task ValidateRow(MealSlotDraft draft)
    {
        var result = await MealSlotSvc.CreateAsync(new CreateMealSlotRequest
        {
            MealType = draft.MealType,
            DayPlanId = draft.DayPlanId
        });

        if (result.Error is null)
        {
            Snackbar.Add("Meal slot created.", Severity.Success);
            _pendingRows.Remove(draft);
            await LoadAsync();
        }
        else
        {
            var message = result.Error switch
            {
                CreateMealSlotError.DayPlanNotFound => "Day plan not found.",
                CreateMealSlotError.AlreadyExists => "This meal type already exists for this day.",
                _ => "Failed to create meal slot."
            };
            Snackbar.Add(message, Severity.Error);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private string DayPlanDate(int dayPlanId) =>
        _dayPlans.FirstOrDefault(dp => dp.Id == dayPlanId)?.Date.ToString("d") ?? "";

    private async Task LoadAsync()
    {
        _loading = true;
        _mealSlots = await MealSlotSvc.GetAllAsync();
        _dayPlans = await DayPlanSvc.GetAllAsync();
        _loading = false;
    }

    private async Task<DataGridEditFormAction> OnCommittedItemChanges(MealSlotResponse item)
    {
        var result = await MealSlotSvc.UpdateAsync(item.Id, new UpdateMealSlotRequest
        {
            MealType = item.MealType,
            DayPlanId = item.DayPlanId
        });

        if (result is not null)
        {
            Snackbar.Add("Meal slot updated.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to update meal slot.", Severity.Error);
            await LoadAsync();
        }

        return DataGridEditFormAction.Close;
    }

    private async Task DeleteAsync(MealSlotResponse mealSlot)
    {
        var deleted = await MealSlotSvc.DeleteAsync(mealSlot.Id);
        if (deleted)
        {
            Snackbar.Add("Meal slot deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Failed to delete meal slot.", Severity.Error);
        }
    }
}
