@page "/menuplan/{CustomerId:int}"
@inject MenuPlanService MenuPlanSvc
@inject CustomerService CustomerSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Menu Plans</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Menu Plans — @_customerName</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudGrid Spacing="3">
        @foreach (var slot in _slots)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Elevation="2" Style="height: 100%;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@slot.Title</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Dark">
                                @slot.StartDate — @slot.EndDate
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    @{
                        var isCurrentMonth = slot.Month == DateTime.Now.Month && slot.Year == DateTime.Now.Year;
                        var hasData = slot.MenuPlan?.HasData ?? false;
                        var btnColor = isCurrentMonth ? Color.Default : hasData ? Color.Primary : Color.Default;
                        var btnVariant = isCurrentMonth || hasData ? Variant.Filled : Variant.Outlined;
                        var btnClass = isCurrentMonth ? "btn-month-current" : "";
                    }
                    <MudCardActions>
                        <MudButton Variant="@btnVariant" Color="@btnColor" Size="Size.Small"
                                   Class="@btnClass"
                                   StartIcon="@Icons.Material.Filled.CalendarMonth"
                                   OnClick="@(() => CreateAndNavigateAsync(slot))">
                            Voir le planning
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

<style>
    .btn-month-current {
        background-color: #1B5E20 !important;
        color: #fff !important;
    }
</style>

@code {
    [Parameter] public int CustomerId { get; set; }

    private static readonly System.Globalization.CultureInfo FrCulture = new("fr-FR");

    private List<MonthSlot> _slots = [];
    private string _customerName = "";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        var customerTask = CustomerSvc.GetByIdAsync(CustomerId);
        var plansTask = MenuPlanSvc.GetByCustomerAsync(CustomerId);
        await Task.WhenAll(customerTask, plansTask);

        var customer = customerTask.Result;
        _customerName = customer?.Name ?? $"Client #{CustomerId}";

        var plans = plansTask.Result;
        _slots = BuildSlots(plans);

        _loading = false;
    }

    private static List<MonthSlot> BuildSlots(List<MenuPlanResponse> plans)
    {
        var now = DateTime.Now;
        var slots = new List<MonthSlot>(12);

        for (int i = 0; i < 12; i++)
        {
            var date = now.AddMonths(i);
            var month = date.Month;
            var year = date.Year;

            var first = new DateOnly(year, month, 1);
            var last = first.AddMonths(1).AddDays(-1);

            var title = first.ToString("MMMM yyyy", FrCulture).ToUpper();
            var startDate = first.ToString("d MMMM", FrCulture);
            var endDate = last.ToString("d MMMM", FrCulture);

            var match = plans.FirstOrDefault(p => p.Month == month && p.Year == year);

            slots.Add(new MonthSlot(month, year, title, startDate, endDate, match));
        }

        return slots;
    }

    private async Task CreateAndNavigateAsync(MonthSlot slot)
    {
        if (slot.MenuPlan is not null)
        {
            Nav.NavigateTo($"dayplans?menuPlanId={slot.MenuPlan.Id}");
            return;
        }

        var result = await MenuPlanSvc.CreateAsync(new MenuPlanRequest
        {
            Name = $"Planning {slot.Month:D2}/{slot.Year}",
            Month = slot.Month,
            Year = slot.Year,
            CustomerId = CustomerId
        });

        if (result is not null)
        {
            Nav.NavigateTo($"dayplans?menuPlanId={result.Id}");
        }
        else
        {
            Snackbar.Add("Échec de la création du menu plan.", Severity.Error);
        }
    }

    private sealed record MonthSlot(int Month, int Year, string Title, string StartDate, string EndDate, MenuPlanResponse? MenuPlan);
}
