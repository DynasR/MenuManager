@page "/menuplan/{CustomerId:int}"
@inject DailyMenuService DailyMenuSvc
@inject CustomerService CustomerSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ThemeState ThemeState
@implements IDisposable

<PageTitle>Menu Plans</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Menu Plans — @_customerName</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    @foreach (var yearGroup in _slotsByYear)
    {
        <MudText Typo="Typo.h5" Class="mt-6 mb-3">@yearGroup.Key</MudText>
        <MudDivider Class="mb-3" />
        <MudGrid Spacing="3" Class="mb-6">
            @foreach (var slot in yearGroup.Value)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="2" Style="height: 100%;">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@slot.Title</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @slot.StartDate — @slot.EndDate
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        @{
                            var isCurrentMonth = slot.Month == DateTime.Now.Month && slot.Year == DateTime.Now.Year;
                            var hasData = slot.Summary?.HasMeals ?? false;
                            var btnColor = isCurrentMonth ? Color.Success : hasData ? Color.Primary : Color.Default;
                            var btnVariant = isCurrentMonth || hasData ? Variant.Filled : Variant.Outlined;
                            var darkStyle = ThemeState.IsDarkMode
                                ? isCurrentMonth
                                    ? "background:#0B2116 !important; color:#7EC89A !important; border:1px solid #173D28 !important;"
                                    : hasData
                                        ? "background:#071525 !important; color:#5B9EC9 !important; border:1px solid #102844 !important;"
                                        : "border-color:rgba(255,255,255,0.18) !important; color:rgba(255,255,255,0.38) !important;"
                                : null;
                        }
                        <MudCardActions Style="display: flex; justify-content: space-between; align-items: center;">
                            <MudButton Variant="@btnVariant" Color="@btnColor" Size="Size.Small"
                                       Style="@darkStyle"
                                       StartIcon="@Icons.Material.Filled.CalendarMonth"
                                       OnClick="@(() => Nav.NavigateTo($"dayplans?customerId={CustomerId}&year={slot.Year}&month={slot.Month}"))">
                                Voir le planning
                            </MudButton>
                            @{
                                var cost = slot.Summary?.MonthlyCost ?? 0;
                            }
                            <MudText Typo="Typo.body2" Class="monthly-cost">
                                @(cost > 0 ? cost.ToString("N2", FrCulture) + " €" : "—")
                            </MudText>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

<style>
    .monthly-cost {
        font-family: monospace;
        color: var(--mud-palette-text-secondary);
        font-size: 0.85rem;
    }
</style>

@code {
    [Parameter] public int CustomerId { get; set; }

    private static readonly System.Globalization.CultureInfo FrCulture = new("fr-FR");

    private SortedDictionary<int, List<MonthSlot>> _slotsByYear = [];
    private string _customerName = "";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        ThemeState.OnChange += StateHasChanged;
        await LoadAsync();
    }

    public void Dispose()
    {
        ThemeState.OnChange -= StateHasChanged;
    }

    private async Task LoadAsync()
    {
        _loading = true;

        var customerTask = CustomerSvc.GetByIdAsync(CustomerId);
        var summaryTask = DailyMenuSvc.GetMonthlySummaryAsync(CustomerId);
        await Task.WhenAll(customerTask, summaryTask);

        var customer = customerTask.Result;
        _customerName = customer?.Name ?? $"Client #{CustomerId}";

        _slotsByYear = BuildSlotsByYear(summaryTask.Result);

        _loading = false;
    }

    private static SortedDictionary<int, List<MonthSlot>> BuildSlotsByYear(List<MonthlySummaryResponse> summaries)
    {
        var now = DateTime.Now;
        var currentYear = now.Year;
        var result = new SortedDictionary<int, List<MonthSlot>>();

        result[currentYear] = BuildSlotsForRange(summaries, currentYear, now.Month, 12);
        result[currentYear + 1] = BuildSlotsForRange(summaries, currentYear + 1, 1, 12);
        result[currentYear + 2] = BuildSlotsForRange(summaries, currentYear + 2, 1, 12);

        return result;
    }

    private static List<MonthSlot> BuildSlotsForRange(List<MonthlySummaryResponse> summaries, int year, int startMonth, int endMonth)
    {
        var slots = new List<MonthSlot>();

        for (int month = startMonth; month <= endMonth; month++)
        {
            var first = new DateOnly(year, month, 1);
            var last = first.AddMonths(1).AddDays(-1);

            var title = first.ToString("MMMM yyyy", FrCulture).ToUpper();
            var startDate = first.ToString("d MMMM", FrCulture);
            var endDate = last.ToString("d MMMM", FrCulture);

            var match = summaries.FirstOrDefault(s => s.Month == month && s.Year == year);

            slots.Add(new MonthSlot(month, year, title, startDate, endDate, match));
        }

        return slots;
    }

    private sealed record MonthSlot(int Month, int Year, string Title, string StartDate, string EndDate, MonthlySummaryResponse? Summary);
}
