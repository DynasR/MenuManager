@page "/suppliers"
@using MenuManager.Shared.Enums
@inject SupplierService SupplierSvc
@inject ISnackbar Snackbar

<PageTitle>Suppliers</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Suppliers</MudText>

<MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PlaylistAdd"
           OnClick="AddRow" Class="mb-4">
    Add row
</MudButton>
<MudButton Variant="Variant.Filled" Color="Color.Primary"
           Disabled="@(_pendingRows.Count == 0 && _dirtyRows.Count == 0)"
           OnClick="SaveAllAsync"
           StartIcon="@Icons.Material.Filled.SaveAlt"
           Class="mb-4 ml-2">
    Save All
</MudButton>

@if (_pendingRows.Count > 0)
{
    <MudDataGrid T="SupplierDraft" Items="_pendingRows" ReadOnly="false"
                 EditMode="DataGridEditMode.Cell" Hover="true" Dense="true"
                 Class="mb-0" Style="table-layout: fixed; width: 100%">
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="Name" Editable="true" Style="width: 11%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Name" Required="true"
                                  RequiredError="Name is required." Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.CompanyName" Title="Company" Editable="true" Style="width: 13%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.CompanyName" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Siret" Title="Siret" Editable="true" Style="width: 9%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Siret" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Phone" Title="Phone" Editable="true" Style="width: 9%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Phone" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Email" Title="Email" Editable="true" Style="width: 14%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Email" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Address" Title="Address" Editable="true" Style="width: 12%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Address" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.City" Title="City" Editable="true" Style="width: 9%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.City" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.PostalCode" Title="PostalCode" Editable="true" Style="width: 7%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.PostalCode" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Country" Title="Country" Editable="true" Style="width: 3%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Country" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Payment" Editable="true" Style="width: 8%">
                <EditTemplate>
                    <MudSelect T="PaymentType" @bind-Value="context.Item.PaymentType" Dense="true">
                        @foreach (var pt in Enum.GetValues<PaymentType>())
                        {
                            <MudSelectItem Value="@pt">@pt.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
                <CellTemplate>
                    @context.Item.PaymentType
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false" Style="width: 5%">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                   Disabled="@(string.IsNullOrWhiteSpace(context.Item.Name))"
                                   OnClick="@(() => ValidateRow(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => RemoveRow(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

<MudDataGrid T="SupplierResponse" Items="_suppliers" ReadOnly="false"
             EditMode="DataGridEditMode.Cell"
             Loading="_loading" Hover="true" Striped="true" Dense="true"
             Style="table-layout: fixed; width: 100%">
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Name" Editable="true" Style="width: 11%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Name"
                    ValueChanged="@((string val) => { context.Item.Name = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.CompanyName" Title="Company" Editable="true" Style="width: 13%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.CompanyName"
                    ValueChanged="@((string val) => { context.Item.CompanyName = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Siret" Title="Siret" Editable="true" Style="width: 9%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Siret"
                    ValueChanged="@((string val) => { context.Item.Siret = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Phone" Title="Phone" Editable="true" Style="width: 9%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Phone"
                    ValueChanged="@((string val) => { context.Item.Phone = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Email" Title="Email" Editable="true" Style="width: 14%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Email"
                    ValueChanged="@((string val) => { context.Item.Email = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Address" Title="Address" Editable="true" Style="width: 12%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Address"
                    ValueChanged="@((string val) => { context.Item.Address = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.City" Title="City" Editable="true" Style="width: 9%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.City"
                    ValueChanged="@((string val) => { context.Item.City = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.PostalCode" Title="PostalCode" Editable="true" Style="width: 7%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.PostalCode"
                    ValueChanged="@((string val) => { context.Item.PostalCode = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Country" Title="Country" Editable="true" Style="width: 3%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Country"
                    ValueChanged="@((string val) => { context.Item.Country = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Payment" Editable="true" Style="width: 8%">
            <EditTemplate>
                <MudSelect T="PaymentType"
                           Value="@context.Item.PaymentType"
                           ValueChanged="@((PaymentType val) => { context.Item.PaymentType = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                           Dense="true">
                    @foreach (var pt in Enum.GetValues<PaymentType>())
                    {
                        <MudSelectItem Value="@pt">@pt.ToString()</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
            <CellTemplate>
                @context.Item.PaymentType
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false" Style="width: 5%">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary" Size="Size.Small"
                               Disabled="@(!_dirtyRows.Contains(context.Item.Id))"
                               OnClick="@(() => SaveRow(context.Item))"
                               />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteAsync(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private List<SupplierResponse> _suppliers = [];
    private HashSet<int> _dirtyRows = new();
    private bool _loading = true;
    private List<SupplierDraft> _pendingRows = [];

    private sealed class SupplierDraft
    {
        public string Name { get; set; } = "";
        public string? CompanyName { get; set; }
        public string? Siret { get; set; }
        public string? Phone { get; set; }
        public string? Email { get; set; }
        public string? Address { get; set; }
        public string? City { get; set; }
        public string? PostalCode { get; set; }
        public string? Country { get; set; }
        public PaymentType PaymentType { get; set; } = PaymentType.TR;
    }

    private void AddRow() => _pendingRows.Add(new SupplierDraft());

    private void RemoveRow(SupplierDraft draft) => _pendingRows.Remove(draft);

    private async Task<bool> ValidateRow(SupplierDraft draft)
    {
        var result = await SupplierSvc.CreateAsync(new CreateSupplierRequest
        {
            Name = draft.Name,
            CompanyName = draft.CompanyName,
            Siret = draft.Siret,
            Phone = draft.Phone,
            Email = draft.Email,
            Address = draft.Address,
            City = draft.City,
            PostalCode = draft.PostalCode,
            Country = draft.Country,
            PaymentType = draft.PaymentType
        });

        if (result is not null)
        {
            _pendingRows.Remove(draft);
            return true;
        }

        Snackbar.Add($"Failed to create \"{draft.Name}\"", Severity.Error);
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _suppliers = await SupplierSvc.GetAllAsync();
        _dirtyRows.Clear();
        _loading = false;
    }

    private async Task SaveRow(SupplierResponse item)
    {
        var request = new UpdateSupplierRequest
        {
            Name = item.Name,
            CompanyName = item.CompanyName,
            Siret = item.Siret,
            Phone = item.Phone,
            Email = item.Email,
            Address = item.Address,
            City = item.City,
            PostalCode = item.PostalCode,
            Country = item.Country,
            PaymentType = item.PaymentType
        };
        var updated = await SupplierSvc.UpdateAsync(item.Id, request);
        if (updated == null)
            Snackbar.Add($"Failed to save \"{item.Name}\"", Severity.Error);
        else
        {
            _dirtyRows.Remove(item.Id);
            StateHasChanged();
        }
    }

    private async Task SaveAllAsync()
    {
        int created = 0, updated = 0, errors = 0;

        foreach (var draft in _pendingRows.ToList())
        {
            if (await ValidateRow(draft))
                created++;
            else
                errors++;
        }

        foreach (var id in _dirtyRows.ToList())
        {
            var item = _suppliers.FirstOrDefault(s => s.Id == id);
            if (item == null) continue;

            var request = new UpdateSupplierRequest
            {
                Name = item.Name,
                CompanyName = item.CompanyName,
                Siret = item.Siret,
                Phone = item.Phone,
                Email = item.Email,
                Address = item.Address,
                City = item.City,
                PostalCode = item.PostalCode,
                Country = item.Country,
                PaymentType = item.PaymentType
            };
            var result = await SupplierSvc.UpdateAsync(item.Id, request);
            if (result != null)
            {
                _dirtyRows.Remove(id);
                updated++;
            }
            else
            {
                Snackbar.Add($"Failed to save \"{item.Name}\"", Severity.Error);
                errors++;
            }
        }

        if (created + updated > 0)
        {
            var parts = new List<string>();
            if (created > 0) parts.Add($"{created} created");
            if (updated > 0) parts.Add($"{updated} updated");
            Snackbar.Add(string.Join(", ", parts), Severity.Success);
            await LoadAsync();
        }
    }

    private async Task DeleteAsync(SupplierResponse supplier)
    {
        var deleted = await SupplierSvc.DeleteAsync(supplier.Id);
        if (deleted)
        {
            Snackbar.Add($"Supplier \"{supplier.Name}\" deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Failed to delete supplier.", Severity.Error);
        }
    }
}
