@page "/suppliers"
@inject SupplierService SupplierSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Fournisseurs</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Fournisseurs</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
           OnClick="@(() => Nav.NavigateTo("/suppliers/create"))" Class="mb-4">
    Nouveau
</MudButton>

<MudTable Items="_suppliers" Hover="true" Striped="true" Loading="_loading">
    <HeaderContent>
        <MudTh>Nom</MudTh>
        <MudTh>Societe</MudTh>
        <MudTh>Siret</MudTh>
        <MudTh>Telephone</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Ville</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nom">@context.Name</MudTd>
        <MudTd DataLabel="Societe">@context.CompanyName</MudTd>
        <MudTd DataLabel="Siret">@context.Siret</MudTd>
        <MudTd DataLabel="Telephone">@context.Phone</MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Ville">@context.City</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                           OnClick="@(() => Nav.NavigateTo($"/suppliers/edit/{context.Id}"))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                           OnClick="@(() => DeleteAsync(context))" />
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<SupplierResponse> _suppliers = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _suppliers = await SupplierSvc.GetAllAsync();
        _loading = false;
    }

    private async Task DeleteAsync(SupplierResponse supplier)
    {
        var deleted = await SupplierSvc.DeleteAsync(supplier.Id);
        if (deleted)
        {
            Snackbar.Add($"Fournisseur \"{supplier.Name}\" supprime.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Impossible de supprimer ce fournisseur.", Severity.Error);
        }
    }
}
