@page "/suppliers/create"
@inject SupplierService SupplierSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Nouveau fournisseur</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Nouveau fournisseur</MudText>

<MudForm @ref="_form" @bind-IsValid="_isValid">
    <MudTextField @bind-Value="_dto.Name" Label="Nom" Required="true"
                  RequiredError="Le nom est obligatoire." MaxLength="100" Class="mb-3" />
    <MudTextField @bind-Value="_dto.CompanyName" Label="Societe" MaxLength="100" Class="mb-3" />
    <MudTextField @bind-Value="_dto.Siret" Label="Siret" MaxLength="14" Class="mb-3" />
    <MudTextField @bind-Value="_dto.Phone" Label="Telephone" MaxLength="20" Class="mb-3" />
    <MudTextField @bind-Value="_dto.Email" Label="Email" MaxLength="100" Class="mb-3" />
    <MudTextField @bind-Value="_dto.Address" Label="Adresse" MaxLength="200" Class="mb-3" />
    <MudTextField @bind-Value="_dto.City" Label="Ville" MaxLength="100" Class="mb-3" />
    <MudTextField @bind-Value="_dto.PostalCode" Label="Code postal" MaxLength="10" Class="mb-3" />
    <MudTextField @bind-Value="_dto.Country" Label="Pays" MaxLength="100" Class="mb-3" />
</MudForm>

<MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
           Disabled="!_isValid" Class="mt-4 mr-2">
    Enregistrer
</MudButton>
<MudButton OnClick="@(() => Nav.NavigateTo("/suppliers"))" Class="mt-4">
    Annuler
</MudButton>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private CreateSupplierRequest _dto = new();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        var result = await SupplierSvc.CreateAsync(_dto);
        if (result is not null)
        {
            Snackbar.Add("Fournisseur cree.", Severity.Success);
            Nav.NavigateTo("/suppliers");
        }
        else
        {
            Snackbar.Add("Erreur lors de la creation.", Severity.Error);
        }
    }
}
