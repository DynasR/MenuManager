@page "/customers/edit/{Id:int}"
@inject CustomerService CustomerSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Modifier le client</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Modifier le client</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudForm @ref="_form" @bind-IsValid="_isValid">
        <MudTextField @bind-Value="_dto.Name" Label="Nom" Required="true"
                      RequiredError="Le nom est obligatoire." MaxLength="100" Class="mb-3" />
        <MudTextField @bind-Value="_dto.Phone" Label="Telephone" MaxLength="20" Class="mb-3" />
        <MudTextField @bind-Value="_dto.Email" Label="Email" MaxLength="100" Class="mb-3" />
        <MudTextField @bind-Value="_dto.Address" Label="Adresse" MaxLength="200" Class="mb-3" />
        <MudTextField @bind-Value="_dto.City" Label="Ville" MaxLength="100" Class="mb-3" />
        <MudTextField @bind-Value="_dto.PostalCode" Label="Code postal" MaxLength="10" Class="mb-3" />
        <MudTextField @bind-Value="_dto.Country" Label="Pays" MaxLength="100" Class="mb-3" />
    </MudForm>

    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
               Disabled="!_isValid" Class="mt-4 mr-2">
        Enregistrer
    </MudButton>
    <MudButton OnClick="@(() => Nav.NavigateTo("/customers"))" Class="mt-4">
        Annuler
    </MudButton>
}

@code {
    [Parameter] public int Id { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private UpdateCustomerRequest _dto = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var customer = await CustomerSvc.GetByIdAsync(Id);

        if (customer is null)
        {
            Snackbar.Add("Client introuvable.", Severity.Error);
            Nav.NavigateTo("/customers");
            return;
        }

        _dto.Name = customer.Name;
        _dto.Phone = customer.Phone;
        _dto.Email = customer.Email;
        _dto.Address = customer.Address;
        _dto.City = customer.City;
        _dto.PostalCode = customer.PostalCode;
        _dto.Country = customer.Country;

        _loading = false;
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        var result = await CustomerSvc.UpdateAsync(Id, _dto);
        if (result is not null)
        {
            Snackbar.Add("Client mis a jour.", Severity.Success);
            Nav.NavigateTo("/customers");
        }
        else
        {
            Snackbar.Add("Erreur lors de la mise a jour.", Severity.Error);
        }
    }
}
