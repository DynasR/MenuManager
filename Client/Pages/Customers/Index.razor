@page "/customers"
@inject CustomerService CustomerSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Customers</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Customers</MudText>

<MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PlaylistAdd"
           OnClick="AddRow" Class="mb-4">
    Add row
</MudButton>
<MudButton Variant="Variant.Filled" Color="Color.Primary"
           Disabled="@(_pendingRows.Count == 0 && _dirtyRows.Count == 0)"
           OnClick="SaveAllAsync"
           StartIcon="@Icons.Material.Filled.SaveAlt"
           Class="mb-4 ml-2">
    Save All
</MudButton>

@if (_pendingRows.Count > 0)
{
    <MudDataGrid T="CustomerDraft" Items="_pendingRows" ReadOnly="false"
                 EditMode="DataGridEditMode.Cell" Hover="true" Dense="true"
                 Class="mb-0" Style="table-layout: fixed; width: 100%">
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="Name" Editable="true" Style="width: 15%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Name" Required="true"
                                  RequiredError="Name is required." Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Phone" Title="Phone" Editable="true" Style="width: 12%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Phone" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Email" Title="Email" Editable="true" Style="width: 20%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Email" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Address" Title="Address" Editable="true" Style="width: 18%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Address" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.City" Title="City" Editable="true" Style="width: 12%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.City" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.PostalCode" Title="PostalCode" Editable="true" Style="width: 8%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.PostalCode" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Country" Title="Country" Editable="true" Style="width: 10%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Country" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false" Style="width: 5%">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                   Disabled="@(string.IsNullOrWhiteSpace(context.Item.Name))"
                                   OnClick="@(() => ValidateRow(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => RemoveRow(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

<MudDataGrid T="CustomerResponse" Items="_customers" ReadOnly="false"
             EditMode="DataGridEditMode.Cell"
             Loading="_loading" Hover="true" Striped="true" Dense="true"
             Style="table-layout: fixed; width: 100%">
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Name" Editable="true" Style="width: 15%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Name"
                    ValueChanged="@((string val) => { context.Item.Name = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Phone" Title="Phone" Editable="true" Style="width: 12%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Phone"
                    ValueChanged="@((string val) => { context.Item.Phone = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Email" Title="Email" Editable="true" Style="width: 20%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Email"
                    ValueChanged="@((string val) => { context.Item.Email = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Address" Title="Address" Editable="true" Style="width: 18%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Address"
                    ValueChanged="@((string val) => { context.Item.Address = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.City" Title="City" Editable="true" Style="width: 12%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.City"
                    ValueChanged="@((string val) => { context.Item.City = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.PostalCode" Title="PostalCode" Editable="true" Style="width: 8%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.PostalCode"
                    ValueChanged="@((string val) => { context.Item.PostalCode = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Country" Title="Country" Editable="true" Style="width: 10%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Country"
                    ValueChanged="@((string val) => { context.Item.Country = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false" Style="width: 5%">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary" Size="Size.Small"
                               Disabled="@(!_dirtyRows.Contains(context.Item.Id))"
                               OnClick="@(() => SaveRow(context.Item))"
                               />
                <MudTooltip Text="Menu Plans">
                    <MudIconButton Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Default" Size="Size.Small"
                                   OnClick="@(() => Nav.NavigateTo($"menuplan/{context.Item.Id}"))" />
                </MudTooltip>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteAsync(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private List<CustomerResponse> _customers = [];
    private HashSet<int> _dirtyRows = new();
    private bool _loading = true;
    private List<CustomerDraft> _pendingRows = [];

    private sealed class CustomerDraft
    {
        public string Name { get; set; } = "";
        public string? Phone { get; set; }
        public string? Email { get; set; }
        public string? Address { get; set; }
        public string? City { get; set; }
        public string? PostalCode { get; set; }
        public string? Country { get; set; }
    }

    private void AddRow() => _pendingRows.Add(new CustomerDraft());

    private void RemoveRow(CustomerDraft draft) => _pendingRows.Remove(draft);

    private async Task<bool> ValidateRow(CustomerDraft draft)
    {
        var result = await CustomerSvc.CreateAsync(new CreateCustomerRequest
        {
            Name = draft.Name,
            Phone = draft.Phone,
            Email = draft.Email,
            Address = draft.Address,
            City = draft.City,
            PostalCode = draft.PostalCode,
            Country = draft.Country
        });

        if (result is not null)
        {
            _pendingRows.Remove(draft);
            return true;
        }

        Snackbar.Add($"Failed to create \"{draft.Name}\"", Severity.Error);
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _customers = await CustomerSvc.GetAllAsync();
        _dirtyRows.Clear();
        _loading = false;
    }

    private async Task SaveRow(CustomerResponse item)
    {
        var request = new UpdateCustomerRequest
        {
            Name = item.Name,
            Phone = item.Phone,
            Email = item.Email,
            Address = item.Address,
            City = item.City,
            PostalCode = item.PostalCode,
            Country = item.Country
        };
        var updated = await CustomerSvc.UpdateAsync(item.Id, request);
        if (updated == null)
            Snackbar.Add($"Failed to save \"{item.Name}\"", Severity.Error);
        else
        {
            _dirtyRows.Remove(item.Id);
            StateHasChanged();
        }
    }

    private async Task SaveAllAsync()
    {
        int created = 0, updated = 0, errors = 0;

        foreach (var draft in _pendingRows.ToList())
        {
            if (await ValidateRow(draft))
                created++;
            else
                errors++;
        }

        foreach (var id in _dirtyRows.ToList())
        {
            var item = _customers.FirstOrDefault(c => c.Id == id);
            if (item == null) continue;

            var request = new UpdateCustomerRequest
            {
                Name = item.Name,
                Phone = item.Phone,
                Email = item.Email,
                Address = item.Address,
                City = item.City,
                PostalCode = item.PostalCode,
                Country = item.Country
            };
            var result = await CustomerSvc.UpdateAsync(item.Id, request);
            if (result != null)
            {
                _dirtyRows.Remove(id);
                updated++;
            }
            else
            {
                Snackbar.Add($"Failed to save \"{item.Name}\"", Severity.Error);
                errors++;
            }
        }

        if (created + updated > 0)
        {
            var parts = new List<string>();
            if (created > 0) parts.Add($"{created} created");
            if (updated > 0) parts.Add($"{updated} updated");
            Snackbar.Add(string.Join(", ", parts), Severity.Success);
            await LoadAsync();
        }
    }

    private async Task DeleteAsync(CustomerResponse customer)
    {
        var deleted = await CustomerSvc.DeleteAsync(customer.Id);
        if (deleted)
        {
            Snackbar.Add($"Customer \"{customer.Name}\" deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Failed to delete customer.", Severity.Error);
        }
    }
}
