@page "/customers"
@inject CustomerService CustomerSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Clients</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Clients</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
           OnClick="@(() => Nav.NavigateTo("/customers/create"))" Class="mb-4">
    Nouveau
</MudButton>

<MudTable Items="_customers" Hover="true" Striped="true" Loading="_loading">
    <HeaderContent>
        <MudTh>Nom</MudTh>
        <MudTh>Telephone</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Ville</MudTh>
        <MudTh>Pays</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nom">@context.Name</MudTd>
        <MudTd DataLabel="Telephone">@context.Phone</MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Ville">@context.City</MudTd>
        <MudTd DataLabel="Pays">@context.Country</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                           OnClick="@(() => Nav.NavigateTo($"/customers/edit/{context.Id}"))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                           OnClick="@(() => DeleteAsync(context))" />
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<CustomerResponse> _customers = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _customers = await CustomerSvc.GetAllAsync();
        _loading = false;
    }

    private async Task DeleteAsync(CustomerResponse customer)
    {
        var deleted = await CustomerSvc.DeleteAsync(customer.Id);
        if (deleted)
        {
            Snackbar.Add($"Client \"{customer.Name}\" supprime.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Impossible de supprimer ce client.", Severity.Error);
        }
    }
}
