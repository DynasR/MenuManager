@page "/mealslotitems"
@using MenuManager.Shared.Entities
@inject MealSlotItemService MealSlotItemSvc
@inject MealSlotService MealSlotSvc
@inject DayPlanService DayPlanSvc
@inject ItemService ItemSvc
@inject ISnackbar Snackbar

<PageTitle>Meal Slot Items</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Meal Slot Items</MudText>

<MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PlaylistAdd"
           OnClick="AddRow" Class="mb-4">
    Add row
</MudButton>

@if (_pendingRows.Count > 0)
{
    <MudDataGrid T="MealSlotItemDraft" Items="_pendingRows" ReadOnly="false"
                 EditMode="DataGridEditMode.Cell" Hover="true" Dense="true"
                 Class="mb-0">
        <Columns>
            <PropertyColumn Property="x => x.MealSlotId" Title="Meal Slot" Editable="true">
                <CellTemplate>
                    @MealSlotLabel(context.Item.MealSlotId)
                </CellTemplate>
                <EditTemplate>
                    <MudSelect T="int" @bind-Value="context.Item.MealSlotId"
                               Immediate="true" Margin="Margin.Dense">
                        @foreach (var ms in _mealSlots)
                        {
                            <MudSelectItem T="int" Value="ms.Id">@MealSlotLabel(ms.Id)</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ItemId" Title="Item" Editable="true">
                <CellTemplate>
                    @ItemName(context.Item.ItemId)
                </CellTemplate>
                <EditTemplate>
                    <MudSelect T="int" @bind-Value="context.Item.ItemId"
                               Immediate="true" Margin="Margin.Dense">
                        @foreach (var item in _items)
                        {
                            <MudSelectItem T="int" Value="item.Id">@item.Name</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Quantity" Title="Quantity" Editable="true">
                <EditTemplate>
                    <MudNumericField T="decimal" @bind-Value="context.Item.Quantity"
                                     Min="0m" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Notes" Title="Notes" Editable="true">
                <EditTemplate>
                    <MudTextField @bind-Value="context.Item.Notes" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                   OnClick="@(() => ValidateRow(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => RemoveRow(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

<MudDataGrid T="MealSlotItemResponse" Items="_mealSlotItems" ReadOnly="false"
             EditMode="DataGridEditMode.Cell" CommittedItemChanges="OnCommittedItemChanges"
             Loading="_loading" Hover="true" Striped="true" Dense="true">
    <Columns>
        <PropertyColumn Property="x => x.MealSlotId" Title="Meal Slot" Editable="true">
            <CellTemplate>
                @MealSlotLabel(context.Item.MealSlotId)
            </CellTemplate>
            <EditTemplate>
                <MudSelect T="int" @bind-Value="context.Item.MealSlotId"
                           Immediate="true" Margin="Margin.Dense">
                    @foreach (var ms in _mealSlots)
                    {
                        <MudSelectItem T="int" Value="ms.Id">@MealSlotLabel(ms.Id)</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.ItemId" Title="Item" Editable="true">
            <CellTemplate>
                @context.Item.ItemName
            </CellTemplate>
            <EditTemplate>
                <MudSelect T="int" @bind-Value="context.Item.ItemId"
                           Immediate="true" Margin="Margin.Dense">
                    @foreach (var item in _items)
                    {
                        <MudSelectItem T="int" Value="item.Id">@item.Name</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Quantity" Title="Quantity" Editable="true">
            <EditTemplate>
                <MudNumericField T="decimal" @bind-Value="context.Item.Quantity"
                                 Min="0m" Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Notes" Title="Notes" Editable="true">
            <EditTemplate>
                <MudTextField @bind-Value="context.Item.Notes" Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteAsync(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private List<MealSlotItemResponse> _mealSlotItems = [];
    private List<MealSlotResponse> _mealSlots = [];
    private List<DayPlanResponse> _dayPlans = [];
    private List<ItemResponse> _items = [];
    private bool _loading = true;
    private List<MealSlotItemDraft> _pendingRows = [];

    private sealed class MealSlotItemDraft
    {
        public int MealSlotId { get; set; }
        public int ItemId { get; set; }
        public decimal Quantity { get; set; }
        public string? Notes { get; set; }
    }

    private void AddRow() => _pendingRows.Add(new MealSlotItemDraft());

    private void RemoveRow(MealSlotItemDraft draft) => _pendingRows.Remove(draft);

    private async Task ValidateRow(MealSlotItemDraft draft)
    {
        var result = await MealSlotItemSvc.CreateAsync(new CreateMealSlotItemRequest
        {
            MealSlotId = draft.MealSlotId,
            ItemId = draft.ItemId,
            Quantity = draft.Quantity,
            Notes = draft.Notes
        });

        if (result is not null)
        {
            Snackbar.Add("Meal slot item created.", Severity.Success);
            _pendingRows.Remove(draft);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Meal slot or item not found.", Severity.Error);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private string MealSlotLabel(int mealSlotId)
    {
        var ms = _mealSlots.FirstOrDefault(m => m.Id == mealSlotId);
        if (ms is null) return "";
        var dp = _dayPlans.FirstOrDefault(d => d.Id == ms.DayPlanId);
        var date = dp?.Date.ToString("d") ?? "?";
        return $"{ms.MealType} — {date}";
    }

    private string ItemName(int itemId) =>
        _items.FirstOrDefault(i => i.Id == itemId)?.Name ?? "";

    private async Task LoadAsync()
    {
        _loading = true;
        _mealSlotItems = await MealSlotItemSvc.GetAllAsync();
        _mealSlots = await MealSlotSvc.GetAllAsync();
        _dayPlans = await DayPlanSvc.GetAllAsync();
        _items = await ItemSvc.GetAllAsync();
        _loading = false;
    }

    private async Task<DataGridEditFormAction> OnCommittedItemChanges(MealSlotItemResponse item)
    {
        var result = await MealSlotItemSvc.UpdateAsync(item.Id, new UpdateMealSlotItemRequest
        {
            MealSlotId = item.MealSlotId,
            ItemId = item.ItemId,
            Quantity = item.Quantity,
            Notes = item.Notes
        });

        if (result is not null)
        {
            Snackbar.Add("Meal slot item updated.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to update meal slot item.", Severity.Error);
            await LoadAsync();
        }

        return DataGridEditFormAction.Close;
    }

    private async Task DeleteAsync(MealSlotItemResponse mealSlotItem)
    {
        var deleted = await MealSlotItemSvc.DeleteAsync(mealSlotItem.Id);
        if (deleted)
        {
            Snackbar.Add("Meal slot item deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Failed to delete meal slot item.", Severity.Error);
        }
    }
}
