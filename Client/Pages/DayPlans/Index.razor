@page "/dayplans"
@using MenuManager.Client.Helpers
@using MenuManager.Shared.Enums
@inject DailyMenuService DailyMenuSvc
@inject MealService MealSvc
@inject MealItemService MealItemSvc
@inject ItemService ItemSvc
@inject RecipeService RecipeSvc
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject RightPanelState RightPanel
@inject NavigationManager Nav
@inject ThemeState ThemeState
@inject ItemSupplierCache ItemSupplierCache
@implements IDisposable

<PageTitle>Day Plans</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Day Plans</MudText>

@if (CustomerId == 0 || Year == 0 || Month == 0)
{
    <MudAlert Severity="Severity.Error">Invalid parameters.</MudAlert>
}
else
{
    <div class="month-nav-bar mb-4">
        @foreach (var m in _monthNav)
        {
            var isCurrent = m.Month == Month && m.Year == Year;
            var color = isCurrent ? Color.Success : m.HasData ? Color.Primary : Color.Default;
            var variant = isCurrent ? Variant.Filled : m.HasData ? Variant.Filled : Variant.Outlined;
            var chipClass = isCurrent ? "month-nav-chip month-current" : "month-nav-chip";
            var size = isCurrent ? Size.Medium : Size.Small;
            var darkStyle = ThemeState.IsDarkMode
                ? isCurrent
                    ? "background:#0B2116 !important; color:#7EC89A !important; border:1px solid #173D28 !important;"
                    : m.HasData
                        ? "background:#071525 !important; color:#5B9EC9 !important; border:1px solid #102844 !important;"
                        : "border-color:rgba(255,255,255,0.18) !important; color:rgba(255,255,255,0.38) !important;"
                : null;
            <MudTooltip Text="@m.Label" Placement="Placement.Bottom">
                <MudButton Size="@size" Variant="@variant" Color="@color"
                           Class="@chipClass" Style="@darkStyle"
                           OnClick="@(() => { if (!isCurrent) NavigateToMonth(m); })">
                    @m.Short
                </MudButton>
            </MudTooltip>
        }
    </div>

    @if (_saving)
    {
        <div class="dayplan-overlay"></div>
    }

    <div class="dayplan-grid-wrapper">
    <div class="dayplan-grid">
        @* Header row *@
        <div class="dayplan-grid-header">
            <MudText Typo="Typo.subtitle2">Date</MudText>
        </div>
        @foreach (var mt in _mealTypes)
        {
            var hmt = mt;
            var hmtKey = ((int)hmt).ToString();
            var colTotal = GetColumnTotal(hmt);
            <div class="dayplan-grid-header"
                 data-colmealtype="@((int)hmt)"
                 @onmousedown="@(() => { _ = JS.InvokeVoidAsync("addColumnPrimed", hmtKey); })"
                 @onmouseup="@(() => { _ = JS.InvokeVoidAsync("removeColumnPrimed", hmtKey); })"
                 @onmouseleave="@(() => { _ = JS.InvokeVoidAsync("removeColumnPrimed", hmtKey); })"
                 @ondblclick="@(() => ClearColumnAsync(hmt))">
                <MudText Typo="Typo.subtitle2">@hmt</MudText>
                @if (colTotal > 0)
                {
                    <span class="dayplan-cost-total">@colTotal.ToString("C", _frCulture)</span>
                }
            </div>
        }
        <div class="dayplan-grid-header">
            <div style="display: flex; flex-direction: row; align-items: center; gap: 2px;">
                <MudTooltip Text="Vider le mois">
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep" Color="Color.Error" Size="Size.Small" OnClick="ClearMonthAsync" />
                </MudTooltip>
                <MudTooltip Text="Remplissage aléatoire">
                    <MudIconButton Icon="@Icons.Material.Filled.Casino" Color="Color.Secondary" Size="Size.Small" OnClick="RandomFillAsync" />
                </MudTooltip>
            </div>
        </div>

        @* Day rows *@
        @foreach (var date in _dates)
        {
            var dm = _dayMenuByDate.GetValueOrDefault(date);
            var isHoliday = _holidays.Contains(date);
            var isWeekend = date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
            var dateCssClass = isHoliday ? "dayplan-holiday" : isWeekend ? "dayplan-weekend" : "";
            var cellCssClass = isHoliday ? "dayplan-grid-cell dayplan-holiday" : isWeekend ? "dayplan-grid-cell dayplan-weekend" : "dayplan-grid-cell";
            var holidayName = isHoliday ? GetHolidayName(date) : null;
            var rowDateStr = date.ToString("yyyy-MM-dd");

            <div class="dayplan-grid-date @dateCssClass"
                 data-rowdate="@rowDateStr"
                 @onmousedown="@(() => { _ = JS.InvokeVoidAsync("addRowPrimed", rowDateStr); })"
                 @onmouseup="@(() => { _ = JS.InvokeVoidAsync("removeRowPrimed", rowDateStr); })"
                 @onmouseleave="@(() => { _ = JS.InvokeVoidAsync("removeRowPrimed", rowDateStr); })"
                 @ondblclick="@(() => ClearRowAsync(date))">
                @if (isHoliday)
                {
                    <MudTooltip Text="@holidayName" Placement="Placement.Right">
                        <div class="date-label">
                            <span class="date-label-dow date-label-holiday">@date.ToString("ddd", _frCulture).TrimEnd('.').ToUpperInvariant()</span>
                            <span class="date-label-num date-label-holiday">@date.ToString("dd", _frCulture)</span>
                        </div>
                    </MudTooltip>
                }
                else
                {
                    <div class="date-label">
                        <span class="date-label-dow @(isWeekend ? "date-label-weekend" : "")">@date.ToString("ddd", _frCulture).TrimEnd('.').ToUpperInvariant()</span>
                        <span class="date-label-num @(isWeekend ? "date-label-weekend" : "")">@date.ToString("dd", _frCulture)</span>
                    </div>
                }
            </div>

            @foreach (var mt in _mealTypes)
            {
                var meal = dm?.Meals.FirstOrDefault(m => m.MealType == mt);
                var capturedDate = date;
                var capturedMt = mt;
                <div @key="@((capturedDate, capturedMt))" class="@cellCssClass" data-rowdate="@rowDateStr" data-colmealtype="@((int)capturedMt)">
                    <MealCell Date="capturedDate"
                              MealType="capturedMt"
                              MealId="meal?.Id"
                              Items="@(meal?.MealItems ?? [])"
                              OnAddRequested="OpenDrawer"
                              OnItemRemoved="RemoveItemAsync"
                              OnItemMoved="HandleMoveItemAsync"
                              OnOrderChanged="HandleOrderChanged"
                              OnCellFooterDrop="@(async args => await HandleCellDragDropAsync(args.fromDate, args.fromMealType, args.isCopy, capturedDate, capturedMt))"
                              OnItemCloneRequested="CloneItemAsync"
                              IsBeingDragged="@(_draggingCell == (capturedDate, capturedMt))"
                              OnDragStarted="@(args => { _draggingCell = args; StateHasChanged(); })"
                              OnDragEnded="@(() => { _draggingCell = null; StateHasChanged(); })"
                              OnCellClearRequested="ClearCellAsync" />
                </div>
            }
            var rowTotal = GetRowTotal(date);
            <div class="dayplan-grid-date-right @dateCssClass"
                 data-rowdate="@rowDateStr"
                 @onmousedown="@(() => { _ = JS.InvokeVoidAsync("addRowPrimed", rowDateStr); })"
                 @onmouseup="@(() => { _ = JS.InvokeVoidAsync("removeRowPrimed", rowDateStr); })"
                 @onmouseleave="@(() => { _ = JS.InvokeVoidAsync("removeRowPrimed", rowDateStr); })"
                 @ondblclick="@(() => ClearRowAsync(date))">
                <div class="date-right-inner">
                    <div class="date-label">
                        <span class="date-label-dow @(isHoliday ? "date-label-holiday" : isWeekend ? "date-label-weekend" : "")">@date.ToString("ddd", _frCulture).TrimEnd('.').ToUpperInvariant()</span>
                        <span class="date-label-num @(isHoliday ? "date-label-holiday" : isWeekend ? "date-label-weekend" : "")">@date.ToString("dd", _frCulture)</span>
                    </div>
                    @if (rowTotal > 0)
                    {
                        <span class="dayplan-cost-total">@rowTotal.ToString("C", _frCulture)</span>
                    }
                </div>
            </div>
        }
    </div>
    </div>
}

<MudDrawer Anchor="Anchor.Right" Width="320px" Variant="@DrawerVariant.Temporary"
           @bind-Open="_drawerOpen" Elevation="2">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Ajouter — @_selectedMealType — @_selectedDate.ToString("dd MMM", _frCulture)</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _drawerOpen = false)" />
    </MudDrawerHeader>
    <MudTabs @bind-ActivePanelIndex="_drawerTab" Rounded="true">
        <MudTabPanel Text="Items" Icon="@Icons.Material.Filled.Restaurant">
            <MudTextField @bind-Value="_itemSearch" Placeholder="Rechercher…"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" Class="mb-2" />
            <MudList T="ItemResponse" Dense="true">
                @foreach (var item in FilteredItems)
                {
                    <MudListItem T="ItemResponse">
                        <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                            <MudText>@item.Name</MudText>
                            <MudTooltip Text="Ajouter">
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small"
                                               OnClick="@(() => AddItemAsync(item))" />
                            </MudTooltip>
                        </div>
                    </MudListItem>
                }
            </MudList>
        </MudTabPanel>
        <MudTabPanel Text="Recettes" Icon="@Icons.Material.Filled.MenuBook">
            <MudTextField @bind-Value="_recipeSearch" Placeholder="Rechercher…"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" Class="mb-2" />
            <MudList T="RecipeResponse" Dense="true">
                @foreach (var recipe in FilteredRecipes)
                {
                    <MudListItem T="RecipeResponse">
                        <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                            <div>
                                <MudText>@recipe.Name</MudText>
                                @if (recipe.EstimatedCost > 0)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@recipe.EstimatedCost.ToString("C", _frCulture)</MudText>
                                }
                            </div>
                            <MudTooltip Text="Ajouter">
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Secondary" Size="Size.Small"
                                               OnClick="@(() => AddRecipeAsync(recipe))" />
                            </MudTooltip>
                        </div>
                    </MudListItem>
                }
            </MudList>
        </MudTabPanel>
    </MudTabs>
</MudDrawer>

<style>
    .month-nav-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        overflow-x: auto;
        white-space: nowrap;
        padding: 4px 0;
    }

    .month-nav-chip {
        min-width: 44px !important;
        width: 44px;
        height: 44px !important;
        border-radius: 50% !important;
        padding: 0 !important;
        font-size: 0.75rem !important;
        font-weight: 600;
        text-transform: uppercase;
    }

    .month-current {
        min-width: 54px !important;
        width: 54px;
        height: 54px !important;
        font-size: 0.8rem !important;
        background-color: var(--mud-palette-success) !important;
        color: white !important;
    }

    .dayplan-grid-wrapper {
        display: flex;
        align-items: stretch;
        user-select: none;
    }

    .date-label {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1px;
    }

    .date-label-right {
        align-items: flex-end;
    }

    .date-label-dow {
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: var(--mud-palette-text-secondary);
        line-height: 1;
    }

    .date-label-num {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
        line-height: 1.1;
    }

    .date-label-weekend {
        opacity: 0.75;
    }

    .date-label-holiday {
        color: var(--mud-palette-warning-darken) !important;
    }

    .dayplan-grid {
        flex: 1;
        min-width: 0;
        display: grid;
        grid-template-columns: 80px repeat(5, 1fr) 80px;
        column-gap: 1px;
        row-gap: 1px;
        background: var(--mud-palette-table-lines);
        border: 1px solid var(--mud-palette-table-lines);
        border-radius: 8px;
        overflow: hidden;
        position: relative;
    }

    .dayplan-grid-header {
        background: color-mix(in srgb, var(--mud-palette-primary) 6%, var(--mud-palette-surface));
        padding: 8px;
        text-align: center;
        font-weight: 600;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
        border-bottom: 2px solid var(--mud-palette-table-lines);
    }

    .date-right-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
    }

    .dayplan-cost-total {
        font-size: 0.68rem;
        font-weight: 600;
        color: var(--mud-palette-info);
        white-space: nowrap;
        border-radius: 4px;
        border: 1px solid color-mix(in srgb, var(--mud-palette-success) 35%, transparent);
        background: color-mix(in srgb, var(--mud-palette-success) 6%, transparent);
        padding: 1px 5px;
    }

    .primed-axis-overlay {
        position: absolute;
        pointer-events: none;
        z-index: 10;
        background: color-mix(in srgb, var(--mud-palette-error) 12%, transparent);
        border: 1px solid color-mix(in srgb, var(--mud-palette-error) 30%, transparent);
        border-radius: 4px;
    }

    .dayplan-grid-date {
        background: color-mix(in srgb, var(--mud-palette-primary) 4%, var(--mud-palette-surface));
        padding: 8px 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px 0 0 4px;
    }

    .dayplan-grid-date-right {
        background: color-mix(in srgb, var(--mud-palette-primary) 4%, var(--mud-palette-surface));
        padding: 8px 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.25s ease, box-shadow 0.25s ease;
        border-radius: 0 4px 4px 0;
    }

    .dayplan-grid-cell {
        background: var(--mud-palette-surface);
        min-height: 64px;
        min-width: 0;
        display: flex;
        flex-direction: column;
        padding: 2px;
    }

    .meal-cell {
        flex: 1;
        min-width: 0;
        min-height: 68px;
        display: flex;
        flex-direction: column;
        position: relative;
        border-radius: 4px;
        overflow: hidden;
        transition: box-shadow 0.2s, background 0.2s;
    }

    .meal-cell:not(.meal-cell-empty) {
        background: color-mix(in srgb, var(--mud-palette-success) 6%, transparent);
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--mud-palette-success) 35%, transparent);
    }

    .meal-cell:hover {
        background: color-mix(in srgb, var(--mud-palette-text-primary) 5%, transparent);
    }

    .meal-cell:not(.meal-cell-empty):hover {
        background: color-mix(in srgb, var(--mud-palette-success) 11%, transparent);
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--mud-palette-success) 45%, transparent);
    }

    .meal-cell:active {
        background: color-mix(in srgb, var(--mud-palette-text-primary) 10%, transparent);
    }

    .meal-cell:not(.meal-cell-empty):active {
        background: color-mix(in srgb, var(--mud-palette-success) 16%, transparent);
    }


    .dayplan-weekend {
        background: var(--mud-palette-background-grey) !important;
    }

    .dayplan-weekend.dayplan-grid-cell {
        background: color-mix(in srgb, var(--mud-palette-text-secondary) 4%, var(--mud-palette-surface)) !important;
    }

    .dayplan-holiday {
        background: color-mix(in srgb, var(--mud-palette-warning) 18%, var(--mud-palette-surface)) !important;
    }

    .dayplan-holiday.dayplan-grid-cell {
        background: color-mix(in srgb, var(--mud-palette-warning) 8%, var(--mud-palette-surface)) !important;
    }

    .meal-cell {
        cursor: grab;
    }

    .meal-cell-item {
        cursor: pointer;
    }

    .meal-cell-list {
        flex: 1;
        list-style: none;
        padding: 0 2px;
        margin: 0;
        position: relative;
        z-index: 1;
    }

    .meal-cell-item {
        display: grid;
        grid-template-columns: 1fr 56px;
        align-items: center;
        gap: 2px;
        padding: 2px 4px;
        font-size: 0.8rem;
        min-width: 0;
        border-radius: 4px;
        background: color-mix(in srgb, var(--mud-palette-info) 12%, transparent);
        border: 1px solid color-mix(in srgb, var(--mud-palette-info) 25%, transparent);
        transition: background 0.15s ease;
    }

    .meal-cell-item-no-id {
        background: #000 !important;
        color: #fff !important;
        border-color: #000 !important;
    }

    .meal-cell-item-no-id .meal-cell-item-price {
        color: #ccc !important;
    }

    .meal-cell-item:hover {
        background: color-mix(in srgb, var(--mud-palette-info) 22%, transparent);
        border-color: color-mix(in srgb, var(--mud-palette-info) 45%, transparent);
    }

    .meal-cell-item-recipe {
        background: color-mix(in srgb, var(--mud-palette-secondary) 12%, transparent) !important;
        border-color: color-mix(in srgb, var(--mud-palette-secondary) 25%, transparent) !important;
    }

    .meal-cell-item-recipe:hover {
        background: color-mix(in srgb, var(--mud-palette-secondary) 22%, transparent) !important;
        border-color: color-mix(in srgb, var(--mud-palette-secondary) 45%, transparent) !important;
    }

    .meal-cell-drag-copy,
    .meal-cell-drag-move {
        border-radius: 8px;
        background: color-mix(in srgb, var(--mud-palette-info) 15%, transparent) !important;
        box-shadow: inset 0 0 0 1px var(--mud-palette-info) !important;
    }

    .meal-cell-item-name {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .meal-cell-item-price {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 3px;
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        white-space: nowrap;
    }

    .payment-badge {
        font-size: 0.6rem;
        font-weight: 600;
        opacity: 0.6;
        border-radius: 3px;
        padding: 0 3px;
        line-height: 1.5;
        border: 1px solid;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .payment-badge-tr {
        color: #1565C0;
        border-color: #1565C0;
        background: rgba(21, 101, 192, 0.07);
    }

    .payment-badge-cb {
        color: #6A1B9A;
        border-color: #6A1B9A;
        background: rgba(106, 27, 154, 0.07);
    }

    .meal-cell-footer {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        padding: 3px 4px;
        position: relative;
        z-index: 1;
    }

    .footer-zone-side {
        flex: 1;
        cursor: grab;
        min-height: 18px;
    }


    .cell-drag-source .meal-cell-item {
        border-style: dashed;
    }

    .cell-drag-source.cell-drag-copy-mode .meal-cell-item {
        border-style: solid;
    }

    .dayplan-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 9999;
    }

    .sortable-copy-ghost {
        opacity: 0.38;
        pointer-events: none;
        border-style: dashed !important;
    }

    .meal-cell-slot-total {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
        text-align: center;
        white-space: nowrap;
        padding: 1px 6px;
        border: 1px solid color-mix(in srgb, var(--mud-palette-text-secondary) 30%, transparent);
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
    }

    .total-primed {
        color: var(--mud-palette-error) !important;
        border-color: var(--mud-palette-error) !important;
        background: color-mix(in srgb, var(--mud-palette-error) 12%, transparent) !important;
    }


</style>

@code {
    [SupplyParameterFromQuery]
    public int CustomerId { get; set; }

    [SupplyParameterFromQuery]
    public int Year { get; set; }

    [SupplyParameterFromQuery]
    public int Month { get; set; }

    private static readonly MealType[] _mealTypes = Enum.GetValues<MealType>();
    private static readonly System.Globalization.CultureInfo _frCulture = new("fr-FR");

    private bool _saving;
    private (DateOnly date, MealType mealType)? _draggingCell;
    private List<DateOnly> _dates = [];
    private Dictionary<DateOnly, DailyMenuResponse> _dayMenuByDate = new();
    private List<ItemResponse> _allItems = [];
    private List<RecipeResponse> _allRecipes = [];
    private HashSet<DateOnly> _holidays = [];
    private Dictionary<DateOnly, string> _holidayNames = new();

    // Month navigation bar
    private List<MonthNavItem> _monthNav = [];
    private List<MonthlySummaryResponse> _monthlySummary = [];

    // Shopping cart
    private List<MealItemResponse> _allMealItems = [];

    private sealed record MonthNavItem(int Month, int Year, string Label, string Short, bool HasData);

    // Drawer state
    private bool _drawerOpen;
    private DateOnly _selectedDate;
    private MealType _selectedMealType;
    private string _itemSearch = "";
    private string _recipeSearch = "";
    private int _drawerTab;

    private (int customerId, int year, int month) _lastKey;

    private List<ItemResponse> FilteredItems =>
        _allItems
            .Where(i => i.Name.Contains(_itemSearch, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private List<RecipeResponse> FilteredRecipes =>
        _allRecipes
            .Where(r => r.Name.Contains(_recipeSearch, StringComparison.OrdinalIgnoreCase))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        ThemeState.OnChange += OnThemeChanged;
        await ItemSupplierCache.EnsureLoadedAsync();
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnParametersSetAsync()
    {
        var key = (CustomerId, Year, Month);
        if (CustomerId == 0 || Year == 0 || Month == 0 || key == _lastKey)
            return;

        _lastKey = key;

        _holidayNames = FrenchHolidays.GetNamedHolidays(Year);
        _holidays = new HashSet<DateOnly>(_holidayNames.Keys);

        _monthlySummary = await DailyMenuSvc.GetMonthlySummaryAsync(CustomerId);
        BuildMonthNav();

        if (!_allItems.Any())
            _allItems = await ItemSvc.GetAllAsync();

        if (!_allRecipes.Any())
            _allRecipes = await RecipeSvc.GetAllAsync();

        await LoadAsync();
    }

    private string? GetHolidayName(DateOnly date) =>
        _holidayNames.GetValueOrDefault(date);

    private async Task LoadAsync()
    {
        var daysInMonth = DateTime.DaysInMonth(Year, Month);
        _dates = Enumerable.Range(1, daysInMonth)
            .Select(day => new DateOnly(Year, Month, day))
            .ToList();

        var all = await DailyMenuSvc.GetByCustomerAsync(CustomerId);
        _dayMenuByDate = all
            .Where(dm => dm.Date.Year == Year && dm.Date.Month == Month)
            .ToDictionary(dm => dm.Date);

        UpdateShoppingCart();
    }

    private void UpdateShoppingCart()
    {
        _allMealItems = _dayMenuByDate.Values
            .SelectMany(dm => dm.Meals)
            .SelectMany(m => m.MealItems)
            .ToList();

        RightPanel.SetContent(builder =>
        {
            builder.OpenComponent<ShoppingCart>(0);
            builder.AddAttribute(1, nameof(ShoppingCart.Items), (IEnumerable<MealItemResponse>)_allMealItems);
            builder.CloseComponent();
        });
    }

    private void OpenDrawer((DateOnly date, MealType mealType) args)
    {
        RightPanel.Close();
        _selectedDate = args.date;
        _selectedMealType = args.mealType;
        _itemSearch = "";
        _recipeSearch = "";
        _drawerOpen = true;
    }

    private async Task AddItemAsync(ItemResponse item)
    {
        var success = await AddItemToSlotAsync(_selectedDate, _selectedMealType, item.Id, 1);
        if (!success) Snackbar.Add("Failed to add item.", Severity.Error);
        await LoadAsync();
    }

    private async Task AddRecipeAsync(RecipeResponse recipe)
    {
        var success = await AddRecipeToSlotAsync(_selectedDate, _selectedMealType, recipe.Id, 1);
        if (!success) Snackbar.Add("Échec de l'ajout de la recette.", Severity.Error);
        await LoadAsync();
    }

    private async Task<bool> AddItemToSlotAsync(DateOnly date, MealType mealType, int itemId, decimal quantity)
    {
        if (!_dayMenuByDate.TryGetValue(date, out var dailyMenu))
        {
            var created = await DailyMenuSvc.CreateAsync(new CreateDailyMenuRequest { Date = date, CustomerId = CustomerId });
            if (created is null) return false;
            dailyMenu = created;
            _dayMenuByDate[date] = dailyMenu;
        }

        var meal = dailyMenu.Meals.FirstOrDefault(m => m.MealType == mealType);
        if (meal is null)
        {
            var createdMeal = await MealSvc.CreateAsync(new CreateMealRequest { DailyMenuId = dailyMenu.Id, MealType = mealType });
            if (createdMeal is null) return false;
            meal = new MealResponse { Id = createdMeal.Id, MealType = createdMeal.MealType, DailyMenuId = createdMeal.DailyMenuId };
            dailyMenu.Meals.Add(meal);
        }

        var result = await MealItemSvc.CreateAsync(new CreateMealItemRequest { MealId = meal.Id, ItemId = itemId, Quantity = quantity });
        return result is not null;
    }

    private async Task<bool> AddRecipeToSlotAsync(DateOnly date, MealType mealType, int recipeId, decimal quantity)
    {
        if (!_dayMenuByDate.TryGetValue(date, out var dailyMenu))
        {
            var created = await DailyMenuSvc.CreateAsync(new CreateDailyMenuRequest { Date = date, CustomerId = CustomerId });
            if (created is null) return false;
            dailyMenu = created;
            _dayMenuByDate[date] = dailyMenu;
        }

        var meal = dailyMenu.Meals.FirstOrDefault(m => m.MealType == mealType);
        if (meal is null)
        {
            var createdMeal = await MealSvc.CreateAsync(new CreateMealRequest { DailyMenuId = dailyMenu.Id, MealType = mealType });
            if (createdMeal is null) return false;
            meal = new MealResponse { Id = createdMeal.Id, MealType = createdMeal.MealType, DailyMenuId = createdMeal.DailyMenuId };
            dailyMenu.Meals.Add(meal);
        }

        var result = await MealItemSvc.CreateAsync(new CreateMealItemRequest { MealId = meal.Id, RecipeId = recipeId, Quantity = quantity, Unit = MeasurementUnit.Piece });
        return result is not null;
    }

    private async Task HandleCellDragDropAsync(DateOnly fromDate, MealType fromMealType, bool isCopy, DateOnly targetDate, MealType targetMealType)
    {
        if (fromDate == targetDate && fromMealType == targetMealType)
        {
            if (isCopy) await ExecuteCellActionAsync(fromDate, fromMealType, targetDate, targetMealType, isCopy: true);
            return;
        }
        await ExecuteCellActionAsync(fromDate, fromMealType, targetDate, targetMealType, isCopy);
    }

    private async Task ExecuteCellActionAsync(DateOnly fromDate, MealType fromMealType, DateOnly toDate, MealType toMealType, bool isCopy)
    {
        if (!_dayMenuByDate.TryGetValue(fromDate, out var srcDm)) return;
        var srcMeal = srcDm.Meals.FirstOrDefault(m => m.MealType == fromMealType);
        if (srcMeal is null || srcMeal.MealItems.Count == 0) return;

        _saving = true;
        StateHasChanged();
        try
        {
            var sourceItems = srcMeal.MealItems.ToList();
            int done = 0;
            foreach (var mi in sourceItems)
            {
                var added = mi.RecipeId.HasValue
                    ? await AddRecipeToSlotAsync(toDate, toMealType, mi.RecipeId.Value, mi.Quantity)
                    : await AddItemToSlotAsync(toDate, toMealType, mi.ItemId, mi.Quantity);
                if (added) done++;
            }

            if (!isCopy)
            {
                foreach (var mi in sourceItems)
                    await MealItemSvc.DeleteAsync(mi.Id);
            }

            if (done < sourceItems.Count)
                Snackbar.Add($"{sourceItems.Count - done} item(s) non {(isCopy ? "copiés" : "déplacés")}.", Severity.Error);
            await LoadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task HandleMoveItemAsync((int itemId, DateOnly fromDate, MealType fromMealType, DateOnly toDate, MealType toMealType, int newIndex, bool isCopy) args)
    {
        _saving = true;
        StateHasChanged();
        try
        {
            if (args.isCopy)
            {
                var source = _dayMenuByDate.GetValueOrDefault(args.fromDate)
                    ?.Meals.FirstOrDefault(m => m.MealType == args.fromMealType)
                    ?.MealItems.FirstOrDefault(i => i.Id == args.itemId);
                if (source is not null)
                {
                    var success = source.RecipeId.HasValue
                        ? await AddRecipeToSlotAsync(args.toDate, args.toMealType, source.RecipeId.Value, source.Quantity)
                        : await AddItemToSlotAsync(args.toDate, args.toMealType, source.ItemId, source.Quantity);
                    if (!success) Snackbar.Add("Échec de la copie.", Severity.Error);
                }
            }
            else
            {
                var result = await MealItemSvc.MoveAsync(args.itemId, new MoveMealItemRequest
                {
                    TargetDate = args.toDate,
                    TargetMealType = args.toMealType,
                    NewOrder = args.newIndex
                });
                if (result is null) Snackbar.Add("Déplacement échoué.", Severity.Error);
            }

            await LoadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task HandleOrderChanged((int? mealId, List<int> orderedIds) args)
    {
        if (args.mealId is null) return;

        var success = await MealItemSvc.ReorderAsync(new ReorderMealItemsRequest
        {
            MealId = args.mealId.Value,
            OrderedItemIds = args.orderedIds
        });

        if (!success)
        {
            await LoadAsync();
            Snackbar.Add("Réordonnancement échoué.", Severity.Error);
        }
    }

    private async Task RemoveItemAsync(int mealItemId)
    {
        var deleted = await MealItemSvc.DeleteAsync(mealItemId);
        if (deleted)
            await LoadAsync();
        else
            Snackbar.Add("Suppression échouée.", Severity.Error);
    }

    private async Task CloneItemAsync((DateOnly date, MealType mealType, int mealItemId) args)
    {
        var meal = _dayMenuByDate.GetValueOrDefault(args.date)
            ?.Meals.FirstOrDefault(m => m.MealType == args.mealType);
        var source = meal?.MealItems.FirstOrDefault(i => i.Id == args.mealItemId);
        if (source is null) return;
        var success = source.RecipeId.HasValue
            ? await AddRecipeToSlotAsync(args.date, args.mealType, source.RecipeId.Value, source.Quantity)
            : await AddItemToSlotAsync(args.date, args.mealType, source.ItemId, source.Quantity);
        if (!success) Snackbar.Add("Duplication échouée.", Severity.Error);
        else await LoadAsync();
    }

    private async Task ClearCellAsync((DateOnly date, MealType mealType) args)
    {
        var meal = _dayMenuByDate.GetValueOrDefault(args.date)
            ?.Meals.FirstOrDefault(m => m.MealType == args.mealType);
        if (meal is null || meal.MealItems.Count == 0) return;
        _saving = true;
        StateHasChanged();
        try
        {
            foreach (var item in meal.MealItems.ToList())
                await MealItemSvc.DeleteAsync(item.Id);
            await LoadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task ClearColumnAsync(MealType mealType)
    {
        _ = JS.InvokeVoidAsync("removeColumnPrimed", ((int)mealType).ToString());

        var mealIds = _dayMenuByDate.Values
            .SelectMany(dm => dm.Meals)
            .Where(m => m.MealType == mealType)
            .Select(m => m.Id)
            .ToList();
        if (mealIds.Count == 0) return;

        _saving = true;
        StateHasChanged();
        try
        {
            var success = await MealSvc.DeleteBatchAsync(mealIds);
            if (!success) Snackbar.Add("Suppression de la colonne échouée.", Severity.Error);
            await LoadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task ClearRowAsync(DateOnly date)
    {
        var rowDateStr = date.ToString("yyyy-MM-dd");
        _ = JS.InvokeVoidAsync("removeRowPrimed", rowDateStr);

        var dm = _dayMenuByDate.GetValueOrDefault(date);
        if (dm is null) return;

        var mealIds = dm.Meals.Select(m => m.Id).ToList();
        if (mealIds.Count == 0) return;

        _saving = true;
        StateHasChanged();
        try
        {
            var success = await MealSvc.DeleteBatchAsync(mealIds);
            if (!success) Snackbar.Add("Suppression de la ligne échouée.", Severity.Error);
            await LoadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task ClearMonthAsync()
    {
        var mealIds = _dayMenuByDate.Values
            .SelectMany(dm => dm.Meals)
            .Select(m => m.Id)
            .ToList();
        if (mealIds.Count == 0) return;

        _saving = true;
        StateHasChanged();
        try
        {
            var success = await MealSvc.DeleteBatchAsync(mealIds);
            if (!success) { Snackbar.Add("Suppression du mois échouée.", Severity.Error); return; }
            _dayMenuByDate.Clear();
            _monthlySummary = await DailyMenuSvc.GetMonthlySummaryAsync(CustomerId);
            BuildMonthNav();
            UpdateShoppingCart();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task RandomFillAsync()
    {
        _saving = true;
        StateHasChanged();
        try
        {
            var result = await MealSvc.RandomFillAsync(CustomerId, Year, Month);
            if (result is null) { Snackbar.Add("Remplissage aléatoire échoué.", Severity.Error); return; }
            _dayMenuByDate = result.ToDictionary(dm => dm.Date);
            _monthlySummary = await DailyMenuSvc.GetMonthlySummaryAsync(CustomerId);
            BuildMonthNav();
            UpdateShoppingCart();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private void BuildMonthNav()
    {
        _monthNav = [];
        var current = new DateOnly(Year, Month, 1);
        for (int i = -6; i <= 6; i++)
        {
            var d = current.AddMonths(i);
            var match = _monthlySummary.FirstOrDefault(s => s.Month == d.Month && s.Year == d.Year);
            var label = d.ToString("MMMM yyyy", _frCulture);
            var abbr = d.ToString("MMM", _frCulture).TrimEnd('.').ToUpper();
            _monthNav.Add(new MonthNavItem(d.Month, d.Year, label, abbr, match?.HasMeals ?? false));
        }
    }

    private static decimal ComputeItemCost(MealItemResponse i)
    {
        if (i.RecipeId.HasValue && i.RecipeEstimatedCost.HasValue)
            return i.RecipeEstimatedCost.Value * i.Quantity;
        if (i.UnitPrice.HasValue)
            return (decimal)Math.Ceiling(i.Quantity / i.ContentQuantity) * i.UnitPrice.Value;
        return 0m;
    }

    private decimal GetRowTotal(DateOnly date) =>
        _dayMenuByDate.TryGetValue(date, out var dm)
            ? dm.Meals.SelectMany(m => m.MealItems).Sum(ComputeItemCost)
            : 0;

    private decimal GetColumnTotal(MealType mealType) =>
        _dayMenuByDate.Values
            .SelectMany(dm => dm.Meals.Where(m => m.MealType == mealType))
            .SelectMany(m => m.MealItems)
            .Sum(ComputeItemCost);

    private void NavigateToMonth(MonthNavItem month)
    {
        Nav.NavigateTo($"dayplans?customerId={CustomerId}&year={month.Year}&month={month.Month}");
    }

