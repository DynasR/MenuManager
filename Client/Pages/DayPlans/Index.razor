@page "/dayplans"
@using MenuManager.Client.Helpers
@inject DayPlanService DayPlanSvc
@inject MenuPlanService MenuPlanSvc
@inject MealSlotService MealSlotSvc
@inject MealSlotItemService MealSlotItemSvc
@inject ItemService ItemSvc
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject RightPanelState RightPanel
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Day Plans</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Day Plans</MudText>

@if (MenuPlanId == 0 || _parentNotFound)
{
    <MudAlert Severity="Severity.Error">
        @(MenuPlanId == 0 ? "No menu plan specified." : $"Menu plan {MenuPlanId} not found.")
    </MudAlert>
}
else if (_parent is not null)
{
    <div class="month-nav-bar mb-4">
        @foreach (var m in _monthNav)
        {
            var isCurrent = m.Month == _parent!.Month && m.Year == _parent.Year;
            var color = isCurrent ? Color.Success : m.HasData ? Color.Primary : Color.Default;
            var variant = isCurrent ? Variant.Filled : m.HasData ? Variant.Filled : Variant.Outlined;
            var chipClass = isCurrent ? "month-nav-chip month-current" : "month-nav-chip";
            var size = isCurrent ? Size.Medium : Size.Small;
            <MudTooltip Text="@m.Label" Placement="Placement.Bottom">
                <MudButton Size="@size" Variant="@variant" Color="@color"
                           Class="@chipClass"
                           Disabled="@(!isCurrent && _navigating)"
                           OnClick="@(async () => { if (!isCurrent) await NavigateToMonthAsync(m); })">
                    @m.Short
                </MudButton>
            </MudTooltip>
        }
    </div>

    @if (_saving)
    {
        <div class="dayplan-overlay"></div>
    }

    <div class="dayplan-grid-wrapper">
    <div class="dayplan-grid">
        @* Header row *@
        <div class="dayplan-grid-header">
            <MudText Typo="Typo.subtitle2">Date</MudText>
        </div>
        @foreach (var mt in _mealTypes)
        {
            <div class="dayplan-grid-header">
                <MudText Typo="Typo.subtitle2">@mt</MudText>
            </div>
        }
        <div class="dayplan-grid-header">
        </div>

        @* Day rows *@
        @foreach (var date in _dates)
        {
            var dp = _dayPlanByDate.GetValueOrDefault(date);
            var isHoliday = _holidays.Contains(date);
            var isWeekend = date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
            var dateCssClass = isHoliday ? "dayplan-holiday" : isWeekend ? "dayplan-weekend" : "";
            var cellCssClass = isHoliday ? "dayplan-grid-cell dayplan-holiday" : isWeekend ? "dayplan-grid-cell dayplan-weekend" : "dayplan-grid-cell";
            var holidayName = isHoliday ? GetHolidayName(date) : null;

            <div class="dayplan-grid-date @dateCssClass">
                @if (isHoliday)
                {
                    <MudTooltip Text="@holidayName" Placement="Placement.Right">
                        <div class="date-label">
                            <span class="date-label-dow date-label-holiday">@date.ToString("ddd", _frCulture).TrimEnd('.').ToUpperInvariant()</span>
                            <span class="date-label-num date-label-holiday">@date.ToString("dd", _frCulture)</span>
                        </div>
                    </MudTooltip>
                }
                else
                {
                    <div class="date-label">
                        <span class="date-label-dow @(isWeekend ? "date-label-weekend" : "")">@date.ToString("ddd", _frCulture).TrimEnd('.').ToUpperInvariant()</span>
                        <span class="date-label-num @(isWeekend ? "date-label-weekend" : "")">@date.ToString("dd", _frCulture)</span>
                    </div>
                }
            </div>

            @foreach (var mt in _mealTypes)
            {
                var slot = dp?.MealSlots.FirstOrDefault(ms => ms.MealType == mt);
                var capturedDate = date;
                var capturedMt = mt;
                <div class="@cellCssClass">
                    <MealCell Date="capturedDate"
                              MealType="capturedMt"
                              MealSlotId="slot?.Id"
                              Items="@(slot?.MealSlotItems ?? [])"
                              OnAddRequested="OpenDrawer"
                              OnItemRemoved="RemoveItemAsync"
                              OnItemMoved="HandleMoveItemAsync"
                              OnOrderChanged="HandleOrderChanged"
                              OnCellFooterDrop="@(async args => await HandleCellDragDropAsync(args.fromDate, args.fromMealType, args.isCopy, capturedDate, capturedMt))"
                              OnItemCloneRequested="CloneItemAsync"
                              IsBeingDragged="@(_draggingCell == (capturedDate, capturedMt))"
                              OnDragStarted="@(args => { _draggingCell = args; StateHasChanged(); })"
                              OnDragEnded="@(() => { _draggingCell = null; StateHasChanged(); })"
                              OnCellClearRequested="ClearCellAsync" />
                </div>
            }
            <div class="dayplan-grid-date-right @dateCssClass">
                <div class="date-label">
                    <span class="date-label-dow @(isHoliday ? "date-label-holiday" : isWeekend ? "date-label-weekend" : "")">@date.ToString("ddd", _frCulture).TrimEnd('.').ToUpperInvariant()</span>
                    <span class="date-label-num @(isHoliday ? "date-label-holiday" : isWeekend ? "date-label-weekend" : "")">@date.ToString("dd", _frCulture)</span>
                </div>
            </div>
        }
    </div>
    </div>
}

<MudDrawer Anchor="Anchor.Right" Width="320px" Variant="@DrawerVariant.Temporary"
           @bind-Open="_drawerOpen" Elevation="2">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6">Add item — @_selectedMealType — @_selectedDate.ToString("dd MMM", _frCulture)</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _drawerOpen = false)" />
    </MudDrawerHeader>
    <div class="pa-4">
        <MudTextField @bind-Value="_itemSearch" Placeholder="Rechercher…"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" Class="mb-4" />
        <MudList T="ItemResponse" Dense="true">
            @foreach (var item in FilteredItems)
            {
                <MudListItem T="ItemResponse">
                    <div style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                        <MudText>@item.Name</MudText>
                        <MudTooltip Text="Add to meal">
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small"
                                           OnClick="@(() => AddItemAsync(item))" />
                        </MudTooltip>
                    </div>
                </MudListItem>
            }
        </MudList>
    </div>
</MudDrawer>

<style>
    .month-nav-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        overflow-x: auto;
        white-space: nowrap;
        padding: 4px 0;
    }

    .month-nav-chip {
        min-width: 44px !important;
        width: 44px;
        height: 44px !important;
        border-radius: 50% !important;
        padding: 0 !important;
        font-size: 0.75rem !important;
        font-weight: 600;
        text-transform: uppercase;
    }

    .month-current {
        min-width: 54px !important;
        width: 54px;
        height: 54px !important;
        font-size: 0.8rem !important;
        background-color: var(--mud-palette-success) !important;
        color: white !important;
    }

    .dayplan-grid-wrapper {
        display: flex;
        align-items: stretch;
        user-select: none;
    }

    .date-label {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1px;
    }

    .date-label-right {
        align-items: flex-end;
    }

    .date-label-dow {
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        color: var(--mud-palette-text-secondary);
        line-height: 1;
    }

    .date-label-num {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
        line-height: 1.1;
    }

    .date-label-weekend {
        opacity: 0.75;
    }

    .date-label-holiday {
        color: var(--mud-palette-warning-darken) !important;
    }

    .dayplan-grid {
        flex: 1;
        min-width: 0;
        display: grid;
        grid-template-columns: 80px repeat(5, 1fr) 80px;
        gap: 1px;
        background: var(--mud-palette-table-lines);
        border: 1px solid var(--mud-palette-table-lines);
    }

    .dayplan-grid-header {
        background: var(--mud-palette-surface);
        padding: 8px;
        text-align: center;
        font-weight: 600;
    }

    .dayplan-grid-date {
        background: var(--mud-palette-surface);
        padding: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .dayplan-grid-date-right {
        background: var(--mud-palette-surface);
        padding: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.25s ease, box-shadow 0.25s ease;
    }

    .dayplan-grid-cell {
        background: var(--mud-palette-surface);
        min-height: 60px;
        min-width: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .meal-cell {
        flex: 1;
        min-width: 0;
        min-height: 68px;
        display: flex;
        flex-direction: column;
        position: relative;
        border-radius: 4px;
        overflow: hidden;
        transition: box-shadow 0.2s, background 0.2s;
    }

    .meal-cell:not(.meal-cell-empty) {
        background: color-mix(in srgb, var(--mud-palette-success) 6%, transparent);
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--mud-palette-success) 35%, transparent);
    }

    .meal-cell:hover {
        background: color-mix(in srgb, var(--mud-palette-text-primary) 5%, transparent);
    }

    .meal-cell:not(.meal-cell-empty):hover {
        background: color-mix(in srgb, var(--mud-palette-success) 11%, transparent);
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--mud-palette-success) 45%, transparent);
    }

    .meal-cell:active {
        background: color-mix(in srgb, var(--mud-palette-text-primary) 10%, transparent);
    }

    .meal-cell:not(.meal-cell-empty):active {
        background: color-mix(in srgb, var(--mud-palette-success) 16%, transparent);
    }


.dayplan-weekend {
        background: var(--mud-palette-background-grey);
    }

    .dayplan-holiday {
        background: color-mix(in srgb, var(--mud-palette-warning) 15%, var(--mud-palette-surface));
    }

    .meal-cell {
        cursor: grab;
    }

    .meal-cell-item {
        cursor: pointer;
    }

    .meal-cell-list {
        flex: 1;
        list-style: none;
        padding: 0 2px;
        margin: 0;
        position: relative;
        z-index: 1;
    }

    .meal-cell-item {
        display: grid;
        grid-template-columns: 1fr 56px;
        align-items: center;
        gap: 2px;
        padding: 2px 4px;
        font-size: 0.8rem;
        min-width: 0;
        border-radius: 4px;
        background: color-mix(in srgb, var(--mud-palette-info) 12%, transparent);
        border: 1px solid color-mix(in srgb, var(--mud-palette-info) 25%, transparent);
        transition: background 0.15s ease;
    }

    .meal-cell-item-no-id {
        background: #000 !important;
        color: #fff !important;
        border-color: #000 !important;
    }

    .meal-cell-item-no-id .meal-cell-item-price {
        color: #ccc !important;
    }

    .meal-cell-item:hover {
        background: color-mix(in srgb, var(--mud-palette-info) 22%, transparent);
        border-color: color-mix(in srgb, var(--mud-palette-info) 45%, transparent);
    }

    .meal-cell-drag-copy,
    .meal-cell-drag-move {
        border-radius: 8px;
        background: color-mix(in srgb, var(--mud-palette-info) 15%, transparent) !important;
        box-shadow: inset 0 0 0 1px var(--mud-palette-info) !important;
    }

    .meal-cell-item-name {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .meal-cell-item-price {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        text-align: right;
        white-space: nowrap;
    }

    .meal-cell-footer {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        padding: 3px 4px;
        position: relative;
        z-index: 1;
    }

    .footer-zone-side {
        flex: 1;
        cursor: grab;
        min-height: 18px;
    }


    .cell-drag-source .meal-cell-item {
        border-style: dashed;
    }

    .cell-drag-source.cell-drag-copy-mode .meal-cell-item {
        border-style: solid;
    }

    .dayplan-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 9999;
    }

    .sortable-copy-ghost {
        opacity: 0.38;
        pointer-events: none;
        border-style: dashed !important;
    }

    .meal-cell-slot-total {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--mud-palette-text-primary);
        text-align: center;
        white-space: nowrap;
        padding: 1px 6px;
        border: 1px solid color-mix(in srgb, var(--mud-palette-text-secondary) 30%, transparent);
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
    }

    .meal-cell-slot-total.total-primed,
    .meal-cell-slot-total.total-primed:hover {
        color: var(--mud-palette-error);
        border-color: color-mix(in srgb, var(--mud-palette-error) 60%, transparent);
        background: color-mix(in srgb, var(--mud-palette-error) 8%, transparent);
    }

    .meal-cell:has(.total-primed) {
        background: color-mix(in srgb, var(--mud-palette-error) 10%, var(--mud-palette-surface)) !important;
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--mud-palette-error) 35%, transparent),
                    inset 0 0 14px color-mix(in srgb, var(--mud-palette-error) 8%, transparent);
        transition: background 0.15s, box-shadow 0.15s;
    }
</style>

@code {
    [SupplyParameterFromQuery]
    public int MenuPlanId { get; set; }

    private static readonly MealType[] _mealTypes = Enum.GetValues<MealType>();
    private static readonly System.Globalization.CultureInfo _frCulture = new("fr-FR");

    private MenuPlanResponse? _parent;
    private bool _parentNotFound;
    private bool _saving;
    private (DateOnly date, MealType mealType)? _draggingCell;
    private List<DateOnly> _dates = [];
    private Dictionary<DateOnly, DayPlanResponse> _dayPlanByDate = new();
    private List<ItemResponse> _allItems = [];
    private HashSet<DateOnly> _holidays = [];
    private Dictionary<DateOnly, string> _holidayNames = new();

    // Month navigation bar
    private List<MonthNavItem> _monthNav = [];
    private List<MenuPlanResponse> _siblingPlans = [];
    private bool _navigating;
    private int _lastMenuPlanId;

    // Shopping cart
    private List<MealSlotItemResponse> _allMealSlotItems = [];

    private sealed record MonthNavItem(int Month, int Year, string Label, string Short, int? MenuPlanId, bool HasData);

    // Drawer state
    private bool _drawerOpen;
    private DateOnly _selectedDate;
    private MealType _selectedMealType;
    private string _itemSearch = "";

    private List<ItemResponse> FilteredItems =>
        _allItems
            .Where(i => i.Name.Contains(_itemSearch, StringComparison.OrdinalIgnoreCase))
            .ToList();

    protected override async Task OnParametersSetAsync()
    {
        if (MenuPlanId == 0 || MenuPlanId == _lastMenuPlanId)
            return;

        _lastMenuPlanId = MenuPlanId;
        _parentNotFound = false;

        _parent = await MenuPlanSvc.GetByIdAsync(MenuPlanId);
        if (_parent is null)
        {
            _parentNotFound = true;
            return;
        }

        _holidayNames = FrenchHolidays.GetNamedHolidays(_parent.Year);
        _holidays = new HashSet<DateOnly>(_holidayNames.Keys);

        _siblingPlans = await MenuPlanSvc.GetByCustomerAsync(_parent.CustomerId);
        BuildMonthNav();

        if (!_allItems.Any())
            _allItems = await ItemSvc.GetAllAsync();

        await LoadAsync();
    }

    private string? GetHolidayName(DateOnly date) =>
        _holidayNames.GetValueOrDefault(date);

    private async Task LoadAsync()
    {
        var daysInMonth = DateTime.DaysInMonth(_parent!.Year, _parent.Month);
        _dates = Enumerable.Range(1, daysInMonth)
            .Select(day => new DateOnly(_parent.Year, _parent.Month, day))
            .ToList();

        var existing = await DayPlanSvc.GetByMenuPlanAsync(MenuPlanId);
        _dayPlanByDate = existing.ToDictionary(dp => dp.Date);

        UpdateShoppingCart();
    }

    private void UpdateShoppingCart()
    {
        _allMealSlotItems = _dayPlanByDate.Values
            .SelectMany(dp => dp.MealSlots)
            .SelectMany(ms => ms.MealSlotItems)
            .ToList();

        RightPanel.SetContent(builder =>
        {
            builder.OpenComponent<ShoppingCart>(0);
            builder.AddAttribute(1, nameof(ShoppingCart.Items), (IEnumerable<MealSlotItemResponse>)_allMealSlotItems);
            builder.CloseComponent();
        });
    }

    private void OpenDrawer((DateOnly date, MealType mealType) args)
    {
        RightPanel.Close();
        _selectedDate = args.date;
        _selectedMealType = args.mealType;
        _itemSearch = "";
        _drawerOpen = true;
    }

    private async Task AddItemAsync(ItemResponse item)
    {
        var success = await AddItemToSlotAsync(_selectedDate, _selectedMealType, item.Id, 1);
        if (!success) Snackbar.Add("Failed to add item.", Severity.Error);
        await LoadAsync();
    }

    private async Task<bool> AddItemToSlotAsync(DateOnly date, MealType mealType, int itemId, decimal quantity)
    {
        if (!_dayPlanByDate.TryGetValue(date, out var dayPlan))
        {
            var created = await DayPlanSvc.CreateAsync(new CreateDayPlanRequest { Date = date, MenuPlanId = MenuPlanId });
            if (created is null) return false;
            dayPlan = created;
            _dayPlanByDate[date] = dayPlan;
        }

        var slot = dayPlan.MealSlots.FirstOrDefault(ms => ms.MealType == mealType);
        if (slot is null)
        {
            var createdSlot = await MealSlotSvc.CreateAsync(new CreateMealSlotRequest { DayPlanId = dayPlan.Id, MealType = mealType });
            if (createdSlot is null) return false;
            slot = new MealSlotResponse { Id = createdSlot.Id, MealType = createdSlot.MealType, DayPlanId = createdSlot.DayPlanId };
            dayPlan.MealSlots.Add(slot);
        }

        var result = await MealSlotItemSvc.CreateAsync(new CreateMealSlotItemRequest { MealSlotId = slot.Id, ItemId = itemId, Quantity = quantity });
        return result is not null;
    }

    private async Task HandleCellDragDropAsync(DateOnly fromDate, MealType fromMealType, bool isCopy, DateOnly targetDate, MealType targetMealType)
    {
        if (fromDate == targetDate && fromMealType == targetMealType)
        {
            if (isCopy) await ExecuteCellActionAsync(fromDate, fromMealType, targetDate, targetMealType, isCopy: true);
            return;
        }
        await ExecuteCellActionAsync(fromDate, fromMealType, targetDate, targetMealType, isCopy);
    }

    private async Task ExecuteCellActionAsync(DateOnly fromDate, MealType fromMealType, DateOnly toDate, MealType toMealType, bool isCopy)
    {
        if (!_dayPlanByDate.TryGetValue(fromDate, out var srcDp)) return;
        var srcSlot = srcDp.MealSlots.FirstOrDefault(ms => ms.MealType == fromMealType);
        if (srcSlot is null || srcSlot.MealSlotItems.Count == 0) return;

        _saving = true;
        StateHasChanged();
        try
        {
            var sourceItems = srcSlot.MealSlotItems.ToList();
            int done = 0;
            foreach (var msi in sourceItems)
            {
                if (await AddItemToSlotAsync(toDate, toMealType, msi.ItemId, msi.Quantity))
                    done++;
            }

            if (!isCopy)
            {
                foreach (var msi in sourceItems)
                    await MealSlotItemSvc.DeleteAsync(msi.Id);
            }

            if (done < sourceItems.Count)
                Snackbar.Add($"{sourceItems.Count - done} item(s) non {(isCopy ? "copiés" : "déplacés")}.", Severity.Error);
            await LoadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task HandleMoveItemAsync((int itemId, DateOnly fromDate, MealType fromMealType, DateOnly toDate, MealType toMealType, int newIndex, bool isCopy) args)
    {
        _saving = true;
        StateHasChanged();
        try
        {
            if (args.isCopy)
            {
                var source = _dayPlanByDate.GetValueOrDefault(args.fromDate)
                    ?.MealSlots.FirstOrDefault(ms => ms.MealType == args.fromMealType)
                    ?.MealSlotItems.FirstOrDefault(i => i.Id == args.itemId);
                if (source is not null)
                {
                    var success = await AddItemToSlotAsync(args.toDate, args.toMealType, source.ItemId, source.Quantity);
                    if (!success) Snackbar.Add("Échec de la copie.", Severity.Error);
                }
            }
            else
            {
                var result = await MealSlotItemSvc.MoveAsync(args.itemId, new MoveMealSlotItemRequest
                {
                    TargetDate = args.toDate,
                    TargetMealType = args.toMealType,
                    NewOrder = args.newIndex
                });
                if (result is null) Snackbar.Add("Déplacement échoué.", Severity.Error);
            }

            await LoadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task HandleOrderChanged((int? mealSlotId, List<int> orderedIds) args)
    {
        if (args.mealSlotId is null) return;

        var success = await MealSlotItemSvc.ReorderAsync(new ReorderMealSlotItemsRequest
        {
            MealSlotId = args.mealSlotId.Value,
            OrderedItemIds = args.orderedIds
        });

        if (!success)
        {
            await LoadAsync(); // restore server order
            Snackbar.Add("Réordonnancement échoué.", Severity.Error);
        }
    }

    private async Task RemoveItemAsync(int mealSlotItemId)
    {
        var deleted = await MealSlotItemSvc.DeleteAsync(mealSlotItemId);
        if (deleted)
            await LoadAsync();
        else
            Snackbar.Add("Suppression échouée.", Severity.Error);
    }

    private async Task CloneItemAsync((DateOnly date, MealType mealType, int mealSlotItemId) args)
    {
        var slot = _dayPlanByDate.GetValueOrDefault(args.date)
            ?.MealSlots.FirstOrDefault(ms => ms.MealType == args.mealType);
        var source = slot?.MealSlotItems.FirstOrDefault(i => i.Id == args.mealSlotItemId);
        if (source is null) return;
        var success = await AddItemToSlotAsync(args.date, args.mealType, source.ItemId, source.Quantity);
        if (!success) Snackbar.Add("Duplication échouée.", Severity.Error);
        else await LoadAsync();
    }

    private async Task ClearCellAsync((DateOnly date, MealType mealType) args)
    {
        var slot = _dayPlanByDate.GetValueOrDefault(args.date)
            ?.MealSlots.FirstOrDefault(ms => ms.MealType == args.mealType);
        if (slot is null || slot.MealSlotItems.Count == 0) return;
        _saving = true;
        StateHasChanged();
        try
        {
            foreach (var item in slot.MealSlotItems.ToList())
                await MealSlotItemSvc.DeleteAsync(item.Id);
            await LoadAsync();
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private void BuildMonthNav()
    {
        _monthNav = [];
        var current = new DateOnly(_parent!.Year, _parent.Month, 1);
        for (int i = -6; i <= 6; i++)
        {
            var d = current.AddMonths(i);
            var match = _siblingPlans.FirstOrDefault(p => p.Month == d.Month && p.Year == d.Year);
            var label = d.ToString("MMMM yyyy", _frCulture);
            var abbr = d.ToString("MMM", _frCulture).TrimEnd('.').ToUpper();
            _monthNav.Add(new MonthNavItem(d.Month, d.Year, label, abbr, match?.Id, match?.HasData ?? false));
        }
    }

    private async Task NavigateToMonthAsync(MonthNavItem month)
    {
        _navigating = true;
        StateHasChanged();

        try
        {
            int targetId;
            if (month.MenuPlanId is not null)
            {
                targetId = month.MenuPlanId.Value;
            }
            else
            {
                var result = await MenuPlanSvc.CreateAsync(new MenuPlanRequest
                {
                    Name = $"Planning {month.Month:D2}/{month.Year}",
                    Month = month.Month,
                    Year = month.Year,
                    CustomerId = _parent!.CustomerId
                });

                if (result is null)
                {
                    Snackbar.Add("Échec de la création du menu plan.", Severity.Error);
                    return;
                }
                targetId = result.Id;
            }

            _lastMenuPlanId = 0; // Reset so OnParametersSetAsync re-triggers
            Nav.NavigateTo($"dayplans?menuPlanId={targetId}");
        }
        finally
        {
            _navigating = false;
        }
    }

    public void Dispose()
    {
        RightPanel.Close();
        RightPanel.SetContent(null);
    }
}
