@page "/itemsupplier"
@inject ItemSupplierService ItemSupplierSvc
@inject ItemService ItemSvc
@inject SupplierService SupplierSvc
@inject ISnackbar Snackbar

<PageTitle>Item Suppliers</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Item Suppliers</MudText>

<MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PlaylistAdd"
           OnClick="AddRow" Class="mb-4">
    Add row
</MudButton>
<MudButton Variant="Variant.Filled" Color="Color.Primary"
           Disabled="@(_pendingRows.Count == 0 && _dirtyRows.Count == 0)"
           OnClick="SaveAllAsync"
           StartIcon="@Icons.Material.Filled.SaveAlt"
           Class="mb-4 ml-2">
    Save All
</MudButton>

@if (_pendingRows.Count > 0)
{
    <MudDataGrid T="ItemSupplierDraft" Items="_pendingRows" ReadOnly="false"
                 EditMode="DataGridEditMode.Cell" Hover="true" Dense="true"
                 Class="mb-0" Style="table-layout: fixed; width: 100%">
        <Columns>
            <PropertyColumn Property="x => x.ItemId" Title="Item" Editable="true" Style="width: 22%">
                <CellTemplate>
                    @ItemName(context.Item.ItemId)
                </CellTemplate>
                <EditTemplate>
                    <MudSelect T="int" @bind-Value="context.Item.ItemId"
                               Immediate="true" Margin="Margin.Dense">
                        @foreach (var item in _items)
                        {
                            <MudSelectItem T="int" Value="item.Id">@item.Name</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.SupplierId" Title="Supplier" Editable="true" Style="width: 22%">
                <CellTemplate>
                    @SupplierName(context.Item.SupplierId)
                </CellTemplate>
                <EditTemplate>
                    <MudSelect T="int" @bind-Value="context.Item.SupplierId"
                               Immediate="true" Margin="Margin.Dense">
                        @foreach (var sup in _suppliers)
                        {
                            <MudSelectItem T="int" Value="sup.Id">@(sup.CompanyName ?? sup.Name)</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.UnitPrice" Title="Unit Price" Editable="true" Style="width: 12%">
                <EditTemplate>
                    <MudNumericField T="decimal" @bind-Value="context.Item.UnitPrice"
                                     Min="0m" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.SupplierReference" Title="Supplier Reference" Editable="true" Style="width: 20%">
                <EditTemplate>
                    <MudTextField @bind-Value="context.Item.SupplierReference" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.IsAvailable" Title="Available" Editable="true" Style="width: 12%">
                <EditTemplate>
                    <MudCheckBox @bind-Value="context.Item.IsAvailable" />
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false" Style="width: 8%">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                   Disabled="@(context.Item.ItemId == 0 || context.Item.SupplierId == 0)"
                                   OnClick="@(() => ValidateRow(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => RemoveRow(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

<MudDataGrid T="ItemSupplierResponse" Items="_itemSuppliers" ReadOnly="false"
             EditMode="DataGridEditMode.Cell"
             Loading="_loading" Hover="true" Striped="true" Dense="true"
             Style="table-layout: fixed; width: 100%">
    <Columns>
        <PropertyColumn Property="x => x.ItemName" Title="Item" Editable="false" Style="width: 22%" />
        <PropertyColumn Property="x => x.SupplierName" Title="Supplier" Editable="false" Style="width: 22%" />
        <PropertyColumn Property="x => x.UnitPrice" Title="Unit Price" Editable="true" Style="width: 12%">
            <EditTemplate>
                <MudNumericField
                    Value="@context.Item.UnitPrice"
                    ValueChanged="@((decimal val) => { context.Item.UnitPrice = val; _dirtyRows.Add((context.Item.ItemId, context.Item.SupplierId)); StateHasChanged(); })"
                    Min="0m" Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.SupplierReference" Title="Supplier Reference" Editable="true" Style="width: 20%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.SupplierReference"
                    ValueChanged="@((string val) => { context.Item.SupplierReference = val; _dirtyRows.Add((context.Item.ItemId, context.Item.SupplierId)); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.IsAvailable" Title="Available" Editable="true" Style="width: 12%">
            <CellTemplate>
                <MudIcon Icon="@(context.Item.IsAvailable ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                         Color="@(context.Item.IsAvailable ? Color.Success : Color.Error)" Size="Size.Small" />
            </CellTemplate>
            <EditTemplate>
                <MudCheckBox
                    Value="@context.Item.IsAvailable"
                    ValueChanged="@((bool val) => { context.Item.IsAvailable = val; _dirtyRows.Add((context.Item.ItemId, context.Item.SupplierId)); StateHasChanged(); })" />
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false" Style="width: 8%">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary" Size="Size.Small"
                               Disabled="@(!_dirtyRows.Contains((context.Item.ItemId, context.Item.SupplierId)))"
                               OnClick="@(() => SaveRow(context.Item))"
                               />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteAsync(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private List<ItemSupplierResponse> _itemSuppliers = [];
    private List<ItemResponse> _items = [];
    private List<SupplierResponse> _suppliers = [];
    private HashSet<(int ItemId, int SupplierId)> _dirtyRows = new();
    private bool _loading = true;
    private List<ItemSupplierDraft> _pendingRows = [];

    private sealed class ItemSupplierDraft
    {
        public int ItemId { get; set; }
        public int SupplierId { get; set; }
        public decimal UnitPrice { get; set; }
        public string? SupplierReference { get; set; }
        public bool IsAvailable { get; set; }
    }

    private void AddRow() => _pendingRows.Add(new ItemSupplierDraft());

    private void RemoveRow(ItemSupplierDraft draft) => _pendingRows.Remove(draft);

    private async Task<bool> ValidateRow(ItemSupplierDraft draft)
    {
        var result = await ItemSupplierSvc.CreateAsync(new CreateItemSupplierRequest
        {
            ItemId = draft.ItemId,
            SupplierId = draft.SupplierId,
            UnitPrice = draft.UnitPrice,
            SupplierReference = draft.SupplierReference,
            IsAvailable = draft.IsAvailable
        });

        if (result.Error is null)
        {
            _pendingRows.Remove(draft);
            return true;
        }

        var message = result.Error switch
        {
            CreateItemSupplierError.ItemNotFound => "Item not found.",
            CreateItemSupplierError.SupplierNotFound => "Supplier not found.",
            CreateItemSupplierError.AlreadyExists => "This Item-Supplier link already exists.",
            _ => "Failed to create link."
        };
        Snackbar.Add(message, Severity.Error);
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private string ItemName(int itemId) =>
        _items.FirstOrDefault(i => i.Id == itemId)?.Name ?? "";

    private string SupplierName(int supplierId)
    {
        var s = _suppliers.FirstOrDefault(s => s.Id == supplierId);
        return s is null ? "" : (s.CompanyName ?? s.Name);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _itemSuppliers = await ItemSupplierSvc.GetAllAsync();
        _items = await ItemSvc.GetAllAsync();
        _suppliers = await SupplierSvc.GetAllAsync();
        _dirtyRows.Clear();
        _loading = false;
    }

    private async Task SaveRow(ItemSupplierResponse item)
    {
        var request = new UpdateItemSupplierRequest
        {
            UnitPrice = item.UnitPrice,
            SupplierReference = item.SupplierReference,
            IsAvailable = item.IsAvailable
        };
        var updated = await ItemSupplierSvc.UpdateAsync(item.ItemId, item.SupplierId, request);
        if (updated == null)
            Snackbar.Add("Failed to save link.", Severity.Error);
        else
        {
            _dirtyRows.Remove((item.ItemId, item.SupplierId));
            StateHasChanged();
        }
    }

    private async Task SaveAllAsync()
    {
        int created = 0, updated = 0, errors = 0;

        foreach (var draft in _pendingRows.ToList())
        {
            if (await ValidateRow(draft))
                created++;
            else
                errors++;
        }

        foreach (var key in _dirtyRows.ToList())
        {
            var item = _itemSuppliers.FirstOrDefault(x => x.ItemId == key.ItemId && x.SupplierId == key.SupplierId);
            if (item == null) continue;

            var request = new UpdateItemSupplierRequest
            {
                UnitPrice = item.UnitPrice,
                SupplierReference = item.SupplierReference,
                IsAvailable = item.IsAvailable
            };
            var result = await ItemSupplierSvc.UpdateAsync(item.ItemId, item.SupplierId, request);
            if (result != null)
            {
                _dirtyRows.Remove(key);
                updated++;
            }
            else
            {
                Snackbar.Add("Failed to save link.", Severity.Error);
                errors++;
            }
        }

        if (created + updated > 0)
        {
            var parts = new List<string>();
            if (created > 0) parts.Add($"{created} created");
            if (updated > 0) parts.Add($"{updated} updated");
            Snackbar.Add(string.Join(", ", parts), Severity.Success);
            await LoadAsync();
        }
    }

    private async Task DeleteAsync(ItemSupplierResponse itemSupplier)
    {
        var deleted = await ItemSupplierSvc.DeleteAsync(itemSupplier.ItemId, itemSupplier.SupplierId);
        if (deleted)
        {
            Snackbar.Add($"Link \"{itemSupplier.ItemName} - {itemSupplier.SupplierName}\" deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Failed to delete link.", Severity.Error);
        }
    }
}
