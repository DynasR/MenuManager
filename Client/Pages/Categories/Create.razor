@page "/category/create"
@inject CategoryService CategorySvc
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>New Category</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">New Category</MudText>

<MudForm @ref="_form" @bind-IsValid="_isValid">
    <MudTextField @bind-Value="_dto.Name" Label="Name" Required="true"
                  RequiredError="Name is required." MaxLength="100" Class="mb-3" />
    <MudTextField @bind-Value="_dto.Description" Label="Description" Lines="3" Class="mb-3" />
    <MudSelect T="int?" @bind-Value="_dto.ParentCategoryId" Label="Parent Category"
               Clearable="true" Class="mb-3">
        @foreach (var cat in _categories)
        {
            <MudSelectItem T="int?" Value="@((int?)cat.Id)">@cat.Name</MudSelectItem>
        }
    </MudSelect>
</MudForm>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitAsync"
           Disabled="!_isValid" Class="mt-4 mr-2">
    Save
</MudButton>
<MudButton Variant="Variant.Text" OnClick="@(() => Nav.NavigateTo("/categories"))">
    Cancel
</MudButton>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private CreateCategoryRequest _dto = new();
    private List<CategoryResponse> _categories = [];

    protected override async Task OnInitializedAsync()
    {
        _categories = await CategorySvc.GetAllAsync();
    }

    private async Task SubmitAsync()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        var result = await CategorySvc.CreateAsync(_dto);
        if (result is not null)
        {
            Snackbar.Add("Category created.", Severity.Success);
            Nav.NavigateTo("/categories");
        }
        else
        {
            Snackbar.Add("Failed to create category.", Severity.Error);
        }
    }
}
