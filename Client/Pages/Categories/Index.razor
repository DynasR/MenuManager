@page "/categories"
@inject CategoryService CategorySvc
@inject ISnackbar Snackbar

<PageTitle>Categories</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Categories</MudText>

<MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.PlaylistAdd"
           OnClick="AddRow" Class="mb-4">
    Add row
</MudButton>
<MudButton Variant="Variant.Filled" Color="Color.Primary"
           Disabled="@(_pendingRows.Count == 0 && _dirtyRows.Count == 0)"
           OnClick="SaveAllAsync"
           StartIcon="@Icons.Material.Filled.SaveAlt"
           Class="mb-4 ml-2">
    Save All
</MudButton>

@if (_pendingRows.Count > 0)
{
    <MudDataGrid T="CategoryDraft" Items="_pendingRows" ReadOnly="false"
                 EditMode="DataGridEditMode.Cell" Hover="true" Dense="true"
                 Class="mb-0">
        <Columns>
            <PropertyColumn Property="x => x.Name" Title="Name" Editable="true" Style="width: 20%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Name" Required="true"
                                  RequiredError="Name is required." Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.Description" Title="Description" Editable="true" Style="width: 50%">
                <EditTemplate>
                    <MudTextField T="string" @bind-Value="context.Item.Description" Immediate="true" />
                </EditTemplate>
            </PropertyColumn>
            <PropertyColumn Property="x => x.ParentCategoryId" Title="Parent" Editable="true" Style="width: 20%">
                <CellTemplate>
                    @ParentName(context.Item.ParentCategoryId)
                </CellTemplate>
                <EditTemplate>
                    <MudSelect T="int?" @bind-Value="context.Item.ParentCategoryId"
                               Immediate="true" Margin="Margin.Dense">
                        <MudSelectItem T="int?" Value="@((int?)null)">— None —</MudSelectItem>
                        @foreach (var cat in _categories)
                        {
                            <MudSelectItem T="int?" Value="cat.Id">@cat.Name</MudSelectItem>
                        }
                    </MudSelect>
                </EditTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false" Style="width: 10%">
                <CellTemplate>
                    <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success" Size="Size.Small"
                                   Disabled="@(string.IsNullOrWhiteSpace(context.Item.Name))"
                                   OnClick="@(() => ValidateRow(context.Item))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => RemoveRow(context.Item))" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

<MudDataGrid T="CategoryResponse" Items="_categories" ReadOnly="false"
             EditMode="DataGridEditMode.Cell"
             Loading="_loading" Hover="true" Striped="true" Dense="true">
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Name" Editable="true" Style="width: 20%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Name"
                    ValueChanged="@((string val) => { context.Item.Name = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.Description" Title="Description" Editable="true" Style="width: 50%">
            <EditTemplate>
                <MudTextField
                    Value="@context.Item.Description"
                    ValueChanged="@((string val) => { context.Item.Description = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    Immediate="true" />
            </EditTemplate>
        </PropertyColumn>
        <PropertyColumn Property="x => x.ParentCategoryId" Title="Parent" Editable="true" Style="width: 20%">
            <CellTemplate>
                @ParentName(context.Item.ParentCategoryId)
            </CellTemplate>
            <EditTemplate>
                <MudSelect
                    Value="@context.Item.ParentCategoryId"
                    ValueChanged="@((int? val) => { context.Item.ParentCategoryId = val; _dirtyRows.Add(context.Item.Id); StateHasChanged(); })"
                    T="int?">
                    <MudSelectItem T="int?" Value="null">— None —</MudSelectItem>
                    @foreach (var cat in _categories.Where(c => c.Id != context.Item.Id))
                    {
                        <MudSelectItem T="int?" Value="@((int?)cat.Id)">@cat.Name</MudSelectItem>
                    }
                </MudSelect>
            </EditTemplate>
        </PropertyColumn>
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false" Editable="false" Style="width: 10%">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary" Size="Size.Small"
                               Disabled="@(!_dirtyRows.Contains(context.Item.Id))"
                               OnClick="@(() => SaveRow(context.Item))"
                               />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteAsync(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
</MudDataGrid>

@code {
    private List<CategoryResponse> _categories = [];
    private HashSet<int> _dirtyRows = new();
    private bool _loading = true;
    private List<CategoryDraft> _pendingRows = [];

    private sealed class CategoryDraft
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public int? ParentCategoryId { get; set; }
    }

    private void AddRow() => _pendingRows.Add(new CategoryDraft());

    private void RemoveRow(CategoryDraft draft) => _pendingRows.Remove(draft);

    private async Task<bool> ValidateRow(CategoryDraft draft)
    {
        var result = await CategorySvc.CreateAsync(new CreateCategoryRequest
        {
            Name = draft.Name,
            Description = draft.Description,
            ParentCategoryId = draft.ParentCategoryId
        });

        if (result is not null)
        {
            _pendingRows.Remove(draft);
            return true;
        }

        Snackbar.Add($"Failed to create \"{draft.Name}\"", Severity.Error);
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private string ParentName(int? parentId) =>
        parentId is null
            ? ""
            : _categories.FirstOrDefault(c => c.Id == parentId)?.Name ?? "";

    private async Task LoadAsync()
    {
        _loading = true;
        _categories = await CategorySvc.GetAllAsync();
        _dirtyRows.Clear();
        _loading = false;
    }

    private async Task SaveRow(CategoryResponse item)
    {
        var request = new UpdateCategoryRequest
        {
            Name = item.Name,
            Description = item.Description,
            ParentCategoryId = item.ParentCategoryId
        };
        var updated = await CategorySvc.UpdateAsync(item.Id, request);
        if (updated == null)
            Snackbar.Add($"Failed to save \"{item.Name}\"", Severity.Error);
        else
        {
            _dirtyRows.Remove(item.Id);
            StateHasChanged();
        }
    }

    private async Task SaveAllAsync()
    {
        int created = 0, updated = 0, errors = 0;

        foreach (var draft in _pendingRows.ToList())
        {
            if (await ValidateRow(draft))
                created++;
            else
                errors++;
        }

        foreach (var id in _dirtyRows.ToList())
        {
            var item = _categories.FirstOrDefault(c => c.Id == id);
            if (item == null) continue;

            var request = new UpdateCategoryRequest
            {
                Name = item.Name,
                Description = item.Description,
                ParentCategoryId = item.ParentCategoryId
            };
            var result = await CategorySvc.UpdateAsync(item.Id, request);
            if (result != null)
            {
                _dirtyRows.Remove(id);
                updated++;
            }
            else
            {
                Snackbar.Add($"Failed to save \"{item.Name}\"", Severity.Error);
                errors++;
            }
        }

        if (created + updated > 0)
        {
            var parts = new List<string>();
            if (created > 0) parts.Add($"{created} created");
            if (updated > 0) parts.Add($"{updated} updated");
            Snackbar.Add(string.Join(", ", parts), Severity.Success);
            await LoadAsync();
        }
    }

    private async Task DeleteAsync(CategoryResponse category)
    {
        var deleted = await CategorySvc.DeleteAsync(category.Id);
        if (deleted)
        {
            Snackbar.Add($"Category \"{category.Name}\" deleted.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Failed to delete category.", Severity.Error);
        }
    }
}
