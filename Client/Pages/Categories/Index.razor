@page "/categories"
@inject CategoryService CategorySvc
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Categories</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Categories</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
           OnClick="OpenCreateDialog" Class="mb-4">
    Nouveau
</MudButton>

<MudTable Items="_categories" Hover="true" Striped="true" Loading="_loading">
    <HeaderContent>
        <MudTh>Nom</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Parent</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Nom">@context.Name</MudTd>
        <MudTd DataLabel="Description">@context.Description</MudTd>
        <MudTd DataLabel="Parent">@ParentName(context.ParentCategoryId)</MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                           OnClick="@(() => OpenEditDialog(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                           OnClick="@(() => DeleteAsync(context))" />
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<CategoryResponse> _categories = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _categories = await CategorySvc.GetAllAsync();
        _loading = false;
    }

    private string ParentName(int? parentId) =>
        parentId is null
            ? ""
            : _categories.FirstOrDefault(c => c.Id == parentId)?.Name ?? "";

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<CategoryDialog>
        {
            { x => x.Categories, _categories }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CategoryDialog>("Nouvelle categorie", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
            await LoadAsync();
    }

    private async Task OpenEditDialog(CategoryResponse category)
    {
        var parameters = new DialogParameters<CategoryDialog>
        {
            { x => x.Category, category },
            { x => x.Categories, _categories }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CategoryDialog>("Modifier la categorie", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
            await LoadAsync();
    }

    private async Task DeleteAsync(CategoryResponse category)
    {
        var deleted = await CategorySvc.DeleteAsync(category.Id);
        if (deleted)
        {
            Snackbar.Add($"Categorie \"{category.Name}\" supprimee.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Impossible de supprimer cette categorie.", Severity.Error);
        }
    }
}
