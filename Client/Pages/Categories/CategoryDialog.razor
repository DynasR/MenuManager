@inject CategoryService CategorySvc
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_name" Label="Nom" Required="true"
                          RequiredError="Le nom est obligatoire." MaxLength="100" Class="mb-3" />
            <MudTextField @bind-Value="_description" Label="Description" Lines="3" Class="mb-3" />
            <MudSelect T="int?" @bind-Value="_parentCategoryId" Label="Categorie parente"
                       Clearable="true" Class="mb-3">
                @foreach (var cat in Categories.Where(c => c.Id != Category?.Id))
                {
                    <MudSelectItem T="int?" Value="@((int?)cat.Id)">@cat.Name</MudSelectItem>
                }
            </MudSelect>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuler</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="!_isValid">
            Enregistrer
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public CategoryResponse? Category { get; set; }
    [Parameter] public List<CategoryResponse> Categories { get; set; } = [];

    private MudForm _form = null!;
    private bool _isValid;
    private string _name = "";
    private string? _description;
    private int? _parentCategoryId;

    protected override void OnParametersSet()
    {
        if (Category is not null)
        {
            _name = Category.Name;
            _description = Category.Description;
            _parentCategoryId = Category.ParentCategoryId;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        if (Category is null)
        {
            var result = await CategorySvc.CreateAsync(new CreateCategoryRequest
            {
                Name = _name,
                Description = _description,
                ParentCategoryId = _parentCategoryId
            });

            if (result is not null)
            {
                Snackbar.Add("Categorie creee.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Erreur lors de la creation.", Severity.Error);
            }
        }
        else
        {
            var result = await CategorySvc.UpdateAsync(Category.Id, new UpdateCategoryRequest
            {
                Name = _name,
                Description = _description,
                ParentCategoryId = _parentCategoryId
            });

            if (result is not null)
            {
                Snackbar.Add("Categorie mise a jour.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Erreur lors de la mise a jour.", Severity.Error);
            }
        }
    }
}
