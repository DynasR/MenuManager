@page "/items/create"
@inject ItemService ItemSvc
@inject CategoryService CategorySvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Nouvel item</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Nouvel item</MudText>

<MudForm @ref="_form" @bind-IsValid="_isValid">
    <MudTextField @bind-Value="_dto.Name" Label="Nom" Required="true"
                  RequiredError="Le nom est obligatoire." MaxLength="100" Class="mb-3" />
    <MudTextField @bind-Value="_dto.Description" Label="Description" Lines="3" Class="mb-3" />
    <MudNumericField @bind-Value="_dto.Quantity" Label="Quantite" Class="mb-3" />
    <MudTextField @bind-Value="_dto.Unit" Label="Unite" MaxLength="50" Class="mb-3" />
    <MudSelect T="int" @bind-Value="_dto.CategoryId" Label="Categorie" Class="mb-3">
        @foreach (var cat in _categories)
        {
            <MudSelectItem T="int" Value="@cat.Id">@cat.Name</MudSelectItem>
        }
    </MudSelect>
</MudForm>

<MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
           Disabled="!_isValid" Class="mt-4 mr-2">
    Enregistrer
</MudButton>
<MudButton OnClick="@(() => Nav.NavigateTo("/items"))" Class="mt-4">
    Annuler
</MudButton>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private CreateItemRequest _dto = new();
    private List<CategoryResponse> _categories = [];

    protected override async Task OnInitializedAsync()
    {
        _categories = await CategorySvc.GetAllAsync();
    }

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        var result = await ItemSvc.CreateAsync(_dto);
        if (result is not null)
        {
            Snackbar.Add("Item cree.", Severity.Success);
            Nav.NavigateTo("/items");
        }
        else
        {
            Snackbar.Add("Erreur lors de la creation.", Severity.Error);
        }
    }
}
