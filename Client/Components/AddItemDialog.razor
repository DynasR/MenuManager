@using MenuManager.Shared.Enums
@using MenuManager.Client.Helpers
@inject ItemSupplierCache Cache
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <div style="display:flex; align-items:flex-start; justify-content:space-between; width:100%; gap:16px; flex-wrap:wrap;">
            <div>
                <MudText Typo="Typo.h6" Style="font-weight:700; line-height:1.2;">
                    @SelectedDate.ToString("dddd d MMMM yyyy", CostHelper.Fr)
                </MudText>
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                    @SelectedMealType.ToFrenchLabel()
                </MudText>
            </div>
            <div style="display:flex; align-items:center; gap:8px; flex-shrink:0;">
                <MudButtonGroup Size="Size.Small">
                    <MudButton Variant="@(_tab == 0 ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Restaurant"
                               OnClick="@(() => { _tab = 0; _search = ""; })">Items</MudButton>
                    <MudButton Variant="@(_tab == 1 ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.MenuBook"
                               OnClick="@(() => { _tab = 1; _search = ""; })">Recettes</MudButton>
                </MudButtonGroup>
                <MudTooltip Text="@(_filterByMealType ? "Voir tout" : "Filtrer par repas")">
                    <MudIconButton Icon="@(_filterByMealType ? Icons.Material.Filled.FilterAlt : Icons.Material.Outlined.FilterAlt)"
                                   Color="@(_filterByMealType ? Color.Primary : Color.Default)"
                                   Size="Size.Small" OnClick="@(() => _filterByMealType = !_filterByMealType)" />
                </MudTooltip>
                <MudTooltip Text="@(_denseView ? "Vue cards" : "Vue liste")">
                    <MudIconButton Icon="@(_denseView ? Icons.Material.Filled.ViewModule : Icons.Material.Filled.ViewList)"
                                   Size="Size.Small" OnClick="ToggleDenseViewAsync" />
                </MudTooltip>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => MudDialog.Cancel())" />
            </div>
        </div>
        <MudTextField @bind-Value="_search" Placeholder="Rechercher…"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" FullWidth="true" Margin="Margin.Dense" Class="mt-2" />
    </TitleContent>
    <DialogContent>
    <div style="display:flex; min-height:450px; gap:0;">
    <div style="flex:1; min-width:0; overflow:hidden;">
        @if (_tab == 0)
        {
            var filtered = AllItems
                .Where(i => i.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
                .Where(i => !_filterByMealType || PassesMealTypeFilter(i))
                .ToList();
            @if (_denseView)
            {
                <MudDataGrid T="ItemResponse" Items="filtered" Dense="true" ReadOnly="true"
                             SortMode="SortMode.Single" Hover="true"
                             RowClass="cursor-pointer"
                             RowClassFunc="@((item, _) => GetItemQty(item.Id) > 0 ? "qty-row-selected" : "")"
                             RowClick="HandleItemRowClick">
                    <Columns>
                        <PropertyColumn Property="x => x.Name" Title="Nom" HeaderStyle="text-align:center;" />
                        <PropertyColumn Property="x => x.CategoryName" Title="Catégorie" HeaderStyle="text-align:center;" />
                        <TemplateColumn Title="Fournisseur" Sortable="true" HeaderStyle="text-align:center;"
                                        SortBy="@(x => Cache.GetBestSupplier(x.Id)?.SupplierName ?? string.Empty)">
                            <CellTemplate>
                                @(Cache.GetBestSupplier(context.Item.Id)?.SupplierName ?? "—")
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Prix unitaire" Sortable="true" HeaderStyle="text-align:center;"
                                        SortBy="@(x => Cache.GetBestSupplier(x.Id)?.UnitPrice ?? 0m)">
                            <CellTemplate>
                                @GetBestUnitPrice(context.Item)
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Unité" Sortable="false" HeaderStyle="text-align:center;">
                            <CellTemplate>
                                @FormatUnit(context.Item.PurchaseUnit)
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="€/kg ou /L" Sortable="false" HeaderStyle="text-align:center;">
                            <CellTemplate>
                                @GetPricePerKgL(context.Item)
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Qté" HeaderStyle="text-align:center;"
                                        SortBy="@(x => GetItemQty(x.Id))">
                            <CellTemplate>
                                @{var ci = context.Item; var cq = GetItemQty(ci.Id);}
                                <div @onclick:stopPropagation="true" style="display:flex;align-items:center;gap:2px;white-space:nowrap;min-width:90px;">
                                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                                   Style="@(cq <= 0 ? "visibility:hidden;pointer-events:none;" : "")"
                                                   OnClick="@(() => DecrItemQty(ci.Id))" />
                                    <span style="min-width:1.4rem;text-align:center;font-size:0.78rem;font-weight:600;visibility:@(cq > 0 ? "visible" : "hidden");">@cq.ToString("0.#", CostHelper.Fr)</span>
                                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                                   OnClick="@(() => IncrItemQty(ci.Id))" />
                                </div>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            }
            else
            {
                <MudGrid Spacing="2">
                    @foreach (var item in filtered)
                    {
                        var ci = item;
                        var best = Cache.GetBestSupplier(item.Id);
                        var cq = GetItemQty(ci.Id);
                        <MudItem xs="6" sm="3">
                            <MudCard Outlined="true"
                                     Style="@($"cursor:pointer; height:100%;{(cq > 0 ? " border:1.5px solid var(--mud-palette-primary) !important;" : "")}")"
                                     @onclick="@(() => IncrItemQty(ci.Id))">
                                <div style="height:160px; @GetGradientStyle(item.CategoryName); display:flex; align-items:center; justify-content:center;">
                                    <MudIcon Icon="@Icons.Material.Filled.Restaurant"
                                             Style="font-size:3rem; color:rgba(255,255,255,0.45);" />
                                </div>
                                <MudCardContent Style="padding:8px 12px 4px;">
                                    <MudText Typo="Typo.body2" Style="font-weight:700;">@item.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.CategoryName</MudText>
                                    @if (best != null)
                                    {
                                        var pp = CostHelper.ComputePricePerKgL(best.UnitPrice, item.ContentQuantity, item.ContentUnit);
                                        <div style="display:flex; align-items:baseline; gap:6px; margin-top:2px; flex-wrap:wrap;">
                                            <MudText Typo="Typo.body2" Style="font-weight:700; color:var(--mud-palette-primary);">@FmtMoney(best.UnitPrice)</MudText>
                                            @if (pp != null) { <MudText Typo="Typo.caption" Color="Color.Secondary">@pp</MudText> }
                                        </div>
                                        <span class="add-dialog-badge add-dialog-badge-@(best.PaymentType == PaymentType.TR ? "tr" : "cb")">@best.PaymentType</span>
                                    }
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                        @FmtQty(item.ContentQuantity) @FormatUnit(item.ContentUnit) / @FormatUnit(item.PurchaseUnit)
                                    </MudText>
                                    <div @onclick:stopPropagation="true"
                                         style="display:flex;align-items:center;justify-content:flex-end;gap:2px;margin-top:4px;">
                                        @if (GetItemQty(ci.Id) > 0)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                                           OnClick="@(() => DecrItemQty(ci.Id))" />
                                            <span style="min-width:1.4rem;text-align:center;font-size:0.78rem;font-weight:600;">@GetItemQty(ci.Id).ToString("0.#", CostHelper.Fr)</span>
                                        }
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                                       OnClick="@(() => IncrItemQty(ci.Id))" />
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
        }
        else
        {
            var filtered = AllRecipes
                .Where(r => r.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
                .ToList();
            @if (_denseView)
            {
                <MudDataGrid T="RecipeResponse" Items="filtered" Dense="true" ReadOnly="true"
                             SortMode="SortMode.Single" Hover="true"
                             RowClass="cursor-pointer"
                             RowClassFunc="@((recipe, _) => GetRecipeQty(recipe.Id) > 0 ? "qty-row-selected" : "")"
                             RowClick="HandleRecipeRowClick">
                    <Columns>
                        <PropertyColumn Property="x => x.Name" Title="Nom" HeaderStyle="text-align:center;" />
                        <PropertyColumn Property="x => x.BaseServings" Title="Portions" HeaderStyle="text-align:center;" />
                        <TemplateColumn Title="Coût estimé" Sortable="false" HeaderStyle="text-align:center;">
                            <CellTemplate>
                                @(context.Item.EstimatedCost > 0 ? FmtMoney(context.Item.EstimatedCost) : "—")
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Coût/portion" Sortable="false" HeaderStyle="text-align:center;">
                            <CellTemplate>
                                @(context.Item.EstimatedCost > 0 && context.Item.BaseServings > 0
                                    ? FmtMoney(context.Item.EstimatedCost / context.Item.BaseServings)
                                    : "—")
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Ingrédients" Sortable="false" HeaderStyle="text-align:center;">
                            <CellTemplate>@context.Item.Ingredients.Count</CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Qté" HeaderStyle="text-align:center;"
                                        SortBy="@(x => GetRecipeQty(x.Id))">
                            <CellTemplate>
                                @{var cr = context.Item; var cq = GetRecipeQty(cr.Id);}
                                <div @onclick:stopPropagation="true" style="display:flex;align-items:center;gap:2px;white-space:nowrap;min-width:90px;">
                                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                                   Style="@(cq <= 0 ? "visibility:hidden;pointer-events:none;" : "")"
                                                   OnClick="@(() => DecrRecipeQty(cr.Id))" />
                                    <span style="min-width:1.4rem;text-align:center;font-size:0.78rem;font-weight:600;visibility:@(cq > 0 ? "visible" : "hidden");">@cq.ToString("0.#", CostHelper.Fr)</span>
                                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                                   OnClick="@(() => IncrRecipeQty(cr.Id))" />
                                </div>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            }
            else
            {
                <MudGrid Spacing="2">
                    @foreach (var recipe in filtered)
                    {
                        var cr = recipe;
                        var cq = GetRecipeQty(cr.Id);
                        <MudItem xs="6" sm="3">
                            <MudCard Outlined="true"
                                     Style="@($"cursor:pointer; height:100%;{(cq > 0 ? " border:1.5px solid var(--mud-palette-secondary) !important;" : "")}")"
                                     @onclick="@(() => IncrRecipeQty(cr.Id))">
                                <div style="height:160px; @GetGradientStyle(recipe.Name); display:flex; align-items:center; justify-content:center;">
                                    <MudIcon Icon="@Icons.Material.Filled.MenuBook"
                                             Style="font-size:3rem; color:rgba(255,255,255,0.45);" />
                                </div>
                                <MudCardContent Style="padding:8px 12px 4px;">
                                    <MudText Typo="Typo.body2" Style="font-weight:700;">@recipe.Name</MudText>
                                    @if (!string.IsNullOrWhiteSpace(recipe.Description))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                 Style="overflow:hidden; text-overflow:ellipsis; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
                                            @recipe.Description
                                        </MudText>
                                    }
                                    @if (recipe.EstimatedCost > 0)
                                    {
                                        <div style="margin-top:2px;">
                                            <MudText Typo="Typo.body2" Style="font-weight:700; color:var(--mud-palette-secondary);">
                                                @FmtMoney(recipe.EstimatedCost)
                                                @if (recipe.BaseServings > 0)
                                                {
                                                    <text> · @FmtMoney(recipe.EstimatedCost / recipe.BaseServings)/pers.</text>
                                                }
                                            </MudText>
                                        </div>
                                    }
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                        @recipe.BaseServings pers. · @recipe.Ingredients.Count ingréd.
                                    </MudText>
                                    <div @onclick:stopPropagation="true"
                                         style="display:flex;align-items:center;justify-content:flex-end;gap:2px;margin-top:4px;">
                                        @if (GetRecipeQty(cr.Id) > 0)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                                           OnClick="@(() => DecrRecipeQty(cr.Id))" />
                                            <span style="min-width:1.4rem;text-align:center;font-size:0.78rem;font-weight:600;">@GetRecipeQty(cr.Id).ToString("0.#", CostHelper.Fr)</span>
                                        }
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                                       OnClick="@(() => IncrRecipeQty(cr.Id))" />
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
        }
    </div>
    <div style="width:460px; flex-shrink:0; border-left:1px solid var(--mud-palette-divider); display:flex; flex-direction:column;">
        <MealRecap Items="BuildRecapItems().ToList()" MealType="SelectedMealType" CurrentDate="SelectedDate" OnQtyChange="HandleRecapQtyChange" />
    </div>
    </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())" Disabled="_saving">Annuler</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="ConfirmAsync" Disabled="_saving">Valider</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .add-dialog-badge {
        font-size: 0.6rem;
        font-weight: 700;
        opacity: 0.7;
        border-radius: 3px;
        padding: 0 3px;
        line-height: 1.5;
        white-space: nowrap;
    }
    .add-dialog-badge-tr { color: #1565C0; }
    .add-dialog-badge-cb { color: #6A1B9A; }

    .qty-row-selected {
        background: color-mix(in srgb, var(--mud-palette-primary) 12%, transparent) !important;
    }
    .qty-row-selected:hover {
        background: color-mix(in srgb, var(--mud-palette-primary) 20%, transparent) !important;
    }
</style>

@code {

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public DateOnly SelectedDate { get; set; }
    [Parameter] public MealType SelectedMealType { get; set; }
    [Parameter] public List<ItemResponse> AllItems { get; set; } = [];
    [Parameter] public List<RecipeResponse> AllRecipes { get; set; } = [];
    [Parameter] public List<MealItemResponse> CurrentMealItems { get; set; } = [];
    [Parameter] public Func<AddItemDialogSaveDiff, Task> OnSave { get; set; } = null!;

    private int _tab;
    private bool _denseView = true;
    private bool _filterByMealType = true;
    private string _search = "";
    private bool _saving;

    // Local quantity state (ItemId/RecipeId → quantity)
    private readonly Dictionary<int, decimal> _itemQty = new();
    private readonly Dictionary<int, decimal> _recipeQty = new();

    // Existing MealItems from current meal, keyed for diff computation
    private Dictionary<int, MealItemResponse> _existingByItemId = new();
    private Dictionary<int, MealItemResponse> _existingByRecipeId = new();

    protected override async Task OnInitializedAsync()
    {
        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "add-dialog-dense");
        if (stored == "false") _denseView = false;

        LoadSlot(CurrentMealItems);
    }

    private async Task ToggleDenseViewAsync()
    {
        _denseView = !_denseView;
        await JS.InvokeVoidAsync("localStorage.setItem", "add-dialog-dense", _denseView ? "true" : "false");
    }

    // ── Slot loading ──────────────────────────────────────────────────────────

    private void LoadSlot(List<MealItemResponse> items)
    {
        _itemQty.Clear();
        _recipeQty.Clear();
        _existingByItemId.Clear();
        _existingByRecipeId.Clear();

        foreach (var mi in items)
        {
            if (mi.RecipeId.HasValue)
            {
                _recipeQty[mi.RecipeId.Value] = mi.Quantity;
                _existingByRecipeId[mi.RecipeId.Value] = mi;
            }
            else
            {
                _itemQty[mi.ItemId] = mi.Quantity;
                _existingByItemId[mi.ItemId] = mi;
            }
        }
    }

    // ── Meal-type filter ─────────────────────────────────────────────────────

    private bool PassesMealTypeFilter(ItemResponse item)
    {
        var flag = ToMealTypeFlag(SelectedMealType);
        return ((MealTypeFlags)item.CategoryAllowedMealTypes).HasFlag(flag);
    }

    private static MealTypeFlags ToMealTypeFlag(MealType mealType) => mealType switch
    {
        MealType.Breakfast      => MealTypeFlags.Breakfast,
        MealType.MorningSnack   => MealTypeFlags.Snack,
        MealType.Lunch          => MealTypeFlags.Lunch,
        MealType.AfternoonSnack => MealTypeFlags.Snack,
        MealType.Dinner         => MealTypeFlags.Dinner,
        _                       => MealTypeFlags.None
    };

    // ── Quantity helpers ──────────────────────────────────────────────────────

    private decimal GetItemQty(int itemId) => _itemQty.GetValueOrDefault(itemId, 0);
    private decimal GetRecipeQty(int recipeId) => _recipeQty.GetValueOrDefault(recipeId, 0);

    private void IncrItemQty(int id) => _itemQty[id] = GetItemQty(id) + 1;
    private void DecrItemQty(int id)
    {
        var v = GetItemQty(id);
        if (v <= 1) _itemQty.Remove(id);
        else _itemQty[id] = v - 1;
    }

    private void IncrRecipeQty(int id) => _recipeQty[id] = GetRecipeQty(id) + 1;
    private void DecrRecipeQty(int id)
    {
        var v = GetRecipeQty(id);
        if (v <= 1) _recipeQty.Remove(id);
        else _recipeQty[id] = v - 1;
    }

    // ── Recap qty change (bidirectional) ─────────────────────────────────────

    private void HandleRecapQtyChange((int Id, decimal Qty, bool IsRecipe) args)
    {
        if (args.IsRecipe)
        {
            if (args.Qty <= 0) _recipeQty.Remove(args.Id);
            else _recipeQty[args.Id] = args.Qty;
        }
        else
        {
            if (args.Qty <= 0) _itemQty.Remove(args.Id);
            else _itemQty[args.Id] = args.Qty;
        }
    }

    // ── Row click handlers ────────────────────────────────────────────────────

    private void HandleItemRowClick(DataGridRowClickEventArgs<ItemResponse> args)
        => IncrItemQty(args.Item.Id);

    private void HandleRecipeRowClick(DataGridRowClickEventArgs<RecipeResponse> args)
        => IncrRecipeQty(args.Item.Id);

    // ── MealRecap feed ────────────────────────────────────────────────────────

    private List<MealItemResponse> BuildRecapItems()
    {
        var result = new List<MealItemResponse>();

        foreach (var (itemId, qty) in _itemQty.Where(kv => kv.Value > 0))
        {
            if (_existingByItemId.TryGetValue(itemId, out var ex))
            {
                result.Add(new MealItemResponse
                {
                    Id = ex.Id,
                    ItemId = ex.ItemId,
                    ItemName = ex.ItemName,
                    Quantity = qty,
                    Unit = ex.Unit,
                    ContentQuantity = ex.ContentQuantity,
                    PurchaseUnit = ex.PurchaseUnit,
                    ContentUnit = ex.ContentUnit,
                    UnitPrice = ex.UnitPrice,
                    MealId = ex.MealId,
                });
            }
            else
            {
                var item = AllItems.FirstOrDefault(i => i.Id == itemId);
                if (item == null) continue;
                result.Add(new MealItemResponse
                {
                    ItemId = itemId,
                    ItemName = item.Name,
                    Quantity = qty,
                    Unit = MeasurementUnit.Piece,
                    ContentQuantity = item.ContentQuantity,
                    PurchaseUnit = item.PurchaseUnit,
                    ContentUnit = item.ContentUnit,
                    UnitPrice = Cache.GetBestSupplier(itemId)?.UnitPrice,
                });
            }
        }

        foreach (var (recipeId, qty) in _recipeQty.Where(kv => kv.Value > 0))
        {
            if (_existingByRecipeId.TryGetValue(recipeId, out var ex))
            {
                result.Add(new MealItemResponse
                {
                    Id = ex.Id,
                    RecipeId = recipeId,
                    RecipeName = ex.RecipeName,
                    RecipeEstimatedCost = ex.RecipeEstimatedCost,
                    RecipeIngredientItemIds = ex.RecipeIngredientItemIds,
                    Quantity = qty,
                    Unit = MeasurementUnit.Piece,
                    MealId = ex.MealId,
                });
            }
            else
            {
                var recipe = AllRecipes.FirstOrDefault(r => r.Id == recipeId);
                if (recipe == null) continue;
                result.Add(new MealItemResponse
                {
                    RecipeId = recipeId,
                    RecipeName = recipe.Name,
                    RecipeEstimatedCost = recipe.EstimatedCost,
                    RecipeIngredientItemIds = recipe.Ingredients.Select(i => i.ItemId).ToList(),
                    Quantity = qty,
                    Unit = MeasurementUnit.Piece,
                });
            }
        }

        return result;
    }

    // ── Diff computation ──────────────────────────────────────────────────────

    private AddItemDialogSaveDiff ComputeDiff()
    {
        var toAddItems = new List<(int ItemId, decimal Qty)>();
        var toAddRecipes = new List<(int RecipeId, decimal Qty)>();
        var toUpdate = new List<(int MealItemId, decimal NewQty)>();
        var toDelete = new List<int>();

        foreach (var (itemId, qty) in _itemQty)
        {
            if (qty <= 0) continue;
            if (_existingByItemId.TryGetValue(itemId, out var ex))
            {
                if (ex.Quantity != qty)
                    toUpdate.Add((ex.Id, qty));
            }
            else
            {
                toAddItems.Add((itemId, qty));
            }
        }
        foreach (var (itemId, ex) in _existingByItemId)
        {
            if (!_itemQty.TryGetValue(itemId, out var qty) || qty <= 0)
                toDelete.Add(ex.Id);
        }

        foreach (var (recipeId, qty) in _recipeQty)
        {
            if (qty <= 0) continue;
            if (_existingByRecipeId.TryGetValue(recipeId, out var ex))
            {
                if (ex.Quantity != qty)
                    toUpdate.Add((ex.Id, qty));
            }
            else
            {
                toAddRecipes.Add((recipeId, qty));
            }
        }
        foreach (var (recipeId, ex) in _existingByRecipeId)
        {
            if (!_recipeQty.TryGetValue(recipeId, out var qty) || qty <= 0)
                toDelete.Add(ex.Id);
        }

        return new AddItemDialogSaveDiff(toAddItems, toAddRecipes, toUpdate, toDelete);
    }

    // ── Confirm / cancel ──────────────────────────────────────────────────────

    private async Task ConfirmAsync()
    {
        var diff = ComputeDiff();
        if (diff.ToAddItems.Count > 0 || diff.ToAddRecipes.Count > 0 ||
            diff.ToUpdate.Count > 0 || diff.ToDelete.Count > 0)
        {
            _saving = true;
            try { await OnSave(diff); }
            finally { _saving = false; }
        }
        MudDialog.Close();
    }

    // ── Display helpers ───────────────────────────────────────────────────────

    private string GetBestUnitPrice(ItemResponse item)
    {
        var best = Cache.GetBestSupplier(item.Id);
        return best != null ? FmtMoney(best.UnitPrice) : "—";
    }

    private string GetPricePerKgL(ItemResponse item)
    {
        var best = Cache.GetBestSupplier(item.Id);
        return best != null ? CostHelper.ComputePricePerKgL(best.UnitPrice, item.ContentQuantity, item.ContentUnit) ?? "—" : "—";
    }

    private static string FmtMoney(decimal v) => v.ToString("0.00 €", CostHelper.Fr);
    private static string FmtQty(decimal v) => v.ToString("0.##", CostHelper.Fr);

    private static string FormatUnit(MeasurementUnit unit) => unit switch
    {
        MeasurementUnit.Piece      => "pcs",
        MeasurementUnit.Gram       => "g",
        MeasurementUnit.Kilogram   => "kg",
        MeasurementUnit.Milliliter => "mL",
        MeasurementUnit.Liter      => "L",
        _                          => unit.ToString()
    };


    private static string GetGradientStyle(string? name)
    {
        if (string.IsNullOrEmpty(name)) name = "default";
        var h = 0;
        foreach (var c in name) h = h * 31 + c;
        h = Math.Abs(h) % 360;
        var h2 = (h + 40) % 360;
        return $"background: linear-gradient(135deg, hsl({h}, 55%, 38%) 0%, hsl({h2}, 50%, 28%) 100%);";
    }
}
