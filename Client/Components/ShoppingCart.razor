@using MenuManager.Shared.Enums
@using MenuManager.Shared.DTOs
@using MenuManager.Client.Helpers
@inject ItemSupplierCache ItemSupplierCache
@inject RightPanelState RightPanel
@implements IDisposable

<div>
    <div style="background: linear-gradient(135deg, #06091A 0%, #0C1228 60%, #050A1C 100%); color: white; padding: 12px 16px; display: flex; align-items: center; gap: 8px;">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Style="color: white;" />
        <MudText Typo="Typo.h6" Style="font-size: 1rem; font-weight: 600; color: white; margin: 0;">Shopping Cart</MudText>
    </div>

    @if (!_itemLines.Any() && !_recipeLines.Any())
    {
        <MudText Class="pa-4" Color="Color.Secondary">No items in the plan yet.</MudText>
    }
    else
    {
        @if (_itemLines.Any())
        {
            @if (_supplierDataLoaded)
            {
                @foreach (var group in _groupedLines)
                {
                    <MudText Typo="Typo.overline" Class="px-4 pt-3 pb-0"
                             Style="@(group.Key.PaymentType == PaymentType.TR ? "color: #1565C0;" : "color: #6A1B9A;")">
                        @group.Key.PaymentType — @group.Key.CompanyName
                    </MudText>
                    <MudList T="EnrichedShoppingLine" Dense="true" Class="px-2">
                        @foreach (var line in group)
                        {
                            var pricePer = ComputePricePerKgL(line.UnitPrice, line.ContentQuantity, line.ContentUnit);
                            var pct = _bestTotal > 0 ? line.BestCost / _bestTotal * 100 : 0m;
                            <MudListItem T="EnrichedShoppingLine">
                                <div style="display: flex; flex-direction: column; width: 100%; gap: 2px;">
                                    <div style="display: flex; justify-content: space-between; align-items: center; gap: 4px;">
                                        <MudText Typo="Typo.body2" Style="font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;">@line.Name</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="margin: 0; height: 20px; flex-shrink: 0;">
                                            @line.PackagesToBuy pkg
                                        </MudChip>
                                    </div>
                                    <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 4px;">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0;">
                                            @FmtQty(line.TotalQuantity) @FormatUnit(line.Unit)
                                            · @FmtMoney(line.UnitPrice)/u
                                            @if (pricePer != null) { <text>· @pricePer</text> }
                                        </MudText>
                                        <span style="flex-shrink: 0; display: flex; align-items: baseline; gap: 4px;">
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@FmtMoney(line.BestCost)</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@FmtQty(pct, 1)%</MudText>
                                        </span>
                                    </div>
                                </div>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                }
            }
            else
            {
                <MudText Typo="Typo.subtitle2" Class="px-4 pt-2 pb-1" Color="Color.Primary">Articles</MudText>
                <MudList T="ShoppingLine" Dense="true" Class="px-2">
                    @foreach (var line in _itemLines)
                    {
                        <MudListItem T="ShoppingLine">
                            <div style="display: flex; flex-direction: column; width: 100%;">
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@line.Name</MudText>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                        @line.PackagesToBuy pkg
                                    </MudChip>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @FmtQty(line.TotalQuantity) @FormatUnit(line.Unit)
                                    </MudText>
                                    <MudText Typo="Typo.body2">
                                        @(line.LineTotal.HasValue ? FmtMoney(line.LineTotal.Value) : "—")
                                    </MudText>
                                </div>
                            </div>
                        </MudListItem>
                        <MudDivider />
                    }
                </MudList>
            }
        }

        @if (_recipeLines.Any())
        {
            <MudText Typo="Typo.subtitle2" Class="px-4 pt-2 pb-1" Color="Color.Secondary">Recettes</MudText>
            <MudList T="RecipeLine" Dense="true" Class="px-2">
                @foreach (var line in _recipeLines)
                {
                    <MudListItem T="RecipeLine">
                        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@line.Name</MudText>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">×@FmtQty(line.TotalQuantity)</MudText>
                                <MudText Typo="Typo.body2">@FmtMoney(line.LineTotal)</MudText>
                            </div>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        }

        @if (!_supplierDataLoaded && _hasMissingPrices)
        {
            <MudText Typo="Typo.caption" Color="Color.Warning" Class="px-4 pb-2">
                * Certains articles n'ont pas de prix et ne sont pas inclus dans le total.
            </MudText>
        }

        <!-- Spacer so footer doesn't overlap last item -->
        <div style="height: 8px;"></div>
    }
</div>

<!-- Pinned footer -->
<div style="position: sticky; bottom: 0; background: var(--mud-palette-background, #fff); border-top: 1px solid rgba(128,128,128,0.2); z-index: 2;">
    @if (_supplierDataLoaded)
    {
        <div class="px-4 py-2" style="display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; align-items: baseline; gap: 5px;">
                <MudText Typo="Typo.caption" Style="color: #1565C0; font-weight: 700; letter-spacing: 0.05em;">TR</MudText>
                <MudText Typo="Typo.body1" Style="color: #1565C0; font-weight: 700;">@FmtMoney(_trTotal)</MudText>
            </div>
            <div style="display: flex; align-items: baseline; gap: 5px;">
                <MudText Typo="Typo.caption" Style="color: #6A1B9A; font-weight: 700; letter-spacing: 0.05em;">CB</MudText>
                <MudText Typo="Typo.body1" Style="color: #6A1B9A; font-weight: 700;">@FmtMoney(_cbTotal)</MudText>
            </div>
            <div style="display: flex; align-items: baseline; gap: 5px;">
                <MudText Typo="Typo.caption" Style="font-weight: 700; letter-spacing: 0.05em;">Total</MudText>
                <MudText Typo="Typo.body1" Style="font-weight: 700;">@FmtMoney(_footerTotal)</MudText>
            </div>
        </div>
        <MudDivider />
    }
</div>

@code {
    [Parameter]
    public IEnumerable<MealItemResponse> Items { get; set; } = [];

    [Parameter]
    public IEnumerable<RecipeResponse> Recipes { get; set; } = [];

    private static readonly System.Globalization.CultureInfo _frCulture = new("fr-FR");

    private List<ShoppingLine> _itemLines = [];
    private List<RecipeLine> _recipeLines = [];
    private decimal _grandTotal;
    private bool _hasMissingPrices;

    private Dictionary<int, RecipeResponse> _recipeById = [];

    // Enriched supplier data
    private bool _supplierDataLoaded;
    private HashSet<int> _loadedItemIds = [];
    private List<EnrichedShoppingLine> _enrichedLines = [];
    private IEnumerable<IGrouping<(PaymentType PaymentType, string CompanyName), EnrichedShoppingLine>> _groupedLines = [];
    private decimal _bestTotal;   // grouped items sum, used for % bar only
    private decimal _footerTotal; // per-item sum matching DayPlan._monthTotal
    private decimal _trTotal;
    private decimal _cbTotal;

    protected override void OnInitialized()
    {
        RightPanel.OnChange += OnPanelChanged;
    }

    protected override void OnParametersSet()
    {
        var itemMealItems = Items.Where(i => !i.RecipeId.HasValue).ToList();
        var recipeMealItems = Items.Where(i => i.RecipeId.HasValue).ToList();

        _itemLines = ComputeItemLines(itemMealItems);
        _recipeLines = ComputeRecipeLines(recipeMealItems);

        var itemTotal = _itemLines.Where(l => l.LineTotal.HasValue).Sum(l => l.LineTotal!.Value);
        var recipeTotal = _recipeLines.Sum(l => l.LineTotal);
        _grandTotal = itemTotal + recipeTotal;
        _hasMissingPrices = _itemLines.Any(l => !l.LineTotal.HasValue);

        _recipeById = Recipes.ToDictionary(r => r.Id);

        var currentItemIds = itemMealItems.Select(i => i.ItemId).Distinct().ToHashSet();
        if (!currentItemIds.SetEquals(_loadedItemIds))
        {
            _supplierDataLoaded = false;
            _loadedItemIds = currentItemIds;
        }
        else if (_supplierDataLoaded)
        {
            // IDs unchanged but quantities or recipes may have changed — refresh enriched totals.
            ComputeEnrichedLines();
        }
    }

    private void OnPanelChanged()
    {
        if (RightPanel.IsOpen && !_supplierDataLoaded && _loadedItemIds.Count > 0)
            InvokeAsync(LoadSupplierDataAsync);
    }

    private async Task LoadSupplierDataAsync()
    {
        await ItemSupplierCache.EnsureLoadedAsync();
        ComputeEnrichedLines();
        _supplierDataLoaded = true;
        await InvokeAsync(StateHasChanged);
    }

    private void ComputeEnrichedLines()
    {
        var itemMealItems = Items.Where(i => !i.RecipeId.HasValue).ToList();

        _enrichedLines = itemMealItems
            .GroupBy(i => i.ItemId)
            .Select(g =>
            {
                var first = g.First();
                var totalQty = g.Sum(i => i.Quantity);

                var best = ItemSupplierCache.GetBestSupplier(first.ItemId);
                if (best is null) return null;

                var packages = (int)Math.Ceiling(totalQty / (first.ContentQuantity > 0 ? first.ContentQuantity : 1m));
                var cost = CostHelper.PackageCost(totalQty, first.ContentQuantity, best.UnitPrice);

                return new EnrichedShoppingLine(
                    first.ItemName,
                    totalQty,
                    first.Unit,
                    first.ContentQuantity,
                    first.ContentUnit,
                    packages,
                    best.UnitPrice,
                    cost,
                    best.SupplierName,
                    best.PaymentType);
            })
            .OfType<EnrichedShoppingLine>()
            .OrderBy(l => l.Name)
            .ToList();

        _groupedLines = _enrichedLines
            .GroupBy(l => (l.RetainedPaymentType, l.RetainedSupplierName))
            .OrderBy(g => g.Key.RetainedPaymentType)
            .ThenBy(g => g.Key.RetainedSupplierName);

        _bestTotal = _enrichedLines.Sum(l => l.BestCost); // grouped items only, for % bar

        // TR / CB: per-item and per-recipe-ingredient computation.
        // Each MealItem (item) and each recipe ingredient is costed individually and
        // bucketed by the best supplier's PaymentType → TR + CB = Total in all cases.
        _trTotal = 0m;
        _cbTotal = 0m;

        foreach (var item in itemMealItems)
        {
            var best = ItemSupplierCache.GetBestSupplier(item.ItemId);
            if (best is null) continue;
            var cost = CostHelper.ComputeItemCost(item, best.UnitPrice);
            if (best.PaymentType == PaymentType.TR) _trTotal += cost;
            else _cbTotal += cost;
        }

        // Recipes: aggregate total qty per recipe, then cost each ingredient individually.
        foreach (var recipeGroup in Items.Where(i => i.RecipeId.HasValue).GroupBy(i => i.RecipeId!.Value))
        {
            if (!_recipeById.TryGetValue(recipeGroup.Key, out var recipe)) continue;
            var totalRecipeQty = recipeGroup.Sum(i => i.Quantity);
            foreach (var ri in recipe.Ingredients)
            {
                var best = ItemSupplierCache.GetBestSupplier(ri.ItemId);
                if (best is null) continue;
                var cost = CostHelper.PackageCost(ri.Quantity * totalRecipeQty, ri.ContentQuantity, best.UnitPrice);
                if (best.PaymentType == PaymentType.TR) _trTotal += cost;
                else _cbTotal += cost;
            }
        }

        _footerTotal = _trTotal + _cbTotal;
    }

    public void Dispose()
    {
        RightPanel.OnChange -= OnPanelChanged;
    }

    private static List<ShoppingLine> ComputeItemLines(IEnumerable<MealItemResponse> items)
    {
        return items
            .GroupBy(i => i.ItemId)
            .Select(g =>
            {
                var first = g.First();
                var totalQty = g.Sum(i => i.Quantity);
                var packages = (int)Math.Ceiling(totalQty / (first.ContentQuantity > 0 ? first.ContentQuantity : 1m));
                decimal? lineTotal = first.UnitPrice.HasValue
                    ? CostHelper.PackageCost(totalQty, first.ContentQuantity, first.UnitPrice.Value)
                    : null;

                return new ShoppingLine(
                    first.ItemName,
                    totalQty,
                    first.Unit,
                    first.ContentQuantity,
                    packages,
                    first.UnitPrice,
                    lineTotal);
            })
            .OrderBy(l => l.Name)
            .ToList();
    }

    private static List<RecipeLine> ComputeRecipeLines(IEnumerable<MealItemResponse> items)
    {
        return items
            .Where(i => i.RecipeId.HasValue)
            .GroupBy(i => i.RecipeId!.Value)
            .Select(g =>
            {
                var first = g.First();
                var totalQty = g.Sum(i => i.Quantity);
                var lineTotal = (first.RecipeEstimatedCost ?? 0) * totalQty;
                return new RecipeLine(first.RecipeName ?? "", totalQty, lineTotal);
            })
            .OrderBy(l => l.Name)
            .ToList();
    }

    private static string FmtMoney(decimal v) => v.ToString("0.## €", _frCulture);

    private static string FmtQty(decimal v, int maxDec = 2)
    {
        var fmt = "0." + new string('#', maxDec);
        return v.ToString(fmt, _frCulture);
    }

    private static string? ComputePricePerKgL(decimal unitPrice, decimal contentQty, MeasurementUnit contentUnit)
    {
        if (contentQty == 0) return null;
        return contentUnit switch
        {
            MeasurementUnit.Gram       => FmtMoney(unitPrice / contentQty * 1000) + "/kg",
            MeasurementUnit.Kilogram   => FmtMoney(unitPrice / contentQty) + "/kg",
            MeasurementUnit.Milliliter => FmtMoney(unitPrice / contentQty * 1000) + "/L",
            MeasurementUnit.Liter      => FmtMoney(unitPrice / contentQty) + "/L",
            _ => null
        };
    }

    private static string FormatUnit(MeasurementUnit unit) => unit switch
    {
        MeasurementUnit.Piece      => "pcs",
        MeasurementUnit.Gram       => "g",
        MeasurementUnit.Kilogram   => "kg",
        MeasurementUnit.Milliliter => "mL",
        MeasurementUnit.Liter      => "L",
        _ => unit.ToString()
    };

    private sealed record ShoppingLine(
        string Name,
        decimal TotalQuantity,
        MeasurementUnit Unit,
        decimal ContentQuantity,
        int PackagesToBuy,
        decimal? UnitPrice,
        decimal? LineTotal);

    private sealed record RecipeLine(
        string Name,
        decimal TotalQuantity,
        decimal LineTotal);

    private sealed record EnrichedShoppingLine(
        string Name,
        decimal TotalQuantity,
        MeasurementUnit Unit,
        decimal ContentQuantity,
        MeasurementUnit ContentUnit,
        int PackagesToBuy,
        decimal UnitPrice,
        decimal BestCost,
        string RetainedSupplierName,
        PaymentType RetainedPaymentType);
}
