@using MenuManager.Shared.Enums

<MudText Typo="Typo.h6" Class="pa-4">Shopping Cart</MudText>

@if (!_itemLines.Any() && !_recipeLines.Any())
{
    <MudText Class="pa-4" Color="Color.Secondary">No items in the plan yet.</MudText>
}
else
{
    @if (_itemLines.Any())
    {
        <MudText Typo="Typo.subtitle2" Class="px-4 pt-2 pb-1" Color="Color.Primary">Items</MudText>
        <MudList T="ShoppingLine" Dense="true" Class="px-2">
            @foreach (var line in _itemLines)
            {
                <MudListItem T="ShoppingLine">
                    <div style="display: flex; flex-direction: column; width: 100%;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@line.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                @line.PackagesToBuy pkg
                            </MudChip>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @line.TotalQuantity @FormatUnit(line.Unit)
                            </MudText>
                            <MudText Typo="Typo.body2">
                                @(line.LineTotal.HasValue ? line.LineTotal.Value.ToString("C2", _frCulture) : "—")
                            </MudText>
                        </div>
                    </div>
                </MudListItem>
                <MudDivider />
            }
        </MudList>
    }

    @if (_recipeLines.Any())
    {
        <MudText Typo="Typo.subtitle2" Class="px-4 pt-2 pb-1" Color="Color.Secondary">Recettes</MudText>
        <MudList T="RecipeLine" Dense="true" Class="px-2">
            @foreach (var line in _recipeLines)
            {
                <MudListItem T="RecipeLine">
                    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">@line.Name</MudText>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">×@line.TotalQuantity</MudText>
                            <MudText Typo="Typo.body2">@line.LineTotal.ToString("C2", _frCulture)</MudText>
                        </div>
                    </div>
                </MudListItem>
                <MudDivider />
            }
        </MudList>
    }

    <div class="pa-4" style="display: flex; justify-content: space-between; align-items: center;">
        <MudText Typo="Typo.h6">Total</MudText>
        <MudText Typo="Typo.h6">@_grandTotal.ToString("C2", _frCulture)</MudText>
    </div>

    @if (_hasMissingPrices)
    {
        <MudText Typo="Typo.caption" Color="Color.Warning" Class="px-4 pb-2">
            * Some items have missing prices and are not included in the total.
        </MudText>
    }
}

@code {
    [Parameter]
    public IEnumerable<MealItemResponse> Items { get; set; } = [];

    private static readonly System.Globalization.CultureInfo _frCulture = new("fr-FR");

    private List<ShoppingLine> _itemLines = [];
    private List<RecipeLine> _recipeLines = [];
    private decimal _grandTotal;
    private bool _hasMissingPrices;

    protected override void OnParametersSet()
    {
        var itemMealItems = Items.Where(i => !i.RecipeId.HasValue).ToList();
        var recipeMealItems = Items.Where(i => i.RecipeId.HasValue).ToList();

        _itemLines = ComputeItemLines(itemMealItems);
        _recipeLines = ComputeRecipeLines(recipeMealItems);

        var itemTotal = _itemLines.Where(l => l.LineTotal.HasValue).Sum(l => l.LineTotal!.Value);
        var recipeTotal = _recipeLines.Sum(l => l.LineTotal);
        _grandTotal = itemTotal + recipeTotal;
        _hasMissingPrices = _itemLines.Any(l => !l.LineTotal.HasValue);
    }

    private static List<ShoppingLine> ComputeItemLines(IEnumerable<MealItemResponse> items)
    {
        return items
            .GroupBy(i => i.ItemId)
            .Select(g =>
            {
                var first = g.First();
                var totalQty = g.Sum(i => i.Quantity);
                var packages = (int)Math.Ceiling(totalQty / first.ContentQuantity);
                decimal? lineTotal = first.UnitPrice.HasValue ? packages * first.UnitPrice.Value : null;

                return new ShoppingLine(
                    first.ItemName,
                    totalQty,
                    first.Unit,
                    first.ContentQuantity,
                    packages,
                    first.UnitPrice,
                    lineTotal);
            })
            .OrderBy(l => l.Name)
            .ToList();
    }

    private static List<RecipeLine> ComputeRecipeLines(IEnumerable<MealItemResponse> items)
    {
        return items
            .Where(i => i.RecipeId.HasValue)
            .GroupBy(i => i.RecipeId!.Value)
            .Select(g =>
            {
                var first = g.First();
                var totalQty = g.Sum(i => i.Quantity);
                var lineTotal = (first.RecipeEstimatedCost ?? 0) * totalQty;
                return new RecipeLine(first.RecipeName ?? "", totalQty, lineTotal);
            })
            .OrderBy(l => l.Name)
            .ToList();
    }

    private static string FormatUnit(MeasurementUnit unit) => unit switch
    {
        MeasurementUnit.Piece => "pcs",
        MeasurementUnit.Gram => "g",
        MeasurementUnit.Kilogram => "kg",
        MeasurementUnit.Milliliter => "mL",
        MeasurementUnit.Liter => "L",
        _ => unit.ToString()
    };

    private sealed record ShoppingLine(
        string Name,
        decimal TotalQuantity,
        MeasurementUnit Unit,
        decimal ContentQuantity,
        int PackagesToBuy,
        decimal? UnitPrice,
        decimal? LineTotal);

    private sealed record RecipeLine(
        string Name,
        decimal TotalQuantity,
        decimal LineTotal);
}
