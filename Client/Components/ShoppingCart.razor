@using MenuManager.Shared.Enums
@using MenuManager.Shared.DTOs
@using MenuManager.Client.Helpers
@inject ItemSupplierCache Cache
@inject RightPanelState RightPanel
@implements IDisposable

<style>
    .sc-header {
        background: linear-gradient(135deg, #06091A 0%, #0C1228 60%, #050A1C 100%);
        color: white; padding: 12px 16px;
        display: flex; align-items: center; gap: 8px;
    }

    /* 4-column grid shared by column labels, data rows, and footer */
    .sc-col-labels, .sc-row, .sc-footer-row {
        display: grid;
        grid-template-columns: 1fr 52px 58px 62px;
        gap: 4px;
        padding-left: 12px;
        padding-right: 12px;
        box-sizing: border-box;
        width: 100%;
    }

    .sc-col-labels {
        padding-top: 6px;
        padding-bottom: 2px;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--mud-palette-text-secondary);
    }
    .sc-col-labels > span:not(:first-child) { text-align: right; }

    .sc-row {
        padding-top: 5px;
        padding-bottom: 5px;
        align-items: start;
        border-top: 1px solid color-mix(in srgb, var(--mud-palette-text-secondary) 12%, transparent);
        transition: background 0.12s;
    }
    .sc-row:hover { background: color-mix(in srgb, var(--mud-palette-text-primary) 5%, transparent); }
    .sc-row-alt { background: color-mix(in srgb, var(--mud-palette-text-primary) 2%, transparent); }
    .sc-row-alt:hover { background: color-mix(in srgb, var(--mud-palette-text-primary) 6%, transparent); }

    .sc-cell-name {
        display: flex; flex-direction: column; gap: 1px;
        min-width: 0; overflow: hidden;
    }
    .sc-name {
        font-size: 0.82rem; font-weight: 600;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sc-meta { font-size: 0.67rem; color: var(--mud-palette-text-secondary); white-space: nowrap; }

    .sc-cell-num {
        font-size: 0.78rem;
        text-align: right;
        white-space: nowrap;
        padding-top: 2px;
        color: var(--mud-palette-text-secondary);
    }

    .sc-cell-total {
        display: flex; flex-direction: column; align-items: flex-end; gap: 1px;
    }
    .sc-total-amount { font-size: 0.82rem; font-weight: 600; white-space: nowrap; }
    .sc-pct { font-size: 0.65rem; color: var(--mud-palette-text-secondary); }

    .sc-group-header {
        display: flex; align-items: center; gap: 6px;
        padding: 6px 12px 2px;
        font-size: 0.7rem; font-weight: 700;
        letter-spacing: 0.04em; text-transform: uppercase;
        color: var(--sc-accent, currentColor);
    }
    .sc-group-badge {
        color: var(--sc-accent, currentColor);
        background: color-mix(in srgb, var(--sc-accent, currentColor) 15%, transparent);
        padding: 1px 5px; border-radius: 3px;
        font-size: 0.65rem; font-weight: 800;
    }
    .sc-group-name {
        font-weight: 600;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    /* Outer wrapper — fills the drawer's flex column */
    .sc-wrap {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: 0;
        overflow: hidden;
    }

    /* Scrollable content area */
    .sc-scroll {
        flex: 1;
        overflow-y: auto;
        min-height: 0;
        scrollbar-gutter: stable;
    }

    /* Pinned footer — always at bottom, same parent as sc-scroll */
    .sc-footer-wrap {
        flex-shrink: 0;
        background: var(--mud-palette-background, #fff);
        border-top: 2px solid color-mix(in srgb, var(--mud-palette-text-secondary) 20%, transparent);
        scrollbar-gutter: stable;
    }
    .sc-footer-row {
        padding-top: 8px;
        padding-bottom: 8px;
        align-items: baseline;
    }
    .sc-footer-tr  { font-size: 0.82rem; font-weight: 700; color: #1565C0; white-space: nowrap; }
    .sc-footer-cb  { font-size: 0.82rem; font-weight: 700; color: #6A1B9A; white-space: nowrap; }
    .sc-footer-total { font-size: 0.9rem; font-weight: 700; text-align: right; white-space: nowrap; }

    .sc-recipes-header {
        display: flex; align-items: center; gap: 6px;
        padding: 8px 12px 2px;
        font-size: 0.7rem; font-weight: 700;
        letter-spacing: 0.04em; text-transform: uppercase;
        color: #E65100;
        border-top: 1px solid color-mix(in srgb, #E65100 25%, transparent);
        margin-top: 4px;
    }
    .sc-recipes-badge {
        color: #E65100;
        background: color-mix(in srgb, #E65100 15%, transparent);
        padding: 1px 5px; border-radius: 3px;
        font-size: 0.65rem; font-weight: 800;
    }
    .sc-recipe-pt {
        font-size: 0.67rem; font-weight: 700; padding: 0 3px; border-radius: 2px;
        white-space: nowrap;
    }
</style>

<div class="sc-wrap">
<div class="sc-scroll">
    <div class="sc-header">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Style="color: white;" />
        <MudText Typo="Typo.h6" Style="font-size: 1rem; font-weight: 600; color: white; margin: 0;">Shopping Cart</MudText>
    </div>

    @if (!_lines.Any() && !_recipeLines.Any())
    {
        <MudText Class="pa-4" Color="Color.Secondary">No items in the plan yet.</MudText>
    }
    else if (!_loaded)
    {
        <MudProgressLinear Indeterminate="true" Class="mt-2" />
    }
    else
    {
        <div class="sc-col-labels">
            <span>Article</span>
            <span>Qté</span>
            <span>U</span>
            <span>Total</span>
        </div>

        @foreach (var group in _groups)
        {
            var accentColor = group.Key.PaymentType == PaymentType.TR ? "#1565C0" : "#6A1B9A";
            <div class="sc-group-header" style="--sc-accent: @accentColor;">
                <span class="sc-group-badge">@group.Key.PaymentType</span>
                <span class="sc-group-name">@group.Key.SupplierName</span>
            </div>
            @foreach (var (line, idx) in group.Select((l, i) => (l, i)))
            {
                var pricePer = CostHelper.ComputePricePerKgL(line.UnitPrice, line.ContentQuantity, line.ContentUnit);
                var pct = _total > 0 ? line.Cost / _total * 100 : 0m;
                <div class="sc-row @(idx % 2 == 1 ? "sc-row-alt" : "")">
                    <div class="sc-cell-name">
                        <span class="sc-name">@line.Name</span>
                        <span class="sc-meta">
                            @line.PackagesToBuy pkg
                            @if (pricePer != null) { <text>· @pricePer</text> }
                        </span>
                    </div>
                    <span class="sc-cell-num">@line.PackageCount</span>
                    <span class="sc-cell-num">@FmtMoney(line.UnitPrice)</span>
                    <div class="sc-cell-total">
                        <span class="sc-total-amount">@FmtMoney(line.Cost)</span>
                        <span class="sc-pct">@FmtQty(pct, 1)%</span>
                    </div>
                </div>
            }
        }

        @if (_recipeLines.Any())
        {
            <div class="sc-recipes-header">
                <span class="sc-recipes-badge">Recettes</span>
                <span>Ingrédients recettes</span>
            </div>
            @foreach (var (line, idx) in _recipeLines.Select((l, i) => (l, i)))
            {
                var pct = _total > 0 ? line.Cost / _total * 100 : 0m;
                <div class="sc-row @(idx % 2 == 1 ? "sc-row-alt" : "")">
                    <div class="sc-cell-name">
                        <span class="sc-name">@line.Name</span>
                        <span class="sc-meta" style="display:flex; align-items:center; gap:3px;">
                            @FmtQty(line.Portions, 1) pt.
                            @if (line.TrCost > 0) { <span class="sc-recipe-pt" style="color:#1565C0; background:color-mix(in srgb,#1565C0 12%,transparent);">TR</span> }
                            @if (line.CbCost > 0) { <span class="sc-recipe-pt" style="color:#6A1B9A; background:color-mix(in srgb,#6A1B9A 12%,transparent);">CB</span> }
                        </span>
                    </div>
                    <span class="sc-cell-num">@FmtQty(line.Portions, 1)</span>
                    <span class="sc-cell-num">@FmtMoney(line.CostPerPortion)</span>
                    <div class="sc-cell-total">
                        <span class="sc-total-amount">@FmtMoney(line.Cost)</span>
                        <span class="sc-pct">@FmtQty(pct, 1)%</span>
                    </div>
                </div>
            }
        }

        <div style="height: 8px;"></div>
    }
</div>

<div class="sc-footer-wrap">
    @if (_loaded && (_lines.Any() || _recipeLines.Any()))
    {
        <div class="sc-footer-row">
            <span style="display:flex; align-items:center; gap:4px; white-space:nowrap;">
                @if (_trTotal > 0) { <span class="sc-footer-tr">@FmtMoney(_trTotal)</span> }
                @if (_trTotal > 0 && _cbTotal > 0) { <span style="opacity:0.4;">|</span> }
                @if (_cbTotal > 0) { <span class="sc-footer-cb">@FmtMoney(_cbTotal)</span> }
            </span>
            <span></span>
            <span></span>
            <span class="sc-footer-total">@FmtMoney(_total)</span>
        </div>
    }
</div>
</div>

@code {
    [Parameter]
    public IEnumerable<MealItemResponse> Items { get; set; } = [];


    private bool _loaded;
    private List<CartLine> _lines = [];
    private IEnumerable<IGrouping<(PaymentType PaymentType, string SupplierName), CartLine>> _groups = [];
    private List<RecipeCartLine> _recipeLines = [];
    private decimal _trTotal, _cbTotal, _total;

    protected override void OnInitialized()
        => RightPanel.OnChange += OnPanelChanged;

    protected override void OnParametersSet()
    {
        if (_loaded) ComputeLines();
    }

    private void OnPanelChanged()
    {
        if (RightPanel.IsOpen && !_loaded)
            InvokeAsync(LoadAsync);
    }

    private async Task LoadAsync()
    {
        await Cache.EnsureLoadedAsync();
        _loaded = true;
        ComputeLines();
        await InvokeAsync(StateHasChanged);
    }

    private void ComputeLines()
    {
        _lines = Items
            .Where(i => !i.RecipeId.HasValue)
            .GroupBy(i => i.ItemId)
            .Select(g =>
            {
                var first = g.First();
                var best = Cache.GetBestSupplier(first.ItemId);
                if (best is null) return null;
                // Cost: sum per-slot exactly as MealCell does (ceil per slot, then sum)
                var cost = g.Sum(i => CostHelper.ComputeItemCost(i, best.UnitPrice));
                var totalQty = g.Sum(i => i.Quantity);
                var packages = (int)g.Sum(i => Math.Ceiling(i.Quantity / Math.Max(first.ContentQuantity, 0.001m)));
                return new CartLine(
                    first.ItemName,
                    totalQty,
                    first.Unit,
                    first.ContentQuantity,
                    first.ContentUnit,
                    packages,
                    best.UnitPrice,
                    cost,
                    best.SupplierName,
                    best.PaymentType);
            })
            .OfType<CartLine>()
            .OrderBy(l => l.Name)
            .ToList();

        _groups = _lines
            .GroupBy(l => (l.PaymentType, l.SupplierName))
            .OrderBy(g => g.Key.PaymentType)
            .ThenBy(g => g.Key.SupplierName);

        _recipeLines = Items
            .Where(i => i.RecipeId.HasValue)
            .GroupBy(i => i.RecipeId!)
            .Select(g =>
            {
                var first = g.First();
                var totalPortions = g.Sum(i => i.Quantity);
                var costPerPortion = (first.RecipeEstimatedCost ?? 0m) / Math.Max(first.RecipeBaseServings, 1);
                var totalCost = costPerPortion * totalPortions;
                var paymentTypes = CostHelper.GetRecipePaymentTypes(first.RecipeIngredientItemIds, Cache);
                var (tr, cb) = CostHelper.BucketByCost(totalCost, paymentTypes);
                return new RecipeCartLine(
                    first.RecipeName ?? first.ItemName,
                    totalPortions,
                    costPerPortion,
                    totalCost,
                    tr,
                    cb);
            })
            .OrderBy(l => l.Name)
            .ToList();

        _trTotal = _lines.Where(l => l.PaymentType == PaymentType.TR).Sum(l => l.Cost)
                 + _recipeLines.Sum(l => l.TrCost);
        _cbTotal = _lines.Where(l => l.PaymentType == PaymentType.CB).Sum(l => l.Cost)
                 + _recipeLines.Sum(l => l.CbCost);
        _total = _trTotal + _cbTotal;
    }

    public void Dispose()
        => RightPanel.OnChange -= OnPanelChanged;

    private static string FmtMoney(decimal v) => v.ToString("0.00 €", CostHelper.Fr);

    private static string FmtQty(decimal v, int maxDec = 2)
    {
        var fmt = "0." + new string('#', maxDec);
        return v.ToString(fmt, CostHelper.Fr);
    }


    private sealed record CartLine(
        string Name,
        decimal TotalQuantity,
        MeasurementUnit Unit,
        decimal ContentQuantity,
        MeasurementUnit ContentUnit,
        int PackagesToBuy,
        decimal UnitPrice,
        decimal Cost,
        string SupplierName,
        PaymentType PaymentType)
    {
        public int PackageCount => (int)Math.Ceiling(TotalQuantity / Math.Max(ContentQuantity, 0.001m));
    }

    private sealed record RecipeCartLine(
        string Name,
        decimal Portions,
        decimal CostPerPortion,
        decimal Cost,
        decimal TrCost,
        decimal CbCost);
}
