@implements IAsyncDisposable
@inject IJSRuntime JS

<div @ref="_cellRef"
     draggable="true"
     class="meal-cell @(Items.Count == 0 ? "meal-cell-empty" : "") @(IsBeingDragged ? "cell-drag-source" : "")"
     @ondragstart="HandleFooterDragStart"
     @ondragend="HandleFooterDragEnd"
     @ondrop="HandleCellDropAsync"
     @onclick="HandleCellClick">
    <ul @ref="_listRef" data-date="@Date.ToString("yyyy-MM-dd")" data-mealtype="@MealType.ToString()" class="meal-cell-list"
        @ondragstart:stopPropagation="true">
        @foreach (var item in Items)
        {
            var capturedItem = item;
            <li @key="item.Id" data-item-id="@item.Id" class="meal-cell-item @(item.Id == 0 ? "meal-cell-item-no-id" : "")"
                @onclick="@(e => HandleItemClick(e, capturedItem.Id))"
                @onclick:stopPropagation="true"
                @ondblclick="@(() => OnItemRemoved.InvokeAsync(capturedItem.Id))"
                @ondblclick:stopPropagation="true">
                <span class="meal-cell-item-name">@item.ItemName</span>
                <span class="meal-cell-item-price">@FormatItemPrice(item)</span>
            </li>
        }
    </ul>
    <div class="meal-cell-footer" @ref="_footerRef"
         @ondragstart:stopPropagation="true"
         @ondragend:stopPropagation="true"
         @onclick:stopPropagation="true">
        <div class="footer-zone-side" draggable="true"
             @ondragstart="HandleFooterDragStart" @ondragend="HandleFooterDragEnd"
             @onclick="HandleFooterZoneClick" @onclick:stopPropagation="true"></div>
        <span class="meal-cell-slot-total @(_clearPrimed ? "total-primed" : "")"
              draggable="true"
              @ondragstart:preventDefault="true"
              @ondragstart:stopPropagation="true"
              @onmousedown="HandleTotalMouseDown"
              @onmousedown:stopPropagation="true"
              @onmouseup="@(() => { _clearPrimed = false; })"
              @onmouseup:stopPropagation="true"
              @ondblclick="HandleTotalDblClick"
              @ondblclick:stopPropagation="true"
              @onmouseleave="@(() => { _clearPrimed = false; })">
            @(SlotTotal > 0 ? SlotTotal.ToString("C", _fr) : "")
        </span>
        <div class="footer-zone-side" draggable="true"
             @ondragstart="HandleFooterDragStart" @ondragend="HandleFooterDragEnd"
             @onclick="HandleFooterZoneClick" @onclick:stopPropagation="true"></div>
    </div>
</div>

@code {
    private static readonly System.Globalization.CultureInfo _fr = new("fr-FR");

    [Parameter, EditorRequired] public DateOnly Date { get; set; }
    [Parameter, EditorRequired] public MealType MealType { get; set; }
    [Parameter] public int? MealId { get; set; }
    [Parameter] public List<MealItemResponse> Items { get; set; } = [];
    [Parameter] public bool IsActionTarget { get; set; }
    [Parameter] public bool IsBeingDragged { get; set; }

    private decimal SlotTotal => Items
        .Where(i => i.UnitPrice.HasValue)
        .Sum(i => Math.Ceiling(i.Quantity / i.PackageSize) * i.UnitPrice!.Value);

    private string FormatItemPrice(MealItemResponse item)
    {
        if (!item.UnitPrice.HasValue) return "";
        var cost = Math.Ceiling(item.Quantity / item.PackageSize) * item.UnitPrice.Value;
        return cost.ToString("C", _fr);
    }

    [Parameter] public EventCallback<(int itemId, DateOnly fromDate, MealType fromMealType, DateOnly toDate, MealType toMealType, int newIndex, bool isCopy)> OnItemMoved { get; set; }
    [Parameter] public EventCallback<int> OnItemRemoved { get; set; }
    [Parameter] public EventCallback<(DateOnly date, MealType mealType)> OnAddRequested { get; set; }
    [Parameter] public EventCallback<(int? mealId, List<int> orderedIds)> OnOrderChanged { get; set; }
    [Parameter] public EventCallback<(DateOnly fromDate, MealType fromMealType, bool isCopy)> OnCellFooterDrop { get; set; }
    [Parameter] public EventCallback<(DateOnly date, MealType mealType, int mealItemId)> OnItemCloneRequested { get; set; }
    [Parameter] public EventCallback<(DateOnly date, MealType mealType)> OnDragStarted { get; set; }
    [Parameter] public EventCallback OnDragEnded { get; set; }
    [Parameter] public EventCallback<(DateOnly date, MealType mealType)> OnCellClearRequested { get; set; }

    private bool _clearPrimed;

    // --- ShouldRender optimisation ---
    private List<MealItemResponse>? _renderedItems;
    private int? _renderedMealId;
    private bool _renderedIsBeingDragged;
    private bool _renderedIsActionTarget;
    private bool _renderedClearPrimed;

    protected override bool ShouldRender()
    {
        var should = _renderedClearPrimed != _clearPrimed
            || _renderedIsBeingDragged != IsBeingDragged
            || _renderedIsActionTarget != IsActionTarget
            || _renderedMealId != MealId
            || !ItemsEqual(_renderedItems, Items);
        return should;
    }

    private static bool ItemsEqual(List<MealItemResponse>? a, List<MealItemResponse>? b)
    {
        if (ReferenceEquals(a, b)) return true;
        if (a is null || b is null) return false;
        if (a.Count != b.Count) return false;
        for (var i = 0; i < a.Count; i++)
            if (a[i].Id != b[i].Id || a[i].Quantity != b[i].Quantity || a[i].Order != b[i].Order)
                return false;
        return true;
    }
    // ---

    private async Task HandleCellClick()
    {
        if (!IsActionTarget)
            await OnAddRequested.InvokeAsync((Date, MealType));
    }

    private async Task HandleItemClick(MouseEventArgs e, int mealItemId)
    {
        if (e.CtrlKey)
            await OnItemCloneRequested.InvokeAsync((Date, MealType, mealItemId));
        else
            await OnAddRequested.InvokeAsync((Date, MealType));
    }

    private void HandleTotalMouseDown()
    {
        if (Items.Count > 0) _clearPrimed = true;
    }

    private async Task HandleTotalDblClick()
    {
        if (Items.Count > 0)
        {
            _clearPrimed = false;
            await OnCellClearRequested.InvokeAsync((Date, MealType));
        }
    }

    private async Task HandleFooterDragStart(DragEventArgs e)
    {
        _ = JS.InvokeVoidAsync("setFooterDragSource", _footerRef, Date.ToString("yyyy-MM-dd"), MealType.ToString(), e.CtrlKey);
        await OnDragStarted.InvokeAsync((Date, MealType));
    }

    private async Task HandleFooterDragEnd(DragEventArgs e)
    {
        _ = JS.InvokeVoidAsync("clearFooterDragSource");
        await OnDragEnded.InvokeAsync();
    }

    private async Task HandleCellDropAsync(DragEventArgs _)
    {
        var raw = await JS.InvokeAsync<string?>("getAndClearFooterDragSource");
        if (raw is null) return;
        var parts = raw.Split('|');
        if (parts.Length != 3) return;
        if (!DateOnly.TryParse(parts[0], out var fromDate)) return;
        if (!Enum.TryParse<MealType>(parts[1], out var fromMealType)) return;
        var isCopy = parts[2] == "1";
        await OnCellFooterDrop.InvokeAsync((fromDate, fromMealType, isCopy));
    }

    private async Task HandleFooterZoneClick()
        => await OnAddRequested.InvokeAsync((Date, MealType));

    private ElementReference _cellRef;
    private ElementReference _listRef;
    private ElementReference _footerRef;
    private DotNetObjectReference<MealCell>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _renderedItems = Items;
        _renderedMealId = MealId;
        _renderedIsBeingDragged = IsBeingDragged;
        _renderedIsActionTarget = IsActionTarget;
        _renderedClearPrimed = _clearPrimed;

        if (firstRender)
        {
            await JS.InvokeVoidAsync("addCellDragOverHandler", _cellRef);
            await JS.InvokeVoidAsync("initSortable", _listRef, "mealslots");
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("observeSortable", _listRef, _dotNetRef);
        }
    }

    [JSInvokable("OnDrop")]
    public async Task HandleDrop(int itemId, string fromDate, string fromMealType, string toDate, string toMealType, int newIndex, bool isCopy)
    {
        if (DateOnly.TryParse(fromDate, out var fd) &&
            DateOnly.TryParse(toDate, out var td) &&
            Enum.TryParse<MealType>(fromMealType, out var fmt) &&
            Enum.TryParse<MealType>(toMealType, out var tmt))
        {
            await OnItemMoved.InvokeAsync((itemId, fd, fmt, td, tmt, newIndex, isCopy));
        }
    }

    [JSInvokable("OnReorder")]
    public async Task HandleReorder(int[] orderedIds)
    {
        await OnOrderChanged.InvokeAsync((MealId, orderedIds.ToList()));
    }

    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("removeCellDragOverHandler", _cellRef);
        if (_dotNetRef is not null)
        {
            await JS.InvokeVoidAsync("destroySortable", _listRef);
            _dotNetRef.Dispose();
        }
    }
}
