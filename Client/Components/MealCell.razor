@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="meal-cell">
    <ul @ref="_listRef" data-date="@Date.ToString("yyyy-MM-dd")" data-mealtype="@MealType.ToString()" class="meal-cell-list">
        @foreach (var item in Items)
        {
            <li data-item-id="@item.Id" class="meal-cell-item">
                <span>@item.ItemName</span>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => OnItemRemoved.InvokeAsync(item.Id))" />
            </li>
        }
    </ul>
    <MudTooltip Text="Add item">
        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small"
                       OnClick="@(() => OnAddRequested.InvokeAsync((Date, MealType)))" />
    </MudTooltip>
</div>

@code {
    [Parameter, EditorRequired] public DateOnly Date { get; set; }
    [Parameter, EditorRequired] public MealType MealType { get; set; }
    [Parameter] public int? MealSlotId { get; set; }
    [Parameter] public List<MealSlotItemResponse> Items { get; set; } = [];
    [Parameter] public EventCallback<(int itemId, DateOnly fromDate, MealType fromMealType, DateOnly toDate, MealType toMealType, int newIndex)> OnItemMoved { get; set; }
    [Parameter] public EventCallback<int> OnItemRemoved { get; set; }
    [Parameter] public EventCallback<(DateOnly date, MealType mealType)> OnAddRequested { get; set; }

    private ElementReference _listRef;
    private DotNetObjectReference<MealCell>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initSortable", _listRef, _dotNetRef, "mealslots");
        }
    }

    [JSInvokable("OnDrop")]
    public async Task HandleDrop(int itemId, string fromDate, string fromMealType, string toDate, string toMealType, int newIndex)
    {
        if (DateOnly.TryParse(fromDate, out var fd) &&
            DateOnly.TryParse(toDate, out var td) &&
            Enum.TryParse<MealType>(fromMealType, out var fmt) &&
            Enum.TryParse<MealType>(toMealType, out var tmt))
        {
            await OnItemMoved.InvokeAsync((itemId, fd, fmt, td, tmt, newIndex));
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_dotNetRef is not null)
        {
            await JS.InvokeVoidAsync("destroySortable", _listRef);
            _dotNetRef.Dispose();
        }
    }
}
