@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="meal-cell @(Items.Count == 0 ? "meal-cell-empty" : "") @CellCssClass"
     style="@(IsActionTarget ? "cursor:pointer;" : "")"
     @onclick="HandleTargetClick">
    <ul @ref="_listRef" data-date="@Date.ToString("yyyy-MM-dd")" data-mealtype="@MealType.ToString()" class="meal-cell-list" style="background:#fff3cd">
        @foreach (var item in Items)
        {
            var isItemSrc = IsSource && PendingSourceItemId == item.Id;
            <li @key="item.Id" data-item-id="@item.Id"
                class="meal-cell-item @(isItemSrc ? "meal-cell-item-source" : "")">
                <span class="meal-cell-item-name" style="background:#d8f5d8">@item.ItemName</span>
                <span class="meal-cell-item-price" style="background:#f5d8f5">@FormatItemPrice(item)</span>
                <span @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Info" Size="Size.Small"
                                   Style="@(IsActionTarget ? "visibility:hidden" : "")"
                                   OnClick="@(() => OnCopyItemRequested.InvokeAsync(item.Id))" />
                </span>
                <span @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Filled.DriveFileMove" Color="Color.Secondary" Size="Size.Small"
                                   Style="@(IsActionTarget ? "visibility:hidden" : "")"
                                   OnClick="@(() => OnMoveItemRequested.InvokeAsync(item.Id))" />
                </span>
                <span @onclick:stopPropagation="true">
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" Size="Size.Small"
                                   Style="background:#ffd8b0"
                                   OnClick="@(() => OnItemRemoved.InvokeAsync(item.Id))" />
                </span>
            </li>
        }
    </ul>
    <div class="meal-cell-footer" style="cursor:pointer;" @onclick:stopPropagation="true" @onclick="HandleFooterClick">
        <span @onclick:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.FileCopy" Color="Color.Info" Size="Size.Small"
                           Style="@(IsActionTarget || Items.Count == 0 ? "visibility:hidden" : "background:#b0d8ff")"
                           OnClick="@(() => OnCopyCellRequested.InvokeAsync())" />
        </span>
        <span @onclick:stopPropagation="true">
            <MudIconButton Icon="@Icons.Material.Filled.DriveFileMove" Color="Color.Secondary" Size="Size.Small"
                           Style="@(IsActionTarget || Items.Count == 0 ? "visibility:hidden" : "")"
                           OnClick="@(() => OnMoveCellRequested.InvokeAsync())" />
        </span>
        <span class="meal-cell-slot-total" style="flex:1; text-align:center; position:relative;">
            @(SlotTotal > 0 ? SlotTotal.ToString("C", _fr) : "")
            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Success" Size="Size.Small"
                           Class="meal-cell-add-icon"
                           Style="@AddIconStyle" />
        </span>
        <span style="visibility:hidden; pointer-events:none;">
            <MudIconButton Icon="@Icons.Material.Filled.FileCopy" Size="Size.Small" />
        </span>
        <span style="visibility:hidden; pointer-events:none;">
            <MudIconButton Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small" />
        </span>
    </div>
</div>

@code {
    private static readonly System.Globalization.CultureInfo _fr = new("fr-FR");

    [Parameter, EditorRequired] public DateOnly Date { get; set; }
    [Parameter, EditorRequired] public MealType MealType { get; set; }
    [Parameter] public int? MealSlotId { get; set; }
    [Parameter] public List<MealSlotItemResponse> Items { get; set; } = [];

    [Parameter] public bool HasPendingAction { get; set; }
    [Parameter] public bool IsSource { get; set; }
    [Parameter] public bool IsCopyMode { get; set; }
    [Parameter] public int? PendingSourceItemId { get; set; }

    private bool IsActionTarget => HasPendingAction && !IsSource;
    private string AddIconStyle => "position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); pointer-events:none;" +
        (IsActionTarget ? " visibility:hidden;" : "");

    private string CellCssClass => IsSource
        ? (IsCopyMode ? "meal-cell-source-copy" : "meal-cell-source-move")
        : IsActionTarget ? (IsCopyMode ? "meal-cell-target-copy" : "meal-cell-target-move") : "";

    private decimal SlotTotal => Items
        .Where(i => i.UnitPrice.HasValue)
        .Sum(i => Math.Ceiling(i.Quantity / i.PackageSize) * i.UnitPrice!.Value);

    private string FormatItemPrice(MealSlotItemResponse item)
    {
        if (!item.UnitPrice.HasValue) return "";
        var cost = Math.Ceiling(item.Quantity / item.PackageSize) * item.UnitPrice.Value;
        return cost.ToString("C", _fr);
    }

    [Parameter] public EventCallback<(int itemId, DateOnly fromDate, MealType fromMealType, DateOnly toDate, MealType toMealType, int newIndex)> OnItemMoved { get; set; }
    [Parameter] public EventCallback<int> OnItemRemoved { get; set; }
    [Parameter] public EventCallback<(DateOnly date, MealType mealType)> OnAddRequested { get; set; }
    [Parameter] public EventCallback<(int? mealSlotId, List<int> orderedIds)> OnOrderChanged { get; set; }
    [Parameter] public EventCallback OnCopyCellRequested { get; set; }
    [Parameter] public EventCallback OnMoveCellRequested { get; set; }
    [Parameter] public EventCallback<int> OnCopyItemRequested { get; set; }
    [Parameter] public EventCallback<int> OnMoveItemRequested { get; set; }
    [Parameter] public EventCallback OnTargetSelected { get; set; }

    private async Task HandleFooterClick()
    {
        if (IsActionTarget)
            await OnTargetSelected.InvokeAsync();
        else
            await OnAddRequested.InvokeAsync((Date, MealType));
    }

    private async Task HandleTargetClick()
    {
        if (IsActionTarget)
            await OnTargetSelected.InvokeAsync();
        else if (Items.Count == 0)
            await OnAddRequested.InvokeAsync((Date, MealType));
    }

    private ElementReference _listRef;
    private DotNetObjectReference<MealCell>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initSortable", _listRef, "mealslots");
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("observeSortable", _listRef, _dotNetRef);
        }
    }

    [JSInvokable("OnDrop")]
    public async Task HandleDrop(int itemId, string fromDate, string fromMealType, string toDate, string toMealType, int newIndex)
    {
        if (DateOnly.TryParse(fromDate, out var fd) &&
            DateOnly.TryParse(toDate, out var td) &&
            Enum.TryParse<MealType>(fromMealType, out var fmt) &&
            Enum.TryParse<MealType>(toMealType, out var tmt))
        {
            await OnItemMoved.InvokeAsync((itemId, fd, fmt, td, tmt, newIndex));
        }
    }

    [JSInvokable("OnReorder")]
    public async Task HandleReorder(int[] orderedIds)
    {
        await OnOrderChanged.InvokeAsync((MealSlotId, orderedIds.ToList()));
    }

    public async ValueTask DisposeAsync()
    {
        if (_dotNetRef is not null)
        {
            await JS.InvokeVoidAsync("destroySortable", _listRef);
            _dotNetRef.Dispose();
        }
    }
}
