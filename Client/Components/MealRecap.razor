@using MenuManager.Shared.Enums
@using MenuManager.Client.Helpers
@inject ItemSupplierCache Cache

<style>
    .mr-wrap {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0;
    }

    .mr-header {
        background: #0F172A;
        color: white;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    /* 5-col grid: × | Nom | €/U | U | Total */
    .mr-col-labels, .mr-row {
        display: grid;
        grid-template-columns: 18px 1fr 56px 32px 58px;
        gap: 4px;
        padding-left: 10px;
        padding-right: 10px;
        box-sizing: border-box;
        width: 100%;
    }

    .mr-col-labels {
        flex-shrink: 0;
        padding-top: 5px;
        padding-bottom: 2px;
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--mud-palette-text-secondary);
    }
    .mr-col-labels > span:nth-child(n+3) { text-align: right; }

    .mr-scroll {
        flex: 1;
        overflow-y: auto;
        min-height: 0;
    }

    .mr-row {
        padding-top: 5px;
        padding-bottom: 5px;
        align-items: start;
        border-top: 1px solid color-mix(in srgb, var(--mud-palette-text-secondary) 12%, transparent);
    }
    .mr-row:hover { background: color-mix(in srgb, var(--mud-palette-text-primary) 5%, transparent); }
    .mr-row-alt { background: color-mix(in srgb, var(--mud-palette-text-primary) 2%, transparent); }
    .mr-row-alt:hover { background: color-mix(in srgb, var(--mud-palette-text-primary) 6%, transparent); }

    .mr-cell-name {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
        overflow: hidden;
    }

    .mr-name {
        font-size: 0.78rem;
        font-weight: 600;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .mr-qty-ctrl {
        display: flex;
        align-items: center;
        gap: 2px;
    }

    .mr-qty-btn {
        width: 18px;
        height: 18px;
        border: 1px solid color-mix(in srgb, var(--mud-palette-text-secondary) 50%, transparent);
        border-radius: 50%;
        background: transparent;
        cursor: pointer;
        font-size: 0.75rem;
        line-height: 1;
        padding: 0;
        color: var(--mud-palette-text-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.1s;
        flex-shrink: 0;
    }
    .mr-qty-btn:hover {
        background: color-mix(in srgb, var(--mud-palette-primary) 18%, transparent);
        border-color: var(--mud-palette-primary);
    }

    .mr-qty-val {
        min-width: 1.4rem;
        text-align: center;
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
    }

    .mr-cell-price {
        font-size: 0.72rem;
        text-align: right;
        padding-top: 4px;
        color: var(--mud-palette-text-secondary);
        white-space: nowrap;
    }

    .mr-cell-num {
        font-size: 0.75rem;
        text-align: right;
        padding-top: 4px;
        color: var(--mud-palette-text-secondary);
    }

    .mr-cell-total {
        font-size: 0.78rem;
        font-weight: 600;
        text-align: right;
        padding-top: 4px;
        white-space: nowrap;
    }

    /* Pinned footer — always visible, flex row */
    .mr-footer-wrap {
        flex-shrink: 0;
        border-top: 2px solid color-mix(in srgb, var(--mud-palette-text-secondary) 20%, transparent);
        background: var(--mud-palette-background, #fff);
        display: flex;
        align-items: baseline;
        gap: 6px;
        padding: 7px 10px;
    }

    .mr-footer-tr    { font-size: 0.78rem; font-weight: 700; color: #1565C0; white-space: nowrap; }
    .mr-footer-cb    { font-size: 0.78rem; font-weight: 700; color: #6A1B9A; white-space: nowrap; }
    .mr-footer-sep   { font-size: 0.78rem; opacity: 0.4; }
    .mr-footer-total { font-size: 0.88rem; font-weight: 700; white-space: nowrap; margin-left: auto; }
</style>

<div class="mr-wrap">

    <div class="mr-header">
        <MudIcon Icon="@Icons.Material.Filled.Receipt" Style="font-size:1.1rem; color:white;" />
        <MudText Typo="Typo.body2" Style="font-weight:700; color:white; margin:0;">@MealType.ToFrenchLabel()</MudText>
        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.55); margin:0;">— @CurrentDate.ToString("dd MMM", _fr)</MudText>
    </div>

    <div class="mr-col-labels">
        <span></span>
        <span>Article</span>
        <span>€/U</span>
        <span>U</span>
        <span>Total</span>
    </div>

    <div class="mr-scroll">
        @if (!_lines.Any())
        {
            <MudText Class="pa-3" Style="font-size:0.75rem;" Color="Color.Secondary">Aucun item.</MudText>
        }
        else
        {
            @foreach (var (line, idx) in _lines.Select((l, i) => (l, i)))
            {
                var cl = line;
                <div class="mr-row @(idx % 2 == 1 ? "mr-row-alt" : "")">
                    <div style="display:flex;align-items:flex-start;padding-top:2px;">
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error"
                                       Size="Size.Small"
                                       Style="padding:0;width:18px;height:18px;min-width:18px;font-size:14px;opacity:0.5;"
                                       OnClick="@(() => RemoveFromRecapAsync(cl))" />
                    </div>
                    <div class="mr-cell-name">
                        <span class="mr-name">@line.Name</span>
                        <div class="mr-qty-ctrl">
                            <button class="mr-qty-btn" @onclick="@(() => ChangeQtyAsync(cl, -1))">−</button>
                            <span class="mr-qty-val">@FmtQty(line.Quantity)</span>
                            <button class="mr-qty-btn" @onclick="@(() => ChangeQtyAsync(cl, +1))">+</button>
                        </div>
                    </div>
                    <span class="mr-cell-price">@(line.UnitPrice.HasValue ? FmtMoney(line.UnitPrice.Value) : "—")</span>
                    <span class="mr-cell-num">@(line.IsRecipe ? "—" : line.PackageCount.ToString())</span>
                    <span class="mr-cell-total">@FmtMoney(line.Cost)</span>
                </div>
            }
        }
        <div style="height:8px;"></div>
    </div>

    <div class="mr-footer-wrap">
        @if (_trTotal > 0) { <span class="mr-footer-tr">TR @FmtMoney(_trTotal)</span> }
        @if (_trTotal > 0 && _cbTotal > 0) { <span class="mr-footer-sep">|</span> }
        @if (_cbTotal > 0) { <span class="mr-footer-cb">CB @FmtMoney(_cbTotal)</span> }
        <span class="mr-footer-total">@FmtMoney(_total)</span>
    </div>

</div>

@code {
    [Parameter]
    public IEnumerable<MealItemResponse> Items { get; set; } = [];

    [Parameter]
    public MealType MealType { get; set; }

    [Parameter]
    public DateOnly CurrentDate { get; set; }

    [Parameter]
    public EventCallback<(int Id, decimal Qty, bool IsRecipe)> OnQtyChange { get; set; }

    private static readonly System.Globalization.CultureInfo _fr = new("fr-FR");

    private List<RecapLine> _lines = [];
    private decimal _total, _trTotal, _cbTotal;

    protected override async Task OnInitializedAsync()
        => await Cache.EnsureLoadedAsync();

    protected override void OnParametersSet()
        => ComputeLines();

    private void ComputeLines()
    {
        decimal tr = 0, cb = 0;
        var lines = new List<RecapLine>();

        foreach (var item in Items)
        {
            if (item.RecipeId.HasValue)
            {
                var cost = CostHelper.ComputeItemCost(item);
                var types = item.RecipeIngredientItemIds
                    .Select(id => Cache.GetBestSupplier(id)?.PaymentType)
                    .Where(pt => pt.HasValue)
                    .Select(pt => pt!.Value)
                    .Distinct().ToList();
                if (types.Count == 1) { if (types[0] == PaymentType.TR) tr += cost; else cb += cost; }
                else { tr += cost / 2; cb += cost / 2; }
                lines.Add(new RecapLine(item.RecipeId.Value, true,
                    item.RecipeName ?? "Recette", item.Quantity, 0, null, cost));
            }
            else
            {
                var best = Cache.GetBestSupplier(item.ItemId);
                var bestPrice = best?.UnitPrice;
                var pkgs = (int)Math.Ceiling(item.Quantity / Math.Max(item.ContentQuantity, 0.001m));
                var cost = CostHelper.ComputeItemCost(item, bestPrice);
                if (best?.PaymentType == PaymentType.TR) tr += cost;
                else if (best?.PaymentType == PaymentType.CB) cb += cost;
                lines.Add(new RecapLine(item.ItemId, false,
                    item.ItemName, item.Quantity, pkgs, bestPrice, cost));
            }
        }

        _lines = lines;
        _total = _lines.Sum(l => l.Cost);
        _trTotal = tr;
        _cbTotal = cb;
    }

    private async Task ChangeQtyAsync(RecapLine line, int delta)
        => await OnQtyChange.InvokeAsync((line.Id, line.Quantity + delta, line.IsRecipe));

    private async Task RemoveFromRecapAsync(RecapLine line)
        => await OnQtyChange.InvokeAsync((line.Id, 0m, line.IsRecipe));

    private static string FmtMoney(decimal v) => v.ToString("0.00 €", _fr);
    private static string FmtQty(decimal v) => v.ToString("0.##", _fr);

    private sealed record RecapLine(
        int Id,
        bool IsRecipe,
        string Name,
        decimal Quantity,
        int PackageCount,
        decimal? UnitPrice,
        decimal Cost);
}
